msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_upgrade_weapon,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_upgrade_weapon,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
