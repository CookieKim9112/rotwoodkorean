#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.COMBAT.CRITICAL_HITS
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.COMBAT.CRITICAL_HITS"
msgid "agent:\n !neutral\n !point\n <#RED>Critical Hits</> deal extra <#RED>Damage</> and appear in <#ATK_CRIT>Pink</>. They happen by random chance when you land an <#RED>Attack</>.\n !gesture\n The likelihood of gettin' them is based on your <#RED>Crit Chance</>, which is affected by your Hunter <#RED>{name_multiple.concept_relic}</> and gear.\n !gruffnod\n Keep in mind, a <#RED>Critical Hit</> is different from a <#BLUE>{name.concept_focus_hit}</>. Landin' <#BLUE>{name_multiple.concept_focus_hit}</> is under your direct control."
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.COMBAT.CRITICAL_HITS_BTN
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.COMBAT.CRITICAL_HITS_BTN"
