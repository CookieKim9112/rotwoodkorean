msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout,struggling_on_eggzy]NOT[has_killed_eggzy,in_town].1
