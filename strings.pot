msgstr ""

#: Quest.dgn_seen_missing_friends_blacksmith_market.QUIP.chitchat:[in_quest_dgn_seen_missing_friends_blacksmith_market,owlitzer_region,role_market_merchant]NOT[wf_town_has_blacksmith].1
msgctxt "Quest.dgn_seen_missing_friends_blacksmith_market.QUIP.chitchat:[in_quest_dgn_seen_missing_friends_blacksmith_market,owlitzer_region,role_market_merchant]NOT[wf_town_has_blacksmith].1"
msgid "agent:\n ...Well?"
msgstr ""

#: Quest.dgn_seen_missing_friends_blacksmith_powerupgrade.QUIP.chitchat:[in_quest_dgn_seen_missing_friends_blacksmith_powerupgrade,owlitzer_region,role_konjurist,wf_town_has_armorsmith]NOT[wf_town_has_blacksmith].1
msgctxt "Quest.dgn_seen_missing_friends_blacksmith_powerupgrade.QUIP.chitchat:[in_quest_dgn_seen_missing_friends_blacksmith_powerupgrade,owlitzer_region,role_konjurist,wf_town_has_armorsmith]NOT[wf_town_has_blacksmith].1"
