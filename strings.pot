#: STRINGS.WEAPON_TIPS.FOCUS_HIT.HAMMER
msgctxt "STRINGS.WEAPON_TIPS.FOCUS_HIT.HAMMER"
msgid "<#BLUE>Focus Hit:</BLUE>\n• Hit multiple enemies with one swing\n• Fully charge a <#RED>Heavy Attack</> combo ender\n• Fully charge a <#RED>Golf Swing</> (<p bind='Controls.Digital.DODGE' color=LIGHT_TEXT>  <p img='images/ui_ftf/arrow_right.tex' color=0 scale=0.4>  Back + <p bind='Controls.Digital.ATTACK_HEAVY' color=LIGHT_TEXT>)"
msgstr ""

#: STRINGS.WEAPON_TIPS.FOCUS_HIT.POLEARM
msgctxt "STRINGS.WEAPON_TIPS.FOCUS_HIT.POLEARM"
