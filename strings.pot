#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.REWARD_TIER_FOUR.TALK
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.REWARD_TIER_FOUR.TALK"
msgid "agent:\n !happy\n !dubious\n ...!\n !shocked\n Hunter... you've completed all my lessons. Do you know how often a Hunter completes all my lessons?\n !neutral\n !point\n Not often! You have officially graduated from my Hunter's class.\n !nervous\n This... this is... <i>(snrrff)</>\n player:\n {name.npc_dojo_master}, are those <i>tears</>?\n agent:\n !neutral\n !agree\n No. Shut up. {name.dojo_cough} Class dismissed.\n !happy\n !disagree\n ...<z 0.7>Just got a little... dust in my eye, is all...</>"
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.REWARD_TIER_ONE.TALK
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.REWARD_TIER_ONE.TALK"
msgid "!happy\n !think\n Y'know, it's nice to see a Hunter take an interest in their education.\n !gesture\n Here, have a little treat for completing your first lesson. On me, ghe-he-he."
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.REWARD_TIER_THREE.TALK
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.REWARD_TIER_THREE.TALK"
msgid "!happy\n !gesture\n 'Ey, kid. {name.dojo_cough} Take this.\n !shrug\n Consider it a gold star for yer studies."
msgstr ""

