msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.DEFENSE.DODGE_CANCEL
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.DEFENSE.DODGE_CANCEL"
msgid "agent:\n !neutral\n !point\n Every <#RED>Attack</> you can perform's got a window of time where <#RED>Dodging</> will cancel its animation, but not its <#RED>Damage</>.\n !happy\n !gesture\n And although them animations is real pretty, cancelling them early allows you to <#RED>Attack</> again sooner, making it easier to build <#RED>Combos</>.\n !neutral\n !gruffnod\n <#RED>Attacks</> all got different cancel windows though, so you'll have to practice to get a feel for <#RED>{name.concept_dodge} Cancelling</> your favourite moves."
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.DEFENSE.DODGE_CANCEL_BTN
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.DEFENSE.DODGE_CANCEL_BTN"
msgid "Dodge Cancels"
msgstr ""

