#: Quest.after_find_all_keys_scout.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,has_volcanokey2,has_volcanokey3,in_quest_after_find_all_keys_scout,in_town,role_scout].1
msgctxt "Quest.after_find_all_keys_scout.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,has_volcanokey2,has_volcanokey3,in_quest_after_find_all_keys_scout,in_town,role_scout].1"
msgid "agent:\n !neutral\n !greet\n Hunter! I finished my <#BLUE>Grandpa's</> <#RED>Diary</>."
msgstr ""

#: Quest.after_find_first_key_dojo.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,in_quest_after_find_first_key_dojo,in_town,qc_after_find_first_key_scout,role_dojo]NOT[has_volcanokey2,has_volcanokey3].1
msgctxt "Quest.after_find_first_key_dojo.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,in_quest_after_find_first_key_dojo,in_town,qc_after_find_first_key_scout,role_dojo]NOT[has_volcanokey2,has_volcanokey3].1"
msgid "agent:\n !neutral\n !point\n I can tell you've got something to tell me, kid. Out with it."
msgstr ""

#: Quest.after_find_first_key_scout.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,in_quest_after_find_first_key_scout,in_town,role_scout]NOT[has_volcanokey2,has_volcanokey3].1
msgctxt "Quest.after_find_first_key_scout.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,in_quest_after_find_first_key_scout,in_town,role_scout]NOT[has_volcanokey2,has_volcanokey3].1"
msgid "agent:\n !neutral\n !diary_start\n ...\n player:\n Are you reading the Diary {name.npc_refiner} stole from your Grandpa?\n agent:\n !neutral\n !agree\n Hm? Oh, yes, minus the few <#RED>Pages</> we recovered already. Speaking of...\n !gesture\n Remember the <#RED>Page</> about how my <#BLUE>Grandpa</> designed the <#KONJUR>{name.i_town_grid_cryst}</> and <#KONJUR>{name.konjur} Pipeline Energy Grid</> that our <#KONJUR>Bubble Shield</> tech was meant to run off of?"
msgstr ""

#: Quest.after_find_second_key_dojo.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,has_volcanokey2,in_quest_after_find_second_key_dojo,in_town,qc_after_find_second_key_scout,role_dojo]NOT[has_volcanokey3].1
msgctxt "Quest.after_find_second_key_dojo.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,has_volcanokey2,in_quest_after_find_second_key_dojo,in_town,qc_after_find_second_key_scout,role_dojo]NOT[has_volcanokey3].1"
msgid "agent:\n !neutral\n !dubious\n What is it, kid? You look all watery-eyed. Do you need more push-ups?"
msgstr ""

#: Quest.after_find_second_key_scout.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,has_volcanokey2,in_quest_after_find_second_key_scout,in_town,role_scout]NOT[has_volcanokey3].1
msgctxt "Quest.after_find_second_key_scout.QUIP.chitchat:[has_killed_grimhollow,has_volcanokey1,has_volcanokey2,in_quest_after_find_second_key_scout,in_town,role_scout]NOT[has_volcanokey3].1"
msgid "agent:\n !neutral\n !diary_start\n Oh, hey, Hunter. I could use a bit of a break from <#BLUE>Grandpa's</> <#RED>Diary</>."
msgstr ""

#: Quest.after_insert_heart_5_scout.QUIP.chitchat:[has_deposited_1_zone_2_hearts,has_deposited_4_zone_1_hearts,has_diarypage1,in_quest_after_insert_heart_5_scout,in_town,role_scout]NOT[has_deposited_2_zone_2_hearts].1
msgctxt "Quest.after_insert_heart_5_scout.QUIP.chitchat:[has_deposited_1_zone_2_hearts,has_deposited_4_zone_1_hearts,has_diarypage1,in_quest_after_insert_heart_5_scout,in_town,role_scout]NOT[has_deposited_2_zone_2_hearts].1"
msgid "agent:\n !neutral\n !shrug\n <i>(sigh)</> Still not enough power to generate the <#KONJUR>Shield</>, and I just don't know why the <#KONJUR>{name.konjur} Pipeline Energy Grid</> is failing!\n !dejected\n My <#BLUE>Grandpa</> is the key. He <i>invented</> all this. We must save him to save our home from the <#RED>{name.rot}</>, Hunter!\n !notebook\n The <#KONJUR>{name.teffrometer}</> readings show he's been moved!\n !gruffnod\n I'm glad you have all that <#RED>{name.rot_boss}</> power. Prepare yourself, Hunter. We ride at dawn!"
msgstr ""

#: Quest.after_insert_heart_6_scout.QUIP.chitchat:[has_deposited_2_zone_2_hearts,has_deposited_4_zone_1_hearts,has_diarypage2,in_quest_after_insert_heart_6_scout,in_town,qc_after_insert_heart_5_scout,role_scout]NOT[has_deposited_3_zone_2_hearts].1
msgctxt "Quest.after_insert_heart_6_scout.QUIP.chitchat:[has_deposited_2_zone_2_hearts,has_deposited_4_zone_1_hearts,has_diarypage2,in_quest_after_insert_heart_6_scout,in_town,qc_after_insert_heart_5_scout,role_scout]NOT[has_deposited_3_zone_2_hearts].1"
msgid "agent:\n !neutral\n !angry\n The <#RED>{name_multiple.rot}</> are toying with us, with Grandpa. But we still have his <#KONJUR>Teffra</> signature, which means he's alive.\n !notebook\n We have them cornered in the <#BLUE>{name.grimhollow_volcano}</>, our old home. There's nowhere left for them to run.\n !point\n This is it. We'll save <#BLUE>Grandpa</>, he'll save us, and everything will go back to how it was."
msgstr ""

#: Quest.after_insert_heart_scout_bnd.QUIP.chitchat:[has_deposited_3_zone_1_hearts,in_quest_after_insert_heart_scout_bnd,in_town,role_scout]NOT[has_deposited_4_zone_1_hearts].1
msgctxt "Quest.after_insert_heart_scout_bnd.QUIP.chitchat:[has_deposited_3_zone_1_hearts,in_quest_after_insert_heart_scout_bnd,in_town,role_scout]NOT[has_deposited_4_zone_1_hearts].1"
msgid "agent:\n !happy\n !clap\n Incredible work, Hunter. We're just <i>one</> <#KONJUR>{name.i_konjur_heart}</> shy of powering the <#KONJUR>Bubble Shield</>!\n !neutral\n !think\n Once we have the <#RED>{name_multiple.rot}</> cleared out and everyone's resettled, I think I'm going to restart my Grandpa's <#KONJUR>{name.konjur}</> laboratory.\n player:\n That sounds great!\n agent:\n !happy\n !notebook\n We'll jump-start the old <#KONJUR>{name.konjur} Pipeline Energy Grid</>, get the <#KONJUR>{name.konjur}</> flowing again, and put our home back to how it was!"
msgstr ""

#: Quest.after_insert_heart_scout_mt.QUIP.chitchat:[has_deposited_1_zone_1_hearts,in_quest_after_insert_heart_scout_mt,in_town,role_scout]NOT[has_deposited_2_zone_1_hearts].1
msgctxt "Quest.after_insert_heart_scout_mt.QUIP.chitchat:[has_deposited_1_zone_1_hearts,in_quest_after_insert_heart_scout_mt,in_town,role_scout]NOT[has_deposited_2_zone_1_hearts].1"
msgid "agent:\n !happy\n !clap\n Did you see that, Hunter? My design... It didn't explode, or implode, or any of the 'plodes!\n player:\n I <i>knew</> it'd work. Did... did it work? \n agent:\n !happy\n !dubious\n Well, not <i>yet</>. Otherwise the <#KONJUR>Bubble Shield</> would be shining above us. But that <#KONJUR>{name.i_konjur_heart}</> you deposited got us on our way.\n !gesture\n By my calculations, we'll need just three more to jump-start the old <#KONJUR>{name.konjur} Pipeline Energy Grid</> and get the <#KONJUR>Shield</> up and running for good!\n player:\n \"Just\" three? Ha. Haha. Ha. And I'm \"just\" having a heart attack...\n agent:\n !point\n Aw, c'mon Hunter! You made quick work of <#RED>{name.megatreemon}</>! What's three more <#RED>{name_multiple.rot_boss}</>? Besides, you got a power boost, didn't you?\n player:\n That <i>did</> feel nice...\n agent:\n !agree\n Well imagine that times three!\n player:\n Okay, I'm on it!\n agent:\n !clap\n I'm proud to work with you, Hunter!\n !closedeyes\n Hm..."
msgstr ""

#: Quest.after_insert_heart_scout_owl.QUIP.chitchat:[has_deposited_2_zone_1_hearts,in_quest_after_insert_heart_scout_owl,in_town,role_scout]NOT[has_deposited_3_zone_1_hearts].1
msgctxt "Quest.after_insert_heart_scout_owl.QUIP.chitchat:[has_deposited_2_zone_1_hearts,in_quest_after_insert_heart_scout_owl,in_town,role_scout]NOT[has_deposited_3_zone_1_hearts].1"
msgid "agent:\n !happy\n !notebook\n Excellent work, Hunter! I've done some calculations--we need two more <#KONJUR>{name_multiple.i_konjur_heart}</> to get the <#KONJUR>Bubble Shield</> running. \n !neutral\n !dubious\n The calculations I did were harder than 'four minus two,' by the way."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abadoned_last_run,has_seen_thatcher,in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abadoned_last_run,has_seen_thatcher,in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp,role_refiner].1"
msgid "!neutral\n !agree\n If a <#RED>{name.rot_boss}</> was melting <i>my</> face off with hot guitar licks, I'd split, too."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].1"
msgid "!neutral [keep-for-room]\n !disagree\n <#BLUE>Grandpa's</> lab isn't like I remember it from when I was young.\n !think\n It seems smaller. And more hostile."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].2"
msgid "!neutral [keep-for-room]\n !gruffnod\n That was overwhelming for me too, so I don't judge you, Hunter.\n !point\n But we can't delay long--the <#KONJUR>Second Eruption</> could still happen any moment!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].3"
msgid "!happy [keep-for-room]\n !agree\n Good idea to retreat! Now we can find more <#KONJUR>{name_multiple.i_konjur_heart}</>.\n !gruffnod\n The power boost will help us in our next run at <#BLUE>{name.tefframech_volcano}</>!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,last_run_was_tefframech_volcano,role_scout]NOT[has_seen_tefframech].4"
msgid "!neutral [keep-for-room]\n !gruffnod\n Smart of you to high-tail it out of there when you did.\n !gesture\n There's too much riding on us stopping <#BLUE>Grandpa</> to fail now."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_apothecary].1"
msgid "!neutral\n !think\n Back so soon? Did you forget to water the plants?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_apothecary].2"
msgid "!neutral\n !shrug\n I guess even Hunters get nervous sometimes.\n !happy\n !gesture\n That's kind of nice to know, actually."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!greet\n I've been looking for you!\n !point\n Can you tell <#BLUE>{name.npc_scout}</> the {name.i_damselfly} should be a community vehicle?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2"
msgid "!greet\n Welcome home!\n !think\n \"Home.\" Huh. It's got a nice mouthfeel."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n !closedeyes\n Still alive, I see.\n !gruffnod\n Good."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_blacksmith].2"
msgid "!neutral\n !closedeyes\n Back for better weapons, are ye?\n !dubious\n Wise."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_cook].1"
msgid "!shocked\n Back so soon?\n !neutral\n !think\n Did you forget to pack a lunch?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_cook].2"
msgid "!happy\n !gesture\n It's alright Hunter, sometimes you've gotta know when to cut and run.\n !neutral\n !shrug\n I ain't gonna fault you for that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_refiner].1"
msgid "!neutral\n !shrug\n When you've gotta split, you've gotta split."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_refiner].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_refiner].2"
msgid "!neutral\n !think\n Was the {name.c_konjur} just not <#KONJUR>{name.konjur}-ing</> in that run?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!happy\n !gesture\n Better to tuck tail on a bad Hunt than get chomped.\n !agree\n The important thing is we made it back."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[abandoned_last_run,in_quest_chat_fluff_fallback,in_town,role_scout].2"
msgid "!happy\n !gesture\n I respect your tactical decision to retreat.\n !agree\n Very smart."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_0,friend_npc_armorsmith_at_least_level_4,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_0,friend_npc_armorsmith_at_least_level_4,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!happy\n !think\n With some <#RED>{name_multiple.upgrade_ingot}</>, I bet I could learn some new techniques.\n !bliss\n Then I could make all your armour way more powerful. Check my shopping list at the <#RED>{name.i_station_armorsmith}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_0,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_0,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!happy\n !point\n Check out the <#RED>{name.i_station_armorsmith}</> over there to see all the <#RED>Armour Upgrades</> we can do for you!\n !gesture\n I mean, we do need some <#RED>{name.rot} {name_multiple.material}</> to work with, but that shouldn't be too hard for you to get, right?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_1,has_deposited_2_zone_2_hearts,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_1,has_deposited_2_zone_2_hearts,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!happy\n !gesture\n I think <#BLUE>{name.npc_lunn}</> and I could do more if we upgraded my tools!\n !point\n Let's get those materials for {name.armourtools2}.\n !clap\n Then I bet I could totally upgrade <i>all</> your armour even more!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_1,has_deposited_3_zone_2_hearts,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[armour_fortification_level_1,has_deposited_3_zone_2_hearts,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "agent:\n !neutral\n !think\n But... doing all those upgrades on that new armour made me realize...\n !point\n I'm definitely gonna need to upgrade my <#RED>{name.armourtools1}</> too.\n !think\n Scratch that--I'll probably need to make a whole new kit to handle working with all that <#KONJUR>{name.konjur}</>.\n !bliss\n Trust me, the upgrades I'll be able to do with it will be totally worth it!\n !happy\n !dubious\n Sooooo could you pick up a few materials for me? Pretty please?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[boss_weapon_equipped,has_any_boss_weapon,in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[boss_weapon_equipped,has_any_boss_weapon,in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1"
msgid "!happy\n !dubious\n Check <i>you</> out! <#RED>{name.weapon_boss}</> and everything! Strut your stuff, Hunter!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[broken_corestone_weapon_equipped,corestone_weapon_equipped,has_any_boss_weapon,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[broken_corestone_weapon_equipped,corestone_weapon_equipped,has_any_boss_weapon,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n !dubious\n Looks like yer <#RED>{name.weapon_crystal}</> needs some repairs, ay?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[broken_corestone_weapon_equipped,corestone_weapon_equipped,in_quest_chat_fluff_fallback,in_town,role_blacksmith]NOT[has_any_boss_weapon].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[broken_corestone_weapon_equipped,corestone_weapon_equipped,in_quest_chat_fluff_fallback,in_town,role_blacksmith]NOT[has_any_boss_weapon].1"
msgid "!neutral\n !dubious\n Hrm. Yer weapon is lookin' a bit worse for wear.\n !gesture\n Dunnae worry, I can fix up yer <#RED>{name.weapon_crystal}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].1"
msgid "!happy\n !point\n <#BLUE>{name.npc_scout}</> tells me you've completed another challenge!\n !gesture\n Go ahead and claim yer <#RED>Mastery</> at the <#BLUE>{name.i_masteries_station}</> whenever you're ready."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].2"
msgid "!happy\n !point\n I hear you finished off one of my challenges, Hunter.\n !gesture\n I've got a little <#KONJUR>Treat</> for you at the <#BLUE>{name.i_masteries_station}</>, when you're ready to claim it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].3"
msgid "!happy\n !think\n Seems like someone went and finished another one of my challenges.\n !point\n If that sounds like you, there's a <#KONJUR>Treat</> for you at the <#BLUE>{name.i_masteries_station}</>. Go on. If it's you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].4"
msgid "!neutral\n !point\n <#RED>Masteries</> aren't to be taken lightly, Hunter.\n !gruffnod\n You complete one, you're owed <#KONJUR>Compensation</>. The <#BLUE>{name.i_masteries_station}</> is where you claim what's yours."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].5"
msgid "!happy\n !agree\n Any <#RED>Master</> I've known'll take a <#KONJUR>Reward</> that's <i>earned.</>\n !point\n And Hunter, you've earned it. Head over to the <#BLUE>{name.i_masteries_station}</>. It's waitin'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_claim_mastery,in_quest_chat_fluff_fallback,in_town,role_dojo].6"
msgid "!happy\n !gruffnod\n Nothin' feels better than a well-deserved <#KONJUR>Treat</>, Hunter.\n !gesture\n <#BLUE>{name.i_masteries_station}</>. Think somethin's there with yer name on it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_craft_potion,in_quest_chat_fluff_fallback,role_travelling_salesman]NOT[needs_potion].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_craft_potion,in_quest_chat_fluff_fallback,role_travelling_salesman]NOT[needs_potion].1"
msgid "agent:\n !neutral\n !shocked\n Why, my friend! Are you aware your flask is full of <i>inferior product</i>?!\n !think\n Golly, I just hate to see a salt of the earth <#BLUE>{player.species}</> like yourself get ssswindled.\n !happy\n !dubious\n Tell you what, why don't you empty that swill out with <p bind='Controls.Digital.USE_POTION' color=BTNICON_DARK> and I'll top you up with some bonafide {name.npc_doc_lastname}-brand <#RED>Potion</> instead?\n player:\n Wow! You'd do that for me?\n agent:\n !point\n Undoubtedly!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_bandi_swamp,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_bandi_swamp,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !dubious\n Free <#RED>Upgrade</> time?\n !notebook\n It'll make your fight with <#RED>{name.bandicoot}</> more survivable."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_eggzy_tundra,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_eggzy_tundra,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !dubious\n You look like you could use an <#RED>Upgrade</>.\n !happy\n !gesture\n Aren't you lucky? I've got a free one right here for you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !dubious\n Hey, do you want your free <#RED>Upgrade</> or what?\n !point\n Make it quick, I need to get back to work."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_owlitzer_forest,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_owlitzer_forest,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !point\n Just the Hunter I was hoping to see.\n !notebook\n I've got some free <#RED>Upgrades</> for you to test out."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !dubious\n Wanna warm up with a free <#RED>Upgrade</>?\n !notebook\n I could use the break."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_thatcher_swamp,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_free_upgrade,in_quest_chat_fluff_fallback,location_thatcher_swamp,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !point\n It's your lucky day!\n !notebook\n I've got a free <#RED>Upgrade</> for you to try out."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !greet\n Oh, hey. Come for some free <#RED>Upgrades</>? Sure, I have time."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].2"
msgid "!neutral\n !gesture\n You've got some free <#RED>Upgrades</> waiting. Save some precious <#KONJUR>{name.i_konjur}</>..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].3"
msgid "!neutral\n !greet\n Come to claim your free <#RED>Upgrades</>?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[can_get_multiple_free_upgrades,in_quest_chat_fluff_fallback,role_konjurist,upgradable_powers].4
