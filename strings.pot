msgctxt "Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_HAS_RESOURCES_2B"
msgid "I think I'll pass, thanks."
msgstr ""

#: Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_HAS_RESOURCES_3A
msgctxt "Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_HAS_RESOURCES_3A"
msgid "Fine, you talked me into it."
msgstr ""

#: Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_HAS_RESOURCES_3B
msgctxt "Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_HAS_RESOURCES_3B"
msgid "No, I'm really okay."
msgstr ""

#: Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_NO_RESOURCES_1
msgctxt "Convo.dgn_secondmeeting_potion.HUB0.convo.giver.STATE_0.QUESTION_NO_RESOURCES_1"
