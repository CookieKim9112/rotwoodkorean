msgctxt "Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_ANNOYING_END"
msgid "agent:\n !neutral [keep-for-room]\n !angry\n \"Call around\"?! I am the ONLY store--!!\n !dubious\n Thou art joking. \n !dejected\n <i>(sigh)</> <z 0.7>How I loathe interacting with the clientele.</z>"
msgstr ""

#: Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_EARLY_END
msgctxt "Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_EARLY_END"
msgid "agent:\n !happy\n !wink\n Make sure to tell your Hunter friends about me once thou returnst home."
msgstr ""

#: Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_LATE_END
msgctxt "Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_LATE_END"
msgid "agent:\n !neutral [keep-for-room]\n !dubious\n Oh. What a relief it is to have that settled. Hurrah.\n !wink\n Thou art free to continue browsing now, little culver."
msgstr ""

#: Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.QUESTION_1A
msgctxt "Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.QUESTION_1A"
