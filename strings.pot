#: Quest.chat_fluff_fallback.QUIP.chitchat:[corestone_weapon_equipped,in_quest_chat_fluff_fallback,in_town,role_blacksmith]NOT[charged_corestone_weapon_equipped,has_any_boss_weapon].1
