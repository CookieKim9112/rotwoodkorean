#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.FRENZIED_HUNTS
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.FRENZIED_HUNTS"
msgid "agent:\n !neutral\n !point\n <#RED>Frenzied</> Hunts are tougher than regular Hunts, but you need them for progression-- they're the only way to get those precious <#KONJUR>{name_multiple.i_konjur_heart}</>.\n !dubious\n Be mindful, though. <#RED>Reviving</> allies is free on regular Hunts, but on <#RED>Frenzied</> Hunts, it'll cost you some <#RED>Health</> to pick up a friend.\n !happy\n !gruffnod\n If you're worried, don't be. <#RED>Frenzies</> might be challenging, but you'll never be given access to one that's beyond your ability."
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.FRENZIED_HUNTS_BTN
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.FRENZIED_HUNTS_BTN"
msgid "Frenzied Hunts"
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.FRENZIED_HUNTS_BTN_ALT
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.FRENZIED_HUNTS_BTN_ALT"
msgid "Frenzied Hunts, again?"
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.POWER_DROPS
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.POWER_DROPS"
msgid "agent:\n !neutral\n !point\n You can use the <#KONJUR>Power Crystals</> you find during a Hunt to manifest mighty abilities, increasing your power and survivability in the field.\n !happy\n !gesture\n There are all sorts of different <#RED>{name_multiple.concept_relic}</>, and many of them pair well together to become extra powerful. Get creative and try different combinations.\n !neutral\n !point\n Your <#RED>{name_multiple.concept_relic}</> always wear off by the time you get home, so there's no downside to experimenting."
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.POWER_DROPS_BTN
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.GENERAL.POWER_DROPS_BTN"
