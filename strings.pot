msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].1"
msgid "!happy\n !think\n Good memories in this lab...\n !neutral\n !disagree\n ... bad ones, too. Hm. Let's go see the old fox, huh?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].2"
msgid "!neutral\n !dubious\n I doubt <#BLUE>Doc {name.flitt_lastname}</> is gonna be stoked to see me."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].3"
msgid "!neutral\n !gruffnod\n If you're taking requests, I'd like to see the old fox get thumped but good."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].4"
msgid "!neutral\n !gesture\n Why keep the old fox waiting?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_tefframech_region,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[has_killed_tefframech,in_town].5"
msgid "!neutral\n !point\n Watch out for <#BLUE>{name.npc_scout}</> in there. \n !think\n It's gonna get... emotional."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_thatcher_region,in_quest_chat_fluff_fallback,in_town,role_refiner]NOT[has_seen_thatcher].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[first_run_in_thatcher_region,in_quest_chat_fluff_fallback,in_town,role_refiner]NOT[has_seen_thatcher].1"
msgid "!neutral\n !dubious\n You heard <i>guitar</> in <#BLUE>{name.thatcher_swamp}</>? <#RED>{name_multiple.rot}</> rocking? That rules."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_10,in_quest_chat_fluff_fallback,in_town,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_10,in_quest_chat_fluff_fallback,in_town,role_apothecary].1"
msgid "!happy\n !bliss\n <#BLUE>{name.npc_armorsmith} was really impressed with the stitching on my cowl!\n !neutral\n !think\n ...She looked a little greener than usual after I told her how I made it, though."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_10,in_quest_chat_fluff_fallback,in_town,role_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_10,in_quest_chat_fluff_fallback,in_town,role_apothecary].2"
msgid "!happy\n !gesture\n I'm getting a lot better at talking to folks.\n !closedeyes\n But I still need to take a break sometimes."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].1"
msgid "!neutral\n !shrug\n Taking care of plants is easy.\n !closedeyes\n They tell you what they need without talking."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].2"
msgid "!neutral\n !think\n <#BLUE>{name.npc_armorsmith}</> never seems to run out of things to say.\n !gesture\n ...Maybe that's because she repeats what <i>other</> people say, too."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].3"
msgid "!neutral\n !closedeyes\n I miss Granny's hut. And our garden.\n !shrug\n ...But it's overrun with <#RED>{name_multiple.rot}</> now. So."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].4"
msgid "!happy\n I like watching the plants grow.\n !agree\n They're doing such a good job."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].5"
msgid "!neutral\n !think\n <#BLUE>{name.npc_scout}</> keeps talking about a place called 'the Brinks'?\n !shrug\n Is that where the sky ships took everybody?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].6"
msgid "!neutral\n !think\n There's nothing wrong with dirt. It's natural.\n !angry\n What's <i>weird</> is everyone telling me to 'wash my hands' and 'stop wiping dirt in your armpits'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].7"
msgid "!neutral\n !closedeyes\n Everyone here talks so much.\n !dejected\n It's so tiring..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].8"
msgid "!neutral\n !think\n Do you ever feel bad for the <#RED>{name_multiple.rot}</>?\n !gesture\n I do sometimes. It's not really their fault they're like that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_apothecary].9"
msgid "!neutral\n !closedeyes\n I was just thinking...\n !closedeyes\n ...about how much I want to take a nap."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_apothecary].1"
msgid "agent:\n !neutral\n !dejected\n I really miss my Granny. Even though I know a part of her is always close by.\n player:\n You mean her spirit?\n agent:\n !neutral\n !gesture\n Oh, no. Her pelt. Granny left me instructions for how to prepare it when she passed. I like knowing she'll always be close, even now that she's gone.\n player:\n Her... <i>pelt?</> You mean... your cowl is...?\n agent:\n !happy\n !agree\n She turned out really well, didn't she? I think she'd be proud of my work.\n player:\n I... um... excuse me, I think I need to go for a walk...\n agent:\n !neutral\n !shrug\n Okay."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_apothecary_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_apothecary].2"
msgid "!neutral\n !think\n I <i>want</> to like being around people. But it's hard sometimes.\n !nervous\n ...What if I never get used to it?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!happy\n !gesture\n You know what makes me a good friend? I'm a great secret-keeper.\n !point\n For example, I've never told anyone that <#BLUE>{name.npc_scout}'s</> self-conscious about their snout."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2"
msgid "!happy\n !gesture\n You wouldn't believe the kinds of juicy secrets people will just write down for anyone to see!\n !shrug\n I mean sure, they write it in a 'diary' or whatever, but what's to stop someone from taking a little peek when no one's around?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].3"
msgid "!dejected\n Ugh. {name.rot} stains just never wash out right...\n !happy\n !think\n It's better to just cut around the stain and sew on a new patch of fabric."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_armorsmith].4"
msgid "!happy\n !point\n Hey, Hunter! What's a juicy secret you've never told anyone before?\n !neutral\n !shrug\n ...Aww, don't give me that look. I was just <i>asking!</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!neutral\n !think\n Some people say I won't amount to anything, then other people say I'm 'too much'.\n !shrug\n Well which is it? Make up your minds!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2"
msgid "!happy\n !wavelunn\n Why would I ever be lonely when I've got <#BLUE>{name.npc_lunn}</> for company?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_armorsmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_armorsmith].3"
msgid "!neutral\n !think\n I think the fact that I have better conversations with my leather cutter than with most people says more about most people than it does about me."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_is_level_10,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_is_level_10,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!happy\n !bliss\n <#BLUE>{name.npc_lunn}</> and Balki are still going strong. I feel kinda silly for getting so worked up over thinking they wouldn't want me around. We still hang out all the time!\n !think\n But I think it's good that <#BLUE>{name.npc_lunn}</> and I aren't spending <i>all</> our time together anymore.\n !laugh\n It was like we shared a brain! I guess there <i>is</> such a thing as being too close."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_is_level_4,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_is_level_4,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!neutral\n !think\n <#BLUE>{name.npc_lunn}</> was a little jealous of Balki at first, but they seem to be getting along better now.\n !happy\n !bliss\n I think with a little time, they'll be great friends!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_is_level_4,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_armorsmith_is_level_4,in_quest_chat_fluff_fallback,in_town,role_armorsmith].2"
msgid "!neutral\n !dejected\n Sorry <#BLUE>{name.npc_lunn}'s</> been giving you the silent treatment, Hunter.\n !wavelunn\n I think he's still a little upset about the whole whetstone thing."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!happy\n !think\n Maybe I've got time ta read one more page... <z 0.7>It's sure nice havin' something ta mark my spot-- I can finally stop re-reading the first chapter...</z>\n !neutral\n !shocked\n Och-- err, Hunter! ...How long have ye been standin' there?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n !dubious\n Ye wanna know where I got this scar, eh?\n !think\n Ah... just a wee 'workplace accident'... It happens in my line o' work.\n !happy\n !dubious\n 'Specially when a customer and I didnae see eye-to-eye on a payment plan."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].2"
msgid "!neutral\n !point\n Here's a free bit of advice, Hunter-- ye'll sleep better knowin' ye got a sharp blade within arm's reach.\n !shrug\n I like ta keep mine under the pillow, meself."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].3"
msgid "!neutral\n !disagree\n ...<z 0.7>'Henri'? Sure doesnae look like an 'Henri' ta me...</z> Oi, Hunter!\n !point\n Would ye tell yer <#BLUE>{name.job_armorsmith}</> she cannae name other people's tools?!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_blacksmith].4"
msgid "!neutral\n !dubious\n Hmph. Looks like ye've been in a scrape or two.\n !point\n Mind yerself out there."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_4,in_quest_chat_fluff_fallback,in_town,role_blacksmith,weapon_fortification_level_0].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_4,in_quest_chat_fluff_fallback,in_town,role_blacksmith,weapon_fortification_level_0].1"
msgid "!neutral\n !gesture\n Want to upgrade yer weapons even more?\n !point\n I'll need materials. Check my list on the <#RED>Weapon Racks</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n !think\n They called me 'Hamish the Hammer' back in the Guild.\n !gesture\n On account o' my soft touch 'n way with words."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].2"
msgid "!neutral\n !gruffnod\n The Blacksmith's Guild was like a big family.\n !point\n Ye never turn yer back on family... gives 'em too clear of a shot at yer vital parts."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].3"
msgid "!neutral\n !dubious\n Ye think a <#RED>{name.yammo}'s</> got a mean mug?\n !gruffnod\n Ye shoulda met my old Guildmaster."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].4"
msgid "!happy\n !gruffnod\n Hmph. Nice racket <#BLUE>{name.npc_scout}'s</> got goin' here. Coulda make a mighty lucrative business haulin' {name.konjur} back ta <#BLUE>the Brinks</>...\n !happy\n !disagree\n Heh. 'Course, the kit's got much loftier goals than that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].5"
msgid "!neutral\n !point\n The Blacksmith's Guild takes care o' its own.\n !shrug\n 'Course, if ye cross 'em, they'll 'take care' of ye in a more permanent sorta way."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].6"
msgid "!neutral\n !think\n A lot's happened in the last ten years...\n !disagree\n I cannae help but wonder if things really can go back ta the way they were."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_blacksmith].7"
msgid "!neutral\n !think\n Hmph. <#BLUE>{name.npc_armorsmith}</> was goin' on about how I'm 'unapproachable'.\n !shrug\n ...Doesn't seem ta stop her from comin' over and talkin' my ear off, though."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_is_level_10,in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_is_level_10,in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1"
msgid "!neutral\n !shocked\n <#BLUE>{name.npc_blacksmith}</>. A <i>romantasy</> fan?\n !happy\n !think\n Beneath his iron exterior lies a soft molten core. Should've known."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_is_level_10,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_is_level_10,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n I suppose I'd call us... friends.\n !point\n Dunnae tell anyone I said that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_is_level_6,in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_blacksmith_is_level_6,in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1"
msgid "!neutral\n !shrug\n All <#BLUE>{name.npc_blacksmith}</> does is grunt and work.\n !happy\n !clap\n He's the perfect collaborator!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].1"
msgid "!neutral\n !think\n Oh, uh, sorry I'm just a bit busy with... vegetable sorting.\n !happy\n !shrug\n Gotta make sure all those sneaky veggies are in order, y'know?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].2"
msgid "!angry\n Hey, wouldya tell <#BLUE>{name.npc_armorsmith}</> to stop pokin' her nose around my kitchen?\n !neutral\n !think\n Doesn't she have more important things to do?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].3"
msgid "!neutral\n !disagree\n Hunter... <#BLUE>{name.npc_dojo_master}</> told me somethin' awful.\n !nervous\n He said that on your Hunts you find <#KONJUR>Teffra Crystals</> and... <i>smash them?!</>\n !dejected\n Tell me it ain't true! Do you have any idea how much those'd be worth in <#BLUE>the Brinks?!</>\n !shocked\n Er, I mean, how <i>pretty</> they are when they're all big and whole?!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].4"
msgid "!neutral\n !dubious\n You haven't overheard any gripin' about my cookin' have you?\n !point\n Comments flyin' about the likes of 'she don't know a fritter from a flambé'?\n !angry\n I know what I'm doin'! Some folks just don't appreciate simple, unassumin', country-style food, is all."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].5"
msgid "!neutral\n !think\n As soon as I'm done cookin', there's all these dishes to clean.\n !dejected\n Then when I'm done cleanin' the dishes, it's time to cook again.\n !scared\n Where does it end?!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_2,in_quest_chat_fluff_fallback,in_town,role_cook].6"
msgid "!happy\n !gesture\n I just found <#RED>{name.blarmadillo}</> spit is a decent replacement for butter when you're in a pinch.\n !think\n Amazin' what you learn when you run out of butter..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_9,in_quest_chat_fluff_fallback,in_town,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_at_least_level_9,in_quest_chat_fluff_fallback,in_town,role_cook].1"
msgid "!neutral\n !think\n Y'know, I tried ta backtrack some fibs I told <#BLUE>{name.npc_blacksmith}</>, tryin' ta rile him up some. Y'know, sowing discord 'n' the like.\n !shocked\n But he just laughed! Said nothin' riles him up no more--'cept a pretty face? Pretty sure he gave me a wink, too!\n !dubious\n Is <i>he</> prone ta fibbin'? <z 0.7>And is he single?</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook,super_frenzy_unlocked].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook,super_frenzy_unlocked].1"
msgid "agent:\n !happy\n !dubious\n I'd say my cookin's a might bit improved in the past year, wouldn't you, Hunter?\n player:\n It's certainly gotten hotter!\n agent:\n !happy\n !gruffnod\n Ya think cookin's all about the food, but it's <i>also</> about turnin' the grill on."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook,super_frenzy_unlocked].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook,super_frenzy_unlocked].2"
msgid "agent:\n !happy\n !point\n The <#KONJUR>{name.konjur}</> levels in yer meals up to your likin', Hunter?\n player:\n Oh, yes. Powers are still popping, {name.npc_cook}.\n agent:\n !gruffnod\n Ah good, good. I haveta remember to <i>not</> put it in everyone else's meals, such that I wrote it on my hand...\n !dubious\n Oh! Seems like I washed it off. Strange. I never wash my hands before cookin'..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].1"
msgid "!neutral\n !think\n Nice of my sister Marigold to leave me with this cookery cart, at least.\n !happy\n !shrug\n Though I hope she gave the original owner just a <i>mild</> concussion to steal it..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].2"
msgid "!happy\n !greet\n Hey Hunter! Wanna taste-test this new recipe I've been workin' on?\n !clap\n I'm experimentin' with <i>salt!</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].3"
msgid "!neutral\n !dubious\n Did ya know there's a kitchen tool made <i>just</> for beatin' eggs? Crazy stuff!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].4"
msgid "!neutral\n !think\n I had a crazy dream last night--a blue mountain goat in a bonnet was teachin' me how ta cook so as to feed a giant mouth in the sky.\n !happy\n !shrug\n I gotta eat more cheese right before bed! It was a HOOT!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].5"
msgid "!happy\n !dubious\n Did ya notice anything special about the last dish I gave you?\n !bliss\n It wasn't raw in the center! I'm thinkin' of callin' that \"a la Glorabelle.\""
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].6"
msgid "!happy\n !think\n Y'know, <#BLUE>{name.npc_blacksmith}</> seems scary and gruff, but he's really just a big pussycat when you get to know him.\n !neutral\n !shocked\n Ulp--Don't tell him I said that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].7"
msgid "agent:\n !happy\n !greet\n Who wants to lick the batter from this bowl?\n player:\n I will!\n agent:\n !happy\n !clap\n Great! One less dish to clean."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_10,in_quest_chat_fluff_fallback,in_town,role_cook].8"
msgid "agent:\n !happy\n !shrug\n While I'm gettin' everythin' out in the open... I guess I oughta tell ya the <#RED>Secret Ingredient</> I've been puttin' in your lunches.\n player:\n Well we already know it's {name.konjur}, right?\n agent:\n !neutral\n !nervous\n Yeeeaaahhh... that, and leftover <#RED>{name.rot}</> parts.\n player:\n Ah. That... explains a lot.\n agent:\n !neutral\n !gesture\n I could stop adding it, if'n ya wanted?\n player:\n Nah. Now I think I'd miss the flavour."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_apothecary].1"
msgid "!neutral\n !angry\n Hey! W-where's the <#RED>Brooch</> I always keep next to my cot?\n !dejected\n My Granny gave that to me..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!neutral\n !think\n It's the weirdest thing... I'm <i>sure</> I left some extra <#KONJUR>{name_multiple.konjur_soul_lesser}</> next to my workbench...\n !wavelunn\n <#BLUE>{name.npc_lunn}</>, you didn't borrow them, did you?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n !dubious\n Haven't seen my satchel of <#KONJUR>{name_multiple.gem}</> around, have ye, Hunter?\n !disagree\n Mark me words. There's somethin' fishy goin' on around here..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_cook].1"
msgid "!neutral\n !nervous\n <#BLUE>{name.npc_armorsmith}</> keeps askin' about my marigold flower... did you tell her 'bout my sister?\n !angry\n Y'know, I told ya about her in strictest confidence, now. Don't. Betray. Me. \n !happy\n !laugh\n Now who wants some grub?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_dojo].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_dojo].1"
msgid "!neutral\n !think\n Huh. My bag of <#KONJUR>Treats</> is feeling a bit light.\n !dubious\n <i>Someone's</> been helpin' themselves while I wasn't looking..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_cook_is_level_7,in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!neutral\n !think\n Where are those <#KONJUR>Ingots</> I've been saving? I could have <i>sworn</> I put them right over here...\n !nervous\n I-I'm sure they must be around here somewhere. I just need to keep looking!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_refiner_is_level_1,in_quest_chat_fluff_fallback,in_town,role_refiner,super_frenzy_unlocked].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_refiner_is_level_1,in_quest_chat_fluff_fallback,in_town,role_refiner,super_frenzy_unlocked].1"
msgid "agent:\n !happy\n !think\n Y'know, I thought the <#RED>{name.weapon_crystal}</> I stole from the Lab was the only one.\n !point\n But <#BLUE>{name.npc_blacksmith}</> claimed he could forge another right here!\n !shocked\n I told him he was nuts! <#KONJUR>{name.konjur_soul_lesser}</> famously can't be forged--it's forge fuel! <i>I</> told <i>him</> that!\n !shrug\n But the mad cat, he did the thing. And when you showed me that button pin <#RED>Souvenir</>, imbued with <#KONJUR>Teffressence</>?\n !gesture\n It confirmed my theory of how the <#RED>{name.weapon_crystal}</> worked.\n !point\n If you took down a <#RED>{name.rot_sf_boss}</> with the <#RED>{name.weapon_crystal}</>, its <#KONJUR>Primeval Teffressence</> would leap into it, charging it with its chaotic power! \n !notebook\n I've since discovered that the <#KONJUR>Primeval \"Entity\"</> possesses <#RED>{name_multiple.rot}</> by imbuing their <#KONJUR>{name.konjur_soul_lesser}</>-like Hearts with its <#KONJUR>Primeval Teffressence</>.\n !agree\n That <#KONJUR>Primeval Teffressence</> is a conduit back to the <#KONJUR>Primeval Source</> itself, allowin' it to strum the strings and make 'em dance, so to speak. \n !think\n Thing I can't figure out is, why wouldn't it leap into <i>you?</> You down enough <#KONJUR>{name.konjur}</> to be like 99% <#KONJUR>{name.konjur_soul_lesser}</> by now...\n !dubious\n You're a conundrum, Hunter... A lucky conundrum indeed."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!happy\n !gesture\n Always glad to see you in one piece, Hunter.\n !point\n Stay that way, okay?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].2"
msgid "!neutral\n !nervous\n It's so eerie hearing the <#RED>Rot</> calls at night.\n !gesture\n I had a hard time sleeping the first couple nights we camped here."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].3"
msgid "!happy\n !gesture\n Don't forget to stop and smell the flowers every now and then.\n !neutral\n !think\n ...Unless they're <#RED>Rot-infected</>. I wouldn't recommend smelling those."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].4"
msgid "!happy\n !shrug\n Don't let the pressure get to you, Hunter.\n !point\n We're all in this fight together!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_3,in_quest_chat_fluff_fallback,in_town,role_scout].5"
msgid "!neutral\n !think\n Hmm... <z 0.7>How will I wash my mug without accidentally wiping off the Hunter's writing?</z>\n !dejected\n Ohh... <z 0.7>This truly is a dilemma.</z>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!neutral\n !think\n Hey Hunter... when this expedition is over, do you think we'll all still stay in touch?\n !happy\n !shrug\n Ah, I'm thinking too far ahead. We need to stay focused on the mission in front of us!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_at_least_level_5,in_quest_chat_fluff_fallback,in_town,role_scout].2"
msgid "!happy\n !think\n I've been thinking about giving the <#RED>{name.i_damselfly}</> a new coat of paint, but there's so many colours to choose from! Should I paint it a sky blue? Burnt orange? Forest green?\n !neutral\n !shocked\n And then there's the trim to consider! Should it match or contrast?!\n !angry\n C'mon, <#BLUE>{name.npc_scout}</>! A leader needs to be ready to make these kinds of important decisions!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_is_level_10,in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[friend_npc_scout_is_level_10,in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!happy\n !gesture\n Hunter, when all this is over... let's take the <#RED>{name.i_damselfly}</> up above the smog-cover and see the stars.\n !happy\n !dubious\n What do you think?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[grimhollow_region,in_quest_chat_fluff_fallback,qc_first_dgn_visit_scout_grimhollow,role_scout,room_type_entrance]NOT[has_killed_grimhollow,in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[grimhollow_region,in_quest_chat_fluff_fallback,qc_first_dgn_visit_scout_grimhollow,role_scout,room_type_entrance]NOT[has_killed_grimhollow,in_town].1"
msgid "!neutral\n !point\n Stay on your toes, Hunter. <#BLUE>Grandpa's</> counting on us."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[grimhollow_region,in_quest_chat_fluff_fallback,qc_first_dgn_visit_scout_grimhollow,role_scout,room_type_entrance]NOT[has_killed_grimhollow,in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[grimhollow_region,in_quest_chat_fluff_fallback,qc_first_dgn_visit_scout_grimhollow,role_scout,room_type_entrance]NOT[has_killed_grimhollow,in_town].2"
msgid "!neutral\n !gruffnod\n Don't think about what we've lost, but what we'll rebuild."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[grimhollow_region,in_quest_chat_fluff_fallback,qc_first_dgn_visit_scout_grimhollow,role_scout,room_type_entrance]NOT[has_killed_grimhollow,in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[grimhollow_region,in_quest_chat_fluff_fallback,qc_first_dgn_visit_scout_grimhollow,role_scout,room_type_entrance]NOT[has_killed_grimhollow,in_town].3"
msgid "!neutral\n !closedeyes\n Whatever he might've done, we need <#BLUE>Grandpa</> to fix our <#KONJUR>Bubble Shield</>. \n !gruffnod\n Let's go save him."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_blarmadillo_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_treemon_forest_r2,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_blarmadillo_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_treemon_forest_r2,role_scout,won_last_run].1"
msgid "!neutral\n !dubious\n You really have nerves of steel, Hunter.\n !happy\n !disagree\n Not many folks could've faced that <#RED>{name.blarmadillo_miniboss}</> head-on and come out on top!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_cabbageroll_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_treemon_forest_r1,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_cabbageroll_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_treemon_forest_r1,role_scout,won_last_run].1"
msgid "!happy\n !clap\n You took down the <#RED>{name.cabbageroll_miniboss}</>!\n !neutral\n !think\n I wonder... does that make you the new <#RED>{name.cabbageroll}</> ruler by default?\n !happy\n !shrug\n We'll see if they send an emissary."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_floracrane_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp_r2,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_floracrane_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp_r2,role_scout,won_last_run].1"
msgid "!happy\n !bliss\n Bingo, bango, bongo! That foul fowl is gonezo!\n !nervous\n Sorry for the outburst. I just really don't like birds."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_gnarlic_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_owlitzer_forest_r1,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_gnarlic_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_owlitzer_forest_r1,role_scout,won_last_run].1"
msgid "!happy\n !agree\n That right there is the sweet smell of victory!\n !neutral\n !think\n Err, well... maybe 'sweet' isn't the right word... but the <i>pungent stink</> of victory doesn't quite roll off the tongue the same way."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_gourdo_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_owlitzer_forest_r3,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_gourdo_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_owlitzer_forest_r3,role_scout,won_last_run].1"
msgid "!happy\n !disagree\n Twice the <#RED>{name_multiple.rot_boss}</>, and you still came out on top! You're really something else, Hunter.\n !laugh\n It's almost a little scary sometimes!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,qc_twn_second_key_refiner,role_apothecary,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,qc_twn_second_key_refiner,role_apothecary,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !neutral\n !disagree\n Hunter. <#BLUE>{name.npc_refiner}'s</>. Been sniffing around my garden.\n player:\n She was really excited about it. \n agent:\n !angry\n A bit too excited. Buzzing around me like an aphid. Do I do this? Have I tried that? \n !dubious\n Is it her <#BLUE>Grandpa</> that wants to kill everything?\n player:\n Er, no. Her dad's the weird guy in the woods, though. \n agent:\n !think\n Oh! Him. ...Maybe I like her, then."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,qc_twn_second_key_refiner,role_blacksmith,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,qc_twn_second_key_refiner,role_blacksmith,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !neutral\n !gesture\n Gemsmiths such as meself rub elbows with miners from time to time. \n !agree\n I know <#BLUE>{name.npc_refiner}'s</> pa. <i>Knew,</> rather. Not closely, mind. \n player:\n What was he like... before?\n agent:\n !think\n A studious 'n' serious {name.species_ogre}. Adored his wee lass somethin' fierce. Och, poor <#BLUE>{name.npc_refiner}</>.\n !dejected\n Never put two and two together he was the feller in the woods. Math were never me strong suit. \n !disagree\n Seein' that... Who knows what a <#KONJUR>Second Eruption</> of <#KONJUR>Primeval Teffra'd</> do. \n !gruffnod\n Careful, Hunter. Who knows what toll it's taken on <#BLUE>{name.flitt_lastname}</>..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_apothecary,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_apothecary,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !neutral\n !dubious\n A <#KONJUR>Second Eruption's</> going to come and wipe everyone out?\n !angry\n I just got to know them!\n player:\n Um, you'd... y'know what? Nevermind.\n agent:\n !eyeroll\n Ugh. Fine. Yes, I'd... I'd <i>miss</> them. Gross. Gross you made me say it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_apothecary,wf_town_has_refiner]NOT[has_killed_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_apothecary,wf_town_has_refiner]NOT[has_killed_tefframech].2"
msgid "agent:\n !neutral\n !think\n Whenever I was a bad little kid, Granny'd tell me the story about a dragon named <#KONJUR>Teffrey</>. \n !point\n <#KONJUR>Teffrey's</> breath turned bad kids into <#KONJUR>{name.konjur}</>. \n !shrug\n I never got scared, but Granny <i>did</> say <#KONJUR>Teffrey'd</> turned into <#KONJUR>{name.konjur}</>. \n player:\n Guess Teffrey had been naughty himself. \n agent:\n !dubious\n No. He just held in a sneeze."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !happy\n !think\n My fingertips are tingling... Is... is there a new <#RED>Diary</> nearby?\n player:\n Weird but yes. {name.npc_refiner} gave {name.npc_scout} Grandpa's Diary.\n agent:\n !neutral\n !shocked\n WHAT?! <#BLUE>{name.npc_grandpa} {name.flitt_lastname}</> kept a <#RED>Diary</>?! And it's HERE?!\n !eyeroll\n Y-you're right, <#BLUE>{name.npc_lunn}</>. <#BLUE>{name.npc_scout}'s</> my friend. We don't steal friends' diaries... \n !angry\n Even if it's <#BLUE>{name.npc_grandpa} {name.flitt_lastname}</>, your admittedly-weird-crush's diary... \n !closedeyes\n Woooo-SHAAAAhhhh....\n !happy\n !gesture\n It's passed. Phew! Am I glad I have friends like you and <#BLUE>{name.npc_lunn}</> to talk me down. \n player:\n Uh, yeah. Don't mention it.\n agent:\n !neutral\n !point\n Oh, I <i>won't.</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_refiner]NOT[has_killed_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_refiner]NOT[has_killed_tefframech].2"
msgid "agent:\n !neutral\n !gesture\n Word on the unpaved paths is <#BLUE>{name.npc_grandpa} {name.flitt_lastname}</> is trying to cause a <i>Second</> Eruption?\n player:\n That's right. Don't worry--we won't let that happen.\n agent:\n !neutral\n !dubious\n IF that's happening. I mean, <#BLUE>{name.npc_refiner}</> said this, right? Who is she, again? \n !shocked\n I heard she got fired for theft! Stole that <#KONJUR>{name.teffrometer}</>. \n !gesture\n Disgruntled employees will say anything. I once said an old boss dyed some of my hair white! \n !shrug\n I was just getting older but... I just can't believe sweet, handsome <#BLUE>{name.npc_grandpa}</> would do something evil.\n !nervous\n He wouldn't... right?\n player:\n Either way, we have to find out.\n agent:\n !think\n I guess that's better than wondering..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_refiner]NOT[has_killed_tefframech].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_refiner]NOT[has_killed_tefframech].3"
msgid "agent:\n !neutral\n !greet\n Hunter! Did you hear about this new kind of <#KONJUR>{name.konjur}</>? \n !neutral\n !gruffnod\n \"<#KONJUR>Primeval {name.konjur}</>,\" they're calling it. Strong stuff, they're saying. \n !nervous\n I even heard it's the putrified remains of a long-dead ancient dragon god named something like <#KONJUR>'Teffrey'</>? \n !scared\n And that if it's awoken from its slumber, it will rain fury down upon our land, sparing none? \n !happy\n !laugh\n Good thing it's just a rumour, huh?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !neutral\n !point\n Dunnae worry about <#BLUE>{name.npc_scout}</>, Hunter. They're made o' tougher steel than ya think.\n !think\n Than <i>they</> think, even. \n !gruffnod\n When hammer meets anvil, and they're snout ta snout with the old fox, they'll hold up. \n !point\n 'Course, should it come ta fisticuffs--get in there, Hunter.\n !gesture\n (Preferably with a solid piece of kit.)"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_refiner]NOT[has_killed_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_refiner]NOT[has_killed_tefframech].2"
msgid "!neutral\n !think\n Where does all this power come from, Hunter? <#KONJUR>{name.konjur}</>, <#KONJUR>{name_multiple.gem}</>--the lot of it.\n !disagree\n No one--<#BLUE>{name.flitt_lastname}</> included--stopped for a second ta think o' that.\n !shrug\n We all just started usin' it. Meself included. Like 'twas ours ta wield as we saw fit. \n !think\n Stands ta reason we oughta pay a price. \n !disagree\n But a <#KONJUR>Second Eruption</> o' <#KONJUR>Primeval Teffra</>? That's a bill I refuse ta pay.\n !gruffnod\n Go get 'em, Hunter."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_cook,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_cook,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !neutral\n !angry\n Do I look like a roast <#RED>{name.meowl}</> to you?\n player:\n Uh... no? \n agent:\n !dubious\n Then why're y'all pullin' my juicy, succulent leg like one with all this \"<#KONJUR>Second Eruption</>\" bunkum?\n !angry\n Y'all don't like my cookin' and want me to run for the hills? Well it won't work! \n !point\n I know a liar when I am one--er, see one! \n player:\n We're not lying, {name.npc_cook}! We... <z 0.7>love...</> your cooking!\n agent:\n !dubious\n ...\n !happy\n !laugh\n Well that's all you had ta say, darlin'!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_cook,wf_town_has_refiner]NOT[has_killed_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_cook,wf_town_has_refiner]NOT[has_killed_tefframech].2"
msgid "agent:\n !happy\n !think\n What would you say to a nice last meal before headin' off to certain death in <#BLUE>{name.tefframech_volcano}</>, darlin'?\n player:\n We're... gonna be fine... I think?\n agent:\n !shocked\n Oh!\n !laugh\n Why, that's the spirit, hun!\n !point\n Tell you what: I'll cook it, and you just give it to <#BLUE>{name.flitt_lastname}</> for <i>his</> last meal, if'n it swings that way. \n !gesture\n I'll make sure it's got a real soft texture for the ol' boy, to boot."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_cook,wf_town_has_refiner]NOT[has_killed_tefframech].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_cook,wf_town_has_refiner]NOT[has_killed_tefframech].3"
msgid "agent:\n !neutral\n !think\n Hmm. <#KONJUR>Primeval Teffra</>... Sounds mighty old, mighty rare, and mighty... <i>expensive</> ...\n !closedeyes\n A gal could think of a lotta things it could buy her...\n !laugh\n ... <#BLUE>{name.town}</>. For her <#BLUE>{name.town}</>, I mean. Besides, me, the <#BLUE>{name.town}</>--what's the difference, anymore? Hahaha.\n !point\n You oughta think about nabbin' some on your heist in <#BLUE>{name.tefframech_volcano}</>. Just sayin'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_dojo_master,wf_town_has_refiner]NOT[has_killed_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_dojo_master,wf_town_has_refiner]NOT[has_killed_tefframech].1"
msgid "agent:\n !gruffnod\n Look. I gave <#BLUE>{name.npc_scout}</> extra inhalers for the Hunt into <#BLUE>{name.tefframech_volcano}</>. \n !gruffnod\n Said I'd tell you to get 'em out of there if their health took a hit around all that <#KONJUR>{name.konjur}</>. \n !cough\n But the darn fool fox said no! {name.dojo_cough} \n !point\n Said you'd <i>have</> to go on and stop their grandpappy. \n player:\n They're right, but... \n agent:\n !angry\n Darn right they're right! So you go on, and you end this. \n !dejected\n ...no matter what."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_dojo_master,wf_town_has_refiner]NOT[has_killed_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_dojo_master,wf_town_has_refiner]NOT[has_killed_tefframech].2"
msgid "agent:\n !happy\n !closedeyes\n Before you head off on the Hunt to end all Hunts, I wanna say somethin'. \n !gruffnod\n It's been an honour trainin' you. You've grown into one of the truest Hunters my remainin' eye has seen. \n player:\n Stop it, {name.npc_dojo_master}, before you make me cry!\n agent:\n !neutral\n !eyeroll\n I'm a bit ashamed to admit this next bit, but day one, I was dead sure you were gonna be <#RED>{name.rot}</> food.\n !point\n In fact, I even called you \"<#RED>{name.rot}</>-Food\" in my head for a while 'cause I plum forgot your name. \n player:\n Stop it, {name.npc_dojo_master}, before you make me <i>actually</> cry!\n agent:\n !happy\n !gruffnod\n Alls I'm sayin' is, I'm very happy to be proven wrong, Hunter."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_dojo_master,wf_town_has_refiner]NOT[has_killed_tefframech].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_grimhollow,in_quest_chat_fluff_fallback,in_town,role_dojo_master,wf_town_has_refiner]NOT[has_killed_tefframech].3"
msgid "agent:\n !neutral\n !gesture\n A tip, Hunter. Do <i>not</> underestimate <#BLUE>{name.npc_grandpa} {name.flitt_lastname}</>. \n !disagree\n He may be a frail, old fox, but dumb, he is not. \n !point\n He knows you're comin'. Knows <#BLUE>{name.npc_scout}</> is comin'. \n !shrug\n And with the unknown of <#KONJUR>Primeval Teffra</> in his corner?\n !gruffnod\n Be ready for anythin'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].1"
msgid "!neutral\n !gesture\n Dad and I used to work in here together. \n !closedeyes\n I miss those times."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].2"
msgid "!neutral\n !gesture\n I thought I'd made it big when I got this job. \n !neutral\n !laugh\n Big mistake, more like it. Hm."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].3"
msgid "!neutral\n !shrug\n What, did we come here for the sights?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].4"
msgid "!happy\n !clap\n I'll never get sick of you whoopin' that old tin can's can. Get at 'er!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_refiner,room_type_hyperoom]NOT[in_town].5"
msgid "!happy\n !think\n Warrior versus giant robot? Pretty metal. \n !shrug\n Prog metal, at <i>least.</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].1"
msgid "!neutral\n !gesture\n Don't let your guard down, Hunter.\n !scared\n Even though he's gone, <#BLUE>Grandpa's</>... \"creations\" still roam the lab."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].2"
msgid "!neutral\n !point\n My <#BLUE>Grandpa's</> gone, but this place is still dangerous."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].3"
msgid "!neutral\n !gruffnod\n Steel yourself, Hunter. <#BLUE>{name.tefframech_volcano}</> is nothing new. \n !scared\n Still, those robo-<#RED>{name_multiple.rot}</> give me the shivers."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].4"
msgid "!happy\n !gruffnod\n You're brave, Hunter. <#BLUE>{name.tefframech_volcano}</> isn't for the faint of heart."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[in_town].5"
msgid "!neutral\n !shocked\n A-ah-AH--All that loose <#KONJUR>{name.konjur}</> in there <i>really</> triggers my ah-ah-aaAAAH! \n !point\n Allergies.  \n !happy\n !shrug\n <#BLUE>{name.npc_dojo_master}</> makes me carry his inhaler."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].1"
msgid "!neutral\n !gruffnod\n Out of the fire, into the Cauldron, eh, Hunter?\n !dubious\n Huh. I sounded like <#BLUE>{name.npc_dojo_master}</> just then."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].2"
msgid "!neutral\n !gesture\n My <#BLUE>Grandpa's</> influence is all over this room."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].3"
msgid "!neutral\n !eyeroll\n <#BLUE>Grandpa's</> mess won't clean itself up, I suppose."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].4"
msgid "!neutral\n !gesture\n Just like this volcano, my Grandpa's mistakes just keep burbling up.\n !think\n Do you think I should write poetry?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[in_town].5"
msgid "!neutral\n !think\n Whatever's waiting ahead, it's not my <#BLUE>Grandpa</>. \n !angry\n Though he did unleash it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_zucco_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_owlitzer_forest_r2,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_killed_zucco_miniboss,in_quest_chat_fluff_fallback,in_town,last_run_was_owlitzer_forest_r2,role_scout,won_last_run].1"
msgid "!happy\n !dubious\n You're getting really good at this, Hunter!\n !point\n That <#RED>{name.zucco_miniboss}</> never stood a chance!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].1"
msgid "!neutral\n !dejected\n Oh, <#BLUE>Grandpa</>... What have you done...?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].2"
msgid "!neutral\n !think\n If we can just get him out of that <#RED>Mech</>...\n !dubious\n ... maybe we can reason with him. <z 0.7>Maybe.</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].3"
msgid "!neutral\n !dejected\n It hurts, seeing him <#BLUE>Grandpa</> taken over by <#KONJUR>Primeval Teffra</>...\n !think\n Though it's as if the stuff is literally speaking <i>for</> him..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].4"
msgid "!neutral\n !point\n We can't give up, Hunter. I know you can beat him."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[has_seen_tefframech,in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].5"
msgid "!neutral\n !gruffnod\n We won't let <#BLUE>Grandpa</> spread this to others. We <i>can't.</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!neutral\n !scared\n <i>ha</i>-CHOO!\n !happy\n !nervous\n Whew. My allergies are acting up all of the sudden."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].2"
msgid "!happy\n !dubious\n Oh hey, don't forget about that <#KONJUR>{name.i_konjur_heart_shard}</> in your bag.\n !point\n Go pop it in the <#KONJUR>{name.i_town_grid_cryst}</> when you get a chance, okay?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].3"
msgid "!neutral\n !scared\n <i>ha</i>-CHOOoo!\n !nervous\n Whewie. Do you have a <#KONJUR>{name.i_konjur_heart_shard}</> on you or something?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].4"
msgid "!greet\n Heya Hunter, how's it--\n !neutral\n !scared\n <i>ha</i>-CHOOoo!\n !happy\n !nervous\n Ah. Have a <#KONJUR>{name.i_konjur_heart_shard}</> on you, do ya?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[holding_any_heart,in_quest_chat_fluff_fallback,in_town,role_scout].5"
msgid "!neutral\n !dubious\n Hey. You planning to put that <#KONJUR>{name.i_konjur_heart_shard}</> in the <#KONJUR>{name.i_town_grid_cryst}</> or--\n !shrug\n We could use the power, y'know."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_bonejaw_miniboss,last_run_was_grimhollow_volcano_r1,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_bonejaw_miniboss,last_run_was_grimhollow_volcano_r1,role_scout,won_last_run].1"
msgid "!happy\n !laugh\n <#RED>{name.bonejaw_miniboss}</> needs a dentist after meeting you! \n !neutral\n !point\n Also because I think it had a <i>bit</> of an underbite."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_blarmadillo_miniboss,last_run_was_treemon_forest_r2,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_blarmadillo_miniboss,last_run_was_treemon_forest_r2,lost_last_run,role_scout].1"
msgid "!neutral\n !think\n You know, as a fellow allergy sufferer I had a bit of sympathy for <#RED>{name_multiple.blarmadillo}</>...\n !point\n ...until now, that is."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_bonejaw,last_run_was_grimhollow_volcano_r1,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_bonejaw,last_run_was_grimhollow_volcano_r1,lost_last_run,role_scout].1"
msgid "!neutral\n !gesture\n How are you feeling, Hunter?\n !shocked\n That <#RED>{name.bonejaw}</> really did a number on you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_cabbageroll_miniboss,last_run_was_treemon_forest_r1,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_cabbageroll_miniboss,last_run_was_treemon_forest_r1,lost_last_run,role_scout].1"
msgid "!happy\n !gesture\n Don't worry about it, Hunter.\n !point\n That <#RED>{name.cabbageroll_miniboss}'s</> days are numbered!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_crystroll,last_run_was_sedament_tundra_r2,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_crystroll,last_run_was_sedament_tundra_r2,lost_last_run,role_scout].1"
msgid "!neutral\n !think\n Things got a little rocky on that last fight, huh?\n !shocked\n S-sorry! I didn't mean to make a joke!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_crystroll,last_run_was_sedament_tundra_r2,lost_last_run,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_crystroll,last_run_was_sedament_tundra_r2,lost_last_run,role_scout].2"
msgid "!neutral\n !scared\n I'm <i>still</> thawing out from our run-in with that <#RED>{name.crystroll}</>.\n !think\n At least you had the option of hacking the ice off those <#RED>Braziers</> down there!\n !dejected\n Sorry, Hunter, I know you had your hands full, but... it's not a bad idea..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_crystroll,last_run_was_sedament_tundra_r2,lost_last_run,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_crystroll,last_run_was_sedament_tundra_r2,lost_last_run,role_scout].3"
msgid "!neutral\n !scared\n Brrr...\n !nervous\n I don't know if I've got the shivers from the cold, or from how that last fight turned out."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_eggzy,last_run_was_eggzy_tundra,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_eggzy,last_run_was_eggzy_tundra,lost_last_run,role_scout].1"
msgid "!neutral\n !nervous\n So... I guess that nest wasn't <i>completely</> abandoned.\n !shrug\n Though in my defense, that <#RED>{name.rot_boss}</> was technically just a hatchling.\n !happy\n !gesture\n But look on the bright side! We were able to gather valuable data that will serve us well on the next Hunt!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_embison,last_run_was_eggzy_tundra_r1,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_embison,last_run_was_eggzy_tundra_r1,lost_last_run,role_scout].1"
msgid "!neutral\n !dubious\n Are you sure you're okay, Hunter?\n !nervous\n <i>I</> sure wouldn't be after taking a right-hook from a <#RED>{name.embison}</>..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,last_run_was_thatcher_swamp_r2,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,last_run_was_thatcher_swamp_r2,lost_last_run,role_scout].1"
msgid "!neutral\n !dejected\n <i>Ugh.</i>\n !point\n I hate that bird."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,last_run_was_thatcher_swamp_r2,lost_last_run,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,last_run_was_thatcher_swamp_r2,lost_last_run,role_scout].2"
msgid "!neutral\n !dejected\n I didn't realize that <#RED>{name.floracrane}</> could hit so hard.\n !point\n This is why I hate birds."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,lost_last_run,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,lost_last_run,role_armorsmith].1"
msgid "!neutral\n !gesture\n I was bit really hard by a seagull once.\n !agree\n I know exactly what you're going through."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,lost_last_run,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,lost_last_run,role_armorsmith].2"
msgid "!happy\n !clap\n Got knocked out by a <#RED>{name.floracrane}</>, huh? Was it a pink one or a green one?\n !think\n Those colours look great together, don't you think?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,lost_last_run,role_armorsmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_floracrane,lost_last_run,role_armorsmith].3"
msgid "!neutral\n !think\n Isn't a <#RED>{name.floracrane}</> just a big bird?\n !happy\n !point\n Oh! I know! You should try throwing french fries in the opposite direction."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_gnarlic_miniboss,last_run_was_owlitzer_forest_r1,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_gnarlic_miniboss,last_run_was_owlitzer_forest_r1,lost_last_run,role_scout].1"
msgid "!neutral\n !disagree\n I can still smell that old <#RED>Gnarlic's</> stench...\n !nervous\n Um, Hunter? Maybe you could wash off a bit before we get back in the <#RED>{name.i_damselfly}</>...?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_gourdo,last_run_was_owlitzer_forest_r3,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_gourdo,last_run_was_owlitzer_forest_r3,lost_last_run,role_scout].1"
msgid "!neutral\n !angry\n I've had just about enough of those two <#RED>{name_multiple.gourdo}</>.\n !think\n Since when did <#RED>{name_multiple.rot}</> learn to team up?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_gourdo,last_run_was_owlitzer_forest_r3,lost_last_run,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_gourdo,last_run_was_owlitzer_forest_r3,lost_last_run,role_scout].2"
msgid "!neutral\n !think\n Fighting two <#RED>{name_multiple.gourdo}</> at once...\n !point\n Watch how you use your <#RED>Potions</>. They've got twice the coverage with their clubs!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_grimhollow,last_run_was_grimhollow_volcano,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_grimhollow,last_run_was_grimhollow_volcano,lost_last_run,role_scout].1"
msgid "!neutral\n !dejected\n I don't know about you, but I'm getting really tired of getting attacked by angry trees.\n !gesture\n Just saying..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_grimhollow,role_refiner,struggling_on_grimhollow].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_grimhollow,role_refiner,struggling_on_grimhollow].1"
msgid "!neutral\n !gesture\n C'mon, Hunter. Are you gonna let a <#RED>computer tree</> best you?\n !neutral\n !angry\n Because it bested me, and it irritates me to this day."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_grimhollow,role_refiner,struggling_on_grimhollow].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_grimhollow,role_refiner,struggling_on_grimhollow].2"
msgid "!neutral\n !point\n See? <#RED>{name.grimhollow}'s</> sneaky for a heap of lumber and circuitry."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_groak,last_run_was_bandi_swamp_r2,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_groak,last_run_was_bandi_swamp_r2,lost_last_run,role_scout].1"
msgid "!neutral\n !scared\n If a <#RED>{name.groak}</> ever swallowed me I think I'd shave off all my fur.\n !shocked\n Yuck!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_groak,lost_last_run,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_groak,lost_last_run,role_armorsmith].1"
msgid "!neutral\n !gesture\n You look like you've seen the inside of a <#RED>{name.groak}</>.\n !think\n Wait, is that what got you?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_sedament,last_run_was_sedament_tundra,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_sedament,last_run_was_sedament_tundra,lost_last_run,role_scout].1"
msgid "!neutral\n !shocked\n The <#RED>{name.rot_boss}</> is a bunch of rocks?! I'm no <#BLUE>{name.job_konjurist}</>, but I thought <#KONJUR>{name.konjur}</> only affected living things...\n !point\n Let's get back out there, Hunter! This calls for further investigation."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_swarmy_miniboss,last_run_was_thatcher_swamp_r1,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_swarmy_miniboss,last_run_was_thatcher_swamp_r1,lost_last_run,role_scout].1"
msgid "!neutral\n !shrug\n That <#RED>{name.swarmy}</> gunk is impossible to wash out...\n !think\n I might need to replace the <#RED>{name.i_damselfly}'s</> seat cushions after this is all over."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].1"
msgid "!neutral [keep-for-room]\n !disagree\n It's not my <#BLUE>Grandpa</> attacking you, Hunter. It's the <#KONJUR>Primeval Teffra</>.  \n !gesture\n What I'm saying is... <i>(sigh)</> Don't pull your punches next time, okay?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].2"
msgid "!neutral [keep-for-room]\n !dejected\n The <#KONJUR>Primeval Teffra</> is so <i>strong!</>\n !gruffnod\n But I know we can beat it, Hunter. We have to."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].3"
msgid "!neutral [keep-for-room]\n !gruffnod\n We have to fight <#KONJUR>{name.konjur}</> with <#KONJUR>{name.konjur}</>!\n !think\n We might need more <#KONJUR>{name_multiple.i_konjur_heart}</> to beat <#BLUE>Grandpa</>..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].4"
msgid "!neutral [keep-for-room]\n !dubious\n Do you think there's some piece of <#BLUE>Grandpa</> left in there? \n !nervous\n I... I have to believe there is..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout].5"
msgid "!neutral [keep-for-room]\n !point\n We're down, but the <#KONJUR>Primeval Teffra</> is scared of us, Hunter. \n !gruffnod\n Let's go remind it why!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].1"
msgid "!happy [keep-for-room]\n !think\n An emergency rescue <i>inside</> a volcano was pretty impressive! Not that I'm bragging. \n !shocked\n I'm not!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].2"
msgid "!neutral [keep-for-room]\n !nervous\n That was a close one, Hunter. \n !shocked\n Those machine-<#RED>{name.rot}</> things are on another level!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].3"
msgid "!neutral [keep-for-room]\n !scared\n Threading the <#RED>{name.i_damselfly}</> between pipes and <#KONJUR>{name.konjur}</>-falls with a near-lifeless Hunter dangling from its claw is <i>stressful!</>\n !dubious\n Oh! B-but not as stressful as fighting those hoards of lab-grown <#RED>{name_multiple.rot}</>, of course."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_tefframech,last_run_was_tefframech_volcano,lost_last_run,role_scout]NOT[has_seen_tefframech].4"
msgid "!neutral [keep-for-room]\n !gesture\n Maybe more <#KONJUR>{name_multiple.i_konjur_heart}</> could keep you in the fight longer?\n !shrug\n I only suggest it because the fate of the world is at stake, of course."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_thatcher,lost_last_run,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_thatcher,lost_last_run,role_refiner].1"
msgid "!neutral\n !gruffnod\n So <#RED>{name.thatcher}</> shreds, huh? And not just your ego."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_yammo,last_run_was_treemon_forest_r3,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_yammo,last_run_was_treemon_forest_r3,lost_last_run,role_scout].1"
msgid "!neutral\n !dejected\n <i>(sigh)</>\n !gesture\n I used to really like yams..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_zucco_miniboss,last_run_was_owlitzer_forest_r2,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_by_zucco_miniboss,last_run_was_owlitzer_forest_r2,lost_last_run,role_scout].1"
msgid "!happy\n !point\n You'll get that <#RED>{name.zucco_miniboss}</> next time, Hunter!\n !gesture\n We all believe in you!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_crystroll_miniboss,last_run_was_sedament_tundra_r2,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_crystroll_miniboss,last_run_was_sedament_tundra_r2,role_scout,won_last_run].1"
msgid "!happy\n !point\n You put <#RED>{name.crystroll_miniboss}</> on ICE! Because of the cold!\n !think\n Or you brought the HEAT? Because of the <#RED>Braziers</>. You did great, is what I mean."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_embison_miniboss,last_run_was_eggzy_tundra_r1,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_embison_miniboss,last_run_was_eggzy_tundra_r1,role_scout,won_last_run].1"
msgid "!happy\n !clap\n You gave <#RED>{name.embison_miniboss}</> a bit o' that sweet chin music!\n !bliss\n A crash course in that sweet science!\n !dubious\n The ol'... one-two... buckle-my-shoe?\n !shrug\n <#BLUE>{name.npc_dojo_master}</> told me to say those things. I have no idea what they mean."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_groak_miniboss,last_run_was_bandi_swamp_r2,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_groak_miniboss,last_run_was_bandi_swamp_r2,role_scout,won_last_run].1"
msgid "!happy\n !clap\n You really <i>suck</> now, <#RED>{name.groak_miniboss}</>! \n !shrug\n It's not here but I just wanted the chance to say my little pun."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_swarmy_miniboss,last_run_was_thatcher_swamp_r1,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_swarmy_miniboss,last_run_was_thatcher_swamp_r1,role_scout,won_last_run].1"
msgid "!happy\n !point\n Nice work cleaning up <#RED>{name.swarmy_miniboss}</>, Hunter! \n !dubious\n You <i>could</> clean the <#RED>{name.i_damselfly}'s</> seats that you sat on after...\n !agree\n Buuuuut I'll just flip them over. All good."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_yammo_miniboss,last_run_was_treemon_forest_r3,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_killed_yammo_miniboss,last_run_was_treemon_forest_r3,role_scout,won_last_run].1"
msgid "!happy\n !point\n Bet you that yam wishes it was a sweet potato today!\n !neutral\n !think\n Wait... are yams also sweet potatoes? No, right? This feels insensitive."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_grimhollow_volcano,role_refiner,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_grimhollow_volcano,role_refiner,won_last_run].1"
msgid "!happy\n !gesture\n Thumped Grimhollow again just for funsies?\n !clap\n I'm here for it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_grimhollow_volcano,role_refiner,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_grimhollow_volcano,role_refiner,won_last_run].2"
msgid "!happy\n !point\n You fed that <#RED>cyborg tree</> to the <i>wood-micro-chipper!</>\n ...\n !angry\n <#BLUE>{name.npc_armorsmith}</> assured me that would go over better."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_grimhollow_volcano,role_refiner,won_last_run].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_grimhollow_volcano,role_refiner,won_last_run].3"
msgid "!happy\n !gesture\n Thanks again for the assist with {name.grimhollow}.\n !nervous\n Even though I didn't need it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp,role_refiner,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp,role_refiner,won_last_run].1"
msgid "!happy\n !point\n <#RED>{name.thatcher}</> should've known better than to get in the pit with you.\n !clap\n You floor-punching, two-stepping, wall-of-death beast!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp,role_refiner,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,last_run_was_thatcher_swamp,role_refiner,won_last_run].2"
msgid "!neutral\n !point\n So {name.c_konjur} mutated a <#RED>{name.rot}</> to rock?\n !happy\n !bliss\n That rules."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_apothecary].1"
msgid "!neutral\n !gruffnod\n Don't feel bad, Hunter. You did your best."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_apothecary].2"
msgid "!neutral\n !think\n Granny used to say that making mistakes is just as important as winning.\n !shrug\n Learning from mistakes makes us stronger."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].1"
msgid "!gesture\n Welcome home!\n !point\n I hear you gave almost as good as you got."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].10"
msgid "!gesture\n I know what it's like to get my butt kicked.\n !shrug\n I had a family once."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].11"
msgid "!wavelunn\n Folks think I won <#BLUE>{name.npc_lunn}</> in a leg-wrestling match against three {name_multiple.cabbageroll}.\n !shrug\n Truth is, I stole him off the jerk who laughed at me for losing."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].12"
msgid "!point\n It's not a loss as long as you learn something.\n !shrug\n Even if all you learn is that you need better <#RED>Armour</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].13
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].13"
msgid "!neutral\n !shocked\n WOAH!\n !happy\n !think\n Oh, sorry. I thought you were a ghost."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].2"
msgid "!happy\n !gesture\n I really admire your grit.\n !neutral\n !point\n ...and your ears."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].3"
msgid "!neutral\n !gesture\n When I've had a rough run, I like to go scream into a tree.\n !happy\n !point\n The trees don't mind. I asked."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].4"
msgid "!gesture\n Heya, welcome back.\n !point\n Glad you made it out with all your limbs!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].5"
msgid "!greet\n Hey Hunter!\n !point\n Those <#RED>{name_multiple.rot}</> are in for a <i>big</i> surprise next time."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].6"
msgid "!greet\n Hey Hunter!\n !point\n You really gave those <#RED>{name_multiple.rot}</> a run for their... rottenness."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].7"
msgid "!greet\n !wavelunn\n <#BLUE>{name.npc_lunn}</> says he's got a good feeling about your next run!\n !point\n !agree\n You're scrappy, like us."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].8"
msgid "!gesture\n It's not just about winning.\n !point\n It's about putting up a fight."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_armorsmith].9"
msgid "!gesture\n Yowza... those <#RED>{name_multiple.rot}</> are tough!\n !point\n And so are you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith,wf_town_has_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith,wf_town_has_apothecary].1"
msgid "!neutral\n !dubious\n Y'alright?\n !closedeyes\n Ye look like somethin' <#BLUE>{name.npc_apothecary}</> dragged in."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].1"
msgid "!neutral\n !gesture\n Listen, Hunter. Yer not the first to get knocked down a peg. \n !closedeyes\n Dust yerself off, an' go show 'em what fer."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].2"
msgid "!neutral\n !dubious\n Mark my words, Hunter.\n !closedeyes\n Those boggin' <#RED>{name_multiple.rot}'ll</> get theirs."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].3"
msgid "!neutral\n !closedeyes\n {name.job_dojo}'s been askin' after ye.\n !dubious\n ..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].4"
msgid "!neutral\n !closedeyes\n I've got th' forge fired up if ye need.\n !dubious\n Don't let a weary weapon take ye down."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_blacksmith].5"
msgid "!neutral\n !dubious\n ...\n !gruffnod\n Failin' means yer playin'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_cook].1"
msgid "!neutral\n !dubious\n Hoo-whee, looks like somethin' gave you a real shiner.\n !neutral\n !think\n I heard slappin' a slab of steak on it helps. Except we don't got any steak... maybe a bag of frozen beans, then?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_cook].2"
msgid "!happy\n !gesture\n Don't you worry your little head over it, Hunter.\n !point\n You'll get that varmint next time!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].1"
msgid "!neutral\n !gesture\n <#RED>Healing's</> scarce on Hunts.\n !happy\n !gruffnod\n Best not to get hit if you can help it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].2"
msgid "!neutral\n !cough\n Listen up, Hunter.\n !happy\n !gruffnod\n Failed Hunts are just learning experiences."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].3"
msgid "!happy\n !gruffnod\n Welcome back.\n !gesture\n I'm prouda you for getting out there."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].4"
msgid "!happy\n !dubious\n Get yer butt whupped?\n !disagree\n Ain't no shame in a loss. It's part of the process."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].5"
msgid "!neutral\n !gesture\n Chin up, kid.\n !point\n You aren't gonna let those rotten monsters win, are ya?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].6"
msgid "!neutral\n !dubious\n Why the long face?\n !gruffnod\n You went down swingin'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_dojo].7"
msgid "!neutral\n !dubious\n Hey kid.\n !gruffnod\n Took some down with ya, I hope?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner,struggling_on_thatcher].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner,struggling_on_thatcher].1"
msgid "!neutral\n !disagree\n Dang. <#RED>{name.thatcher}</> rocked your little socks off, huh?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].1"
msgid "!neutral\n !point\n Hey, at least you survived to overthink all your mistakes. He he he."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].2"
msgid "!neutral\n !gesture\n Don't get down, Hunter. That last run was just the warm-up.\n !point\n Now for the headliner."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].3"
msgid "!neutral\n !think\n Is it time to gives those <#RED>{name_multiple.rot}</> a lesson in retribution?\n !point\n Yes. Yes it is."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].4"
msgid "!neutral\n !shrug\n Don't sweat that last Hunt. Failure's necessary for progress, Hunter.\n !point\n Still, it sucks a big one. Tough break."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].5"
msgid "!neutral\n !gesture\n Don't worry, Hunter. No one's keeping track of your failures.\n !notebook\n Oh this? I'm just keeping track of... other stuff."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].6"
msgid "!neutral\n !shrug\n Hey, everyone gets their butts destroyed by nasty vegetables now and then.\n !happy\n !point\n Though usually it's due to food poisoning. He he he. Sorry."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_refiner].7"
msgid "!neutral\n !nervous\n Don't give up. My dad's out there, alone."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_scout].1"
msgid "!shrug\n You win some, you lose some, right Hunter?\n !gesture\n No one said it'd be easy."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_scout].2"
msgid "!gesture\n Glad to see you up.\n !point\n Ready to get back to it?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,lost_last_run,role_scout].3"
msgid "!greet\n Hey, Hunter.\n !agree\n No lasting damage from that last Hunt, I hope."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_blacksmith,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_blacksmith,won_last_run].1"
msgid "!neutral\n !dubious\n ...\n !gruffnod\n Doin' us all proud."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_blacksmith,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_blacksmith,won_last_run].2"
msgid "!neutral\n !dubious\n ...\n !point\n 'Tis an honour to fight alongside yer pals."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo].1"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !happy\n !gesture\n Remember that you and other Hunters are working together."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo].2"
msgid "!happy\n !gesture\n By the way, if yer fighting with allies and get knocked out try hitting the <#RED>Attack</> and <#RED>{name.concept_dodge}</> buttons.\n !cough\n Ghe-he-he."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo]NOT[using_gamepad].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo]NOT[using_gamepad].1"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !happy\n !gruffnod\n If you learn something useful out there, share the tip with your fellow Hunters."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo]NOT[using_gamepad].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,multiplayer,role_dojo]NOT[using_gamepad].2"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !happy\n !gruffnod\n By the way, you can communicate with other Hunters by pressing <p bind='Controls.Digital.TOGGLE_SAY' color=BTNICON_DARK> to chat."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook].1"
msgid "agent:\n !neutral\n !angry\n No more beatin' around the bush, Hunter. \n !point\n You got new <#RED>Recipes</>, a <#RED>{name.i_lunchbox}</>, and a functionin' stomach. \n !gesture\n And I got a grill, a buncha cookin' tools and whatsits, and time on my hands. \n !happy\n !bliss\n Whaddaya say we get this party started, ay, hun?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook].2"
msgid "agent:\n !happy\n !point\n I've been practicin' the meals what're on that there new {name.cook_rotating_recipe} menu.\n !gruffnod\n Reckon I've got 'em down pat, so I offer you my Solid Gold 'No Tummyache' Guarantee!\n !neutral\n !dubious\n Ahem. <z 0.7>Guarantee does not cover inverted eye waterin', downstairs winds, the deep knee bends, or spontaneous hair braidin'.</>\n !happy\n !clap\n Well? Grill ain't gettin' any hotter!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook]NOT[pf_made_rotatingmenu_food].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook]NOT[pf_made_rotatingmenu_food].1"
msgid "agent:\n !neutral\n !angry\n You're gonna ignore all these new <#RED>Recipes</> I done dug up for ya? \n !dejected\n After I made sure they'd give ya helpful powers 'n' the like?\n !point\n Shooooot. Don't come bellyachin' to me 'bout yer belly achin' on account of you not askin' me to pack you a meal, now, y'hear?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook]NOT[pf_made_rotatingmenu_food].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook]NOT[pf_made_rotatingmenu_food].2"
msgid "agent:\n !neutral\n !think\n Look at all thems new <#RED>Recipes</> goin' uncooked!\n !shrug\n Guess <i>someone</> doesn't like <i>someone else's</> cookin'! \n !angry\n Guess that <i>someone else</> could get offended 'n' such, should they not be asked to pack one of 'em up in the <#RED>{name.i_lunchbox}</> sooner 'n' later...\n !dubious\n Psst! <z 0.7>I'm talkin' about me. I'll get offended. I <i>will,</> dadgummit!</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook]NOT[pf_made_rotatingmenu_food].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_cook_rotatingmenu_unlocked,role_cook]NOT[pf_made_rotatingmenu_food].3"
msgid "agent:\n !happy\n !point\n You've been readin' that there new <#RED>{name.cook_rotating_recipe}</> menu like there's gonna be a test, hun!\n !angry\n Well there is: TESTIN' MY GALL-DURN PATIENCE!\n !laugh\n I'm just kiddin'.\n !angry\n OR AM I?\n !laugh\n Go on and <i>pick</> somethin', already! I promise, it's all made with love.\n !angry\n OR SPITE!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_corestone_weapon_crafting_unlocked,role_refiner].1"
msgid "!neutral\n !think\n Working with the <#BLUE>{name.job_blacksmith}</>, he's so aloof, antisocial, and assiduous to a fault.\n !happy\n !gruffnod\n A+. 10 out of 10. Would recommend."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_gave_cookingtools,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_gave_cookingtools,role_cook].1"
msgid "agent:\n !happy\n !disagree\n Now, we don't want ya goin' hungry on a {name.run}, Hunter. \n !point\n Look fer the <#RED>{name.i_lunchbox}</> next to the <#RED>{name.i_damselfly}</> when next you're in the wilds. \n !gruffnod\n This scrum-diddly-umptious somethin'-or-rather'll be waitin' for ya.\n !angry\n And <i>no,</> it won't go <i>bad,</> <z 0.7>I don't reckon.</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_gave_cookingtools,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,pf_gave_cookingtools,role_cook].2"
msgid "agent:\n !neutral\n !dejected\n Don't tell ol' <#BLUE>{name.npc_cook}</> you don't like her cookin', now!\n !gesture\n Your <#RED>{name.i_lunchbox}</> has some home-cooked, power-packed meals waitin'... \n !happy\n !gruffnod\n Find it by the <#RED>{name.i_damselfly}</> next time you land in the wilds. Them powers'll do you good."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,qc_twn_gems_intro_blacksmith,role_armorsmith,wf_town_has_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,qc_twn_gems_intro_blacksmith,role_armorsmith,wf_town_has_blacksmith].1"
msgid "!bliss\n Oooohoho, I can smell a secret from a mile away! What were you and <#BLUE>{name.npc_blacksmith}</> whispering about?\n !think\n Does it have something to do with that <#RED>{name.gem}</> you showed him?\n !happy\n !dubious\n C'mon, spill! You can tell me! <i>Pleeeeaaaase?</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,qc_twn_gems_intro_blacksmith,role_armorsmith,wf_town_has_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,qc_twn_gems_intro_blacksmith,role_armorsmith,wf_town_has_blacksmith].2"
msgid "!happy\n !think\n Have you ever noticed how big and shiny <#BLUE>{name.npc_blacksmith}'s</> eyes get whenever he sees a <#RED>Gem</>?\n !shrug\n I asked him about it and he just grunted at me... but I swear it was a <i>nervous</> grunt.\n !angry\n Uuuugh why does he have to be so secretive!!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,qc_twn_second_key_refiner,role_refiner,wf_seen_npc_specialeventhost].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,qc_twn_second_key_refiner,role_refiner,wf_seen_npc_specialeventhost].1"
msgid "agent:\n !neutral\n !greet\n Did you see my dad on your last Hunt? How was he?\n player:\n He looked good, {name.npc_refiner}.\n agent:\n !neutral\n !nervous\n Did he... did he ask about me? Say my name at all... ?\n player:\n ... Sorry, he wasn't--\n agent:\n !neutral\n !notebook_start\n No it's fine. Thanks anyway. See ya."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,weapon_type_polearm].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,weapon_type_polearm].1"
msgid "!neutral\n !dubious\n That's a weird-looking scythe.\n !disagree\n You can't harvest crops with that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,wf_seen_npc_potionmaker_dungeon].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,wf_seen_npc_potionmaker_dungeon].1"
msgid "!neutral\n !dubious\n {name.apothecary_sniff}\n !disagree\n I don't like the smell of those potions you've been getting from the potion-seller.\n !think\n I can't pick up a single natural ingredient."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,won_last_run].1"
msgid "!neutral\n !dubious\n {name.apothecary_sniff} Eww...\n !shocked\n You're covered in <#RED>{name.rot_boss}</> stink. Hope that means you beat it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary,won_last_run].2"
msgid "!neutral\n !gesture\n <#BLUE>{name.npc_scout}</> said you beat the <#RED>{name.rot_boss}</>.\n !happy\n !think\n They seemed really proud."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].1"
msgid "!neutral\n !dubious\n {name.apothecary_sniff}\n !point\n You smell weird."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].2"
msgid "!neutral\n !closedeyes\n <i>(yawn)</> Do you know any good napping spots?\n !think\n The <#RED>{name.job_blacksmith}</> gets mad when I sleep next to his forge. But it's so warm and cozy..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].3"
msgid "!neutral\n !nervous\n There's so many people here...\n !neutral\n !dubious\n Are they here <i>all</> the time?!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].4"
msgid "!neutral\n !closedeyes\n Shh. I'm practicing being invisible."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary].5"
msgid "!neutral\n !dubious\n Was <#BLUE>{name.npc_dojo_master}</> really a Hunter too?\n !think\n I wonder if he knew... never mind."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary]NOT[wf_town_has_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_apothecary]NOT[wf_town_has_blacksmith].1"
msgid "!dubious\n Um. How have you lasted this long without a <#RED>{name.job_blacksmith}</>?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,weapon_type_polearm].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,weapon_type_polearm].1"
msgid "!happy\n !clap\n I knew it was a <#RED>{name.rot}</> kebab kind of day!\n !point\n Just watch where you point that thing."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_seen_npc_potionmaker_dungeon].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_seen_npc_potionmaker_dungeon].1"
msgid "!neutral\n !gesture\n I got a free mouthwash sample from a slippery salesman out there once...\n !shocked\n ...turned out to be a <i>very</i> powerful burping potion."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_seen_npc_potionmaker_dungeon].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_seen_npc_potionmaker_dungeon].2"
msgid "!neutral\n !dubious\n You're not talking to <i>strange</i> strangers out there, are you?\n !clap\n You could be home talking to strange friends instead!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].1"
msgid "!happy\n !bliss\n <#BLUE>{name.npc_blacksmith}</>'s sonnets are so lyrical.\n !point\n You didn't hear it from me."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].2"
msgid "!neutral\n !think\n You know some folks call <#BLUE>{name.npc_blacksmith}</> \"HAM-ish\" instead of \"HAY-mish\"?\n !shrug\n He's really not much of a ham."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].3"
msgid "!neutral\n !shocked\n They say that <#BLUE>{name.npc_blacksmith}</> gave <i>himself</i> that tattoo.\n !happy\n !shrug\n Okay, nobody says that. But it could be true!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].4"
msgid "!neutral\n !wavelunn\n <#BLUE>{name.npc_blacksmith}'s</> hammer just called <#BLUE>{name.npc_lunn}</> <i>dull</i>.\n !disagree\n What a tool."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].5"
msgid "!happy\n !eyeroll\n <#BLUE>{name.npc_blacksmith}</> is <i>so weird</i> about accepting help.\n !laugh\n I spent all morning suggesting names for his hammer, and he told me to go <i>boil my head!</i>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].6"
msgid "!neutral\n !shrug\n Does <#BLUE>{name.npc_blacksmith}</> seem okay to you?\n !think\n He seems gruntier than usual."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_blacksmith].7"
msgid "!neutral\n !gesture\n I tried to help <#BLUE>{name.npc_blacksmith}</> come up with some names for his tools, and do you know what he said?\n !angry\n <i>'Och, me tools need names like I need a hole in the head!'</> Can you believe that?!\n !think\n Why would <#BLUE>{name.npc_blacksmith}</> think he needs a hole in his head?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].1"
msgid "!happy\n !gesture\n <#BLUE>{name.npc_cook}</> says superheating food releases the nutrients.\n !point\n That's why she makes sure to burn everything."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].2"
msgid "!neutral\n !shocked\n Some <#RED>{name.rot}</>-tainted jerk called <#BLUE>{name.npc_cook}'s</> food \"slop\"!\n !dubious\n !angry\n They're not <i>wrong</i>. But still."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].3"
msgid "!happy\n !shocked\n Smell that?\n !bliss\n It's mystery mash casserole night!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].4"
msgid "!happy\n !gesture\n You know what's worse than food poisoning?\n !point\n !agree\n Eating raw <#RED>{name.gnarlic}</> out of a shoe. Trust me."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].5"
msgid "!happy\n !shocked\n A few more weeks with <#BLUE>{name.npc_cook}</>, and you'll have a cast-iron gut!\n !point\n That's like <#RED>Armour</> for your insides."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,wf_town_has_cook].6"
msgid "!happy\n !gesture\n I added a flame-retardant lining to <#BLUE>{name.npc_cook}'s</> apron.\n !clap\n She said she's already getting lots of use out of it!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].1"
msgid "!greet\n I've been hearing a <i>lot</i> of chatter about you...\n !point\n ...folks are saying you're a natural!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].2"
msgid "!neutral\n !gesture\n Even if you <i>do</i> wipe out all the <#RED>{name_multiple.rot}</>...\n !happy\n !bliss\n ...you'll need <#RED>Armour</> to stay safe from all your fans."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].3"
msgid "!clap\n Way to slay, Hunter!\n !point\n Get it? 'Cause you slayed all those <#RED>{name_multiple.rot}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].4"
msgid "!gesture\n If you ever run outta <#RED>{name_multiple.rot}</> to hunt...\n !laugh\n ...<#BLUE>{name.npc_lunn}</> could teach you to be an {name.job_armorsmith}!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].5"
msgid "!greet\n That last run was <i>killer!</i>\n !laugh\n Hooyah!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].6"
msgid "!point\n All your training is really paying off.\n !think\n D'you think I could train myself to be taller?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].7"
msgid "!dubious\n !disagree\n You're not a Hunter.\n !point\n !clap\n You're a DECIMATOR! Hooyah!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith,won_last_run].8"
msgid "!notebook\n <i>Dear Diary, many <#RED>{name.rot}</> butts were kicked today.</i>\n !think\n Do you think <#BLUE>{name.npc_dojo_master}</> minds that I borrowed his diary?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].1"
msgid "!happy\n !dubious\n Find you're dying a bunch out there?\n !point\n The right kind of <#RED>Armour</> could change that..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].10"
msgid "!notebook\n Says here you've been voted \"Most Likely To Sleep Through A Natural Disaster.\"\n !shrug\n Honestly, same."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].11"
msgid "!wavelunn\n <#BLUE>{name.npc_lunn}</> once carved my initials into a <#RED>{name.gourdo}'s</> leg.\n !laugh\n He got almost halfway through the \"B\" before it woke up."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].12"
msgid "!happy\n !think\n D'you think <#BLUE>{name.npc_scout}</> would let me borrow the <#RED>{name.i_damselfly}</>?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].13
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].13"
msgid "!happy\n !shocked\n You'll never guess who came by my workshop today!\n !eyeroll\n Oh wait, I promised not to say."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].14
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].14"
msgid "!happy\n !wavelunn\n Hahaha! Ohmygosh Lunn you are such a <i>riot!</> How do you come up with this stuff?\n !shocked\n Oh, sorry Hunter, it's an inside joke."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].15
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].15"
msgid "!neutral\n !gesture\n <#BLUE>{name.npc_dojo_master}</> once killed a <#RED>{name.rot}</> by slapping it in the face with a sandwich.\n !shocked\n And then ate the sandwich!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].16
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].16"
msgid "!gesture\n <#BLUE>{name.npc_dojo_master}</> mutters in his sleep.\n !think\n It'd be nice if he spoke up a little."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].17
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].17"
msgid "!shocked\n <#BLUE>{name.npc_dojo_master}</> told <#BLUE>{name.npc_scout}</> you were a gut biter!\n !think\n !shrug\n Or maybe it was \"good fighter.\" Lip-reading is hard."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].18
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].18"
msgid "!greet\n <#BLUE>{name.npc_dojo_master}</> has never stayed in one place this long.\n !shrug\n He must <i>really</i> like my work."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].19
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].19"
msgid "!wavelunn\n <#BLUE>{name.npc_lunn}</> and I would be great {name.job_dojo}s!\n !shrug\n We just don't wanna step on <#BLUE>{name.npc_dojo_master}</>'s toes. He's already missing a few."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].2"
msgid "!happy\n !dubious\n Skin too soft?\n !shocked\n Protect it with <#RED>Armour</>!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].3"
msgid "!happy\n !dubious\n Been feeling unlucky on the Hunt?\n !shocked\n With the right <#RED>Armour</>, you don't <i>need</i> luck!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].4"
msgid "!happy\n !shocked\n People's voices really carry in this camp. \n !bliss\n I love it!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].5"
msgid "!happy\n !think\n I wonder if <#BLUE>{name.npc_dojo_master}</> would take <#BLUE>{name.npc_lunn}</> as an apprentice.\n !agree\n <#BLUE>{name.npc_lunn}'s</> very studious."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].6"
msgid "!happy\n !point\n Information is the best <#RED>Armour</>.\n !shocked\n That's why I'm <i>always</i> listening!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].7"
msgid "!greet\n !point\n You're looking sharp!\n !wavelunn\n Almost as sharp as <#BLUE>{name.npc_lunn}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].8"
msgid "!shocked\n D'you ever think about singing your feelings?\n !point\n I think you'd be good at it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith].9"
msgid "!gesture\n Folks say I talk too much.\n !shrug\n But then when I listen, they call it eavesdropping."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith]NOT[wf_town_has_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith]NOT[wf_town_has_blacksmith].1"
msgid "!nervous\n Do you think <#BLUE>{name.npc_blacksmith}</> has made new friends elsewhere?\n !neutral\n !shrug\n Not that I'd care.\n !wavelunn\n But <#BLUE>{name.npc_lunn}</> misses him."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith]NOT[wf_town_has_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith]NOT[wf_town_has_blacksmith].2"
msgid "!nervous\n You're still looking for <#BLUE>{name.npc_blacksmith}</>, right?\n !dejected\n He's not as tough as he thinks."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith]NOT[wf_town_has_blacksmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_armorsmith]NOT[wf_town_has_blacksmith].3"
msgid "!nervous\n It's not that I miss <#BLUE>{name.npc_blacksmith}</>, it's just...\n !dubious\n ...no one's grunted angrily at me in ages."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,struggling_on_miniboss].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,struggling_on_miniboss].1"
msgid "!neutral\n !gesture\n Hm... Listen, Hunter.\n !gruffnod\n Yer mind is yer best weapon."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,weapon_fortification_level_0].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,weapon_fortification_level_0].1"
msgid "!gruffnod\n Me an' my forge will get the job done.\n !neutral\n !point\n All ye've gotta do is go out into the wilds an' get the goods I need.\n !dubious\n Ye ken?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,weapon_type_hammer,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,weapon_type_hammer,won_last_run].1"
msgid "!neutral\n !gruffnod\n Th' <#RED>{name.weapon_hammer}</>'s a good, honest weapon.\n !dubious\n ..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_apothecary].1"
msgid "!neutral\n !closedeyes\n <#BLUE>{name.npc_apothecary}'s</> not one for bletherin'.\n !gruffnod\n Makes fer a nice change."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_apothecary].2"
msgid "!neutral\n !closedeyes\n {name.town}'s gettin' crowded.\n !gruffnod\n <i>(hmph)</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].1"
msgid "!neutral\n !closedeyes\n Och, th' scullery reeks o' burnt porridge again.\n !dubious\n <i>(hmph)</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].2"
msgid "!neutral\n !closedeyes\n The <#BLUE>{name.job_cook}'s</> been after me biscuit recipe.\n !dubious\n Good luck. I'm a steel trap."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].3"
msgid "!neutral\n !closedeyes\n Th' dinner around here's like a Guild initiation rite.\n !dubious\n <i>(hmph)</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,wf_town_has_cook].4"
msgid "!neutral\n !disagree\n Och. Yer <#BLUE>{name.job_cook}'s</> mince and tatties'd kill a <#RED>{name.groak}</> faster'n a <#RED>{name.weapon_cannon}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,won_last_run].1"
msgid "!neutral\n !dubious\n Hrm.\n !gruffnod\n Yer showin' promise."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,won_last_run].2"
msgid "!neutral\n !dubious\n Och, well done.\n !closedeyes\n I've not smiled like this in years."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,won_last_run].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith,won_last_run].3"
msgid "!neutral\n !gruffnod\n Ye almost gave <#BLUE>{name.npc_scout}</> a wee heart attack that time.\n !dubious\n ..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].1"
msgid "!neutral\n !point\n Yer wee {name.job_armorsmith}'s been snoopin' round me forge again.\n !dubious\n <i>(hmph)</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].10"
msgid "!neutral\n !closedeyes\n {name.blacksmith_grunt} I'm busy. Bother someone else."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].11"
msgid "!neutral\n !dubious\n ...Ye keep standin' there, ye'll grow moss."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].12"
msgid "!neutral\n !gruffnod\n There's always work that needs ta be done.\n !dubious\n ...Don't ye have somewhere ta be, Hunter?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].13
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].13"
msgid "!neutral\n !gesture\n Want somethin' forged?\n !dubious\n ...No? Then why are ye botherin' me?!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].14
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].14"
msgid "!neutral\n !closedeyes\n That {name.job_dojo}'s got some battle scars.\n !dubious\n I'd wager he's got some tales to tell."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].15
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].15"
msgid "!neutral\n !gruffnod\n I had a square go wit' yer {name.job_dojo}.\n !point\n Fierce fella."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].2"
msgid "!neutral\n !disagree\n Hrm. Ye've got naught for me, I see.\n !dubious\n ..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].3"
msgid "!neutral\n !gruffnod\n 'Tis a fine forge ye've got here."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].4"
msgid "!neutral\n !dubious\n Have ye e'er ate a good, hot mustard?\n !gruffnod\n Me mind's been spinnin' on a good, hot mustard."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].5"
msgid "!neutral\n !point\n I'm here ta work, not chat."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].6"
msgid "!neutral\n !gruffnod\n There's always work that needs ta be done."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].7"
msgid "!neutral\n !dubious\n What are ye gawkin' at? Never seen a smithy ponderin' before?\n !point\n I cannae work with folks peerin' over me shoulder."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].8"
msgid "!neutral\n !dubious\n Och. I see how it is.\n !point\n Ye think I'm not busy? Got all the time in th'world for a wee blether? Feh."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_blacksmith].9"
msgid "!neutral\n !dubious\n That wee <#BLUE>{name.job_armorsmith}'s</> been snoopin' round me forge again.\n !point\n Ye'd better tell her ta keep her nose outta other folks' business.\n !think\n ...Lots o' <i>accidents</> can happen 'round a forge. Nasty accidents."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook,won_last_run].1"
msgid "!happy\n !clap\n Hoooo-whee! Heard you gave 'em a real thrashing out there!\n !happy\n !dubious\n All thanks to that faaaan<i>tastic</> lunch I packed for you, right?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook,won_last_run].2"
msgid "!happy\n !point\n Nice going, Hunter!\n !happy\n !dubious\n Did you get lots of good loot from beating that oversized <#RED>{name.rot_boss}</>?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].1"
msgid "!happy\n !greet\n Well howdy there, Hunter!\n !point\n Feelin' a bit peckish?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].2"
msgid "!happy\n !bliss\n There's nothin' I love more in this world than whipping up big tasty batches of grub!\n !point\n Hooo-wee! Boy howdy!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].3"
msgid "!happy\n !greet\n Howdy! Everything's right as rain here--\n !shrug\n I sure do love choppin' and fryin' and all that other cookin' stuff!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].4"
msgid "!laugh\n Well, someone's lookin' ready for adventure!\n !happy\n !dubious\n Best get a move-on, don't ya think?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].5"
msgid "!neutral\n !think\n Aw shucks, I can't find my flipper-flapper... er... turner-over...er...?\n !shocked\n Splatula! I definitely meant splatula."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].6"
msgid "!happy\n !greet\n Hoo-boy, I sure am workin' hard in this here kitchen! Yes-siree!\n !bliss\n Here I am, cookin' up a storm!\n !happy\n !shrug\n Mixin' and stirrin' away!\n !neutral\n ...Are you gonna be standin' there for much longer, Hunter?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].7"
msgid "!neutral\n !shocked\n Yeep! Don't sneak up on me like that!!\n !happy\n !nervous\n ...Uh, sorry, guess I got a mite jumpy there. Good to see ya!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].8"
msgid "!happy\n !dubious\n Findin' lots of rare stuff on your adventures?\n !shrug\n Just curious!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_cook].9"
msgid "!happy\n !think\n Whew, the stuff in that big chest sure would fetch a pretty penny back in <#BLUE>the Brinks</>.\n !neutral\n !shocked\n N-not that I was snoopin' or nothin'!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].1"
msgid "!happy\n !point\n Way to go.\n !gruffnod\n You put the fear in 'em out there."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].2"
msgid "!happy\n !point\n There's my star pupil.\n !think\n It'd be nice if the rest of my students learned a thing or two from you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].3"
msgid "!neutral\n !gruffnod\n There's the Hunter of the hour.\n !dubious\n Whatcha need?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].4"
msgid "!happy\n !gruffnod\n A+, kid.\n !gesture\n Now. You need a lesson review?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo,won_last_run].5"
msgid "!neutral\n !gruffnod\n I'm glad at least <i>one</i> of my students pays attention in class.\n !happy\n !dubious\n Whatcha need?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].1"
msgid "!neutral\n !point\n It's easy to regret a swing, but you'll never regret a <#RED>{name.concept_dodge}</>.\n !shrug\n So, y'know. <#RED>{name.concept_dodge}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].10"
msgid "!neutral\n !point\n Didja know smacking objects in the environment keeps yer <#RED>Hit Streak</> going?\n !happy\n !gesture\n 'Thought it was a good tip."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].11"
msgid "!neutral\n !dubious\n A <#RED>{name.beets}</> is dazed after a head slam.\n !point\n Bait and <#RED>{name.concept_dodge}</> before going in for the kill."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].12"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !point\n You can swap your equipped gear at the <#RED>{name.i_station_armorsmith}</> here in town."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].13
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].13"
msgid "!neutral\n !gesture\n You can't change your gear once you set out on a Hunt.\n !cough\n {name.dojo_cough} Dress wisely before you leave."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].14
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].14"
msgid "!neutral\n !point\n Don't forget, it's more important to stay alive than it is to strike.\n !happy\n !gruffnod\n This is yer daily reminder to <#RED>{name.concept_dodge}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].15
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].15"
msgid "!neutral\n !gruffnod\n Remember, all <#RED>Weight</> builds are viable.\n !point\n You just gotta find what build works for you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].16
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].16"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !gruffnod\n All great Hunters started off as newbies trying stuff out."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].17
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].17"
msgid "!happy\n !agree\n If you ever feel stuck, try changing up your gear.\n !happy\n !shrug\n If nothing else, you'll feel snazzy."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].18
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].18"
msgid "!happy\n !agree\n Gettin' stuck is just an opportunity to try new things.\n !gesture\n Try experimenting with your tactics."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].19
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].19"
msgid "!neutral\n !dubious\n <#RED>{name_multiple.rot}</> have melons for brains.\n !disagree\n <#RED>{name_multiple.yammo}'ll</> hit their own pals if you bait a swing right."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].2"
msgid "!neutral\n !gesture\n You can check yer <#RED>Weight Class</> over at the <#RED>{name.i_station_armorsmith}</>.\n !cough\n {name.dojo_cough}"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].20
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].20"
msgid "!neutral\n !cough\n {name.dojo_cough} Hey.\n !dubious\n Be wary of the folks in the woods."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].21
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].21"
msgid "!neutral\n !cough\n You done any training lately?\n !happy\n !point\n You can practice <#BLUE>Focus Hits</> on the dummies here in town."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].22
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].22"
msgid "!neutral\n !gesture\n <#RED>{name_multiple.concept_relic}</> only last for one Hunt.\n !point\n Experiment with yer combinations."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].23
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].23"
msgid "!neutral\n !cough\n Listen up, Hunter.\n !gesture\n You'll know yer <#RED>Luck</> stat swayed a sitchy-ation if you see a <#RED>Lucky Clover Icon</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].24
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].24"
msgid "!neutral\n !gesture\n Gusts of <#RED>Wind</> aren't so bad if you're a <#RED>{name.heavy_weight} Class</> build.\n !happy\n !dubious\n <#RED>{name.light_weight} Class</> build? Different story."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].25
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].25"
msgid "!neutral\n !cough\n Listen up, Hunter.\n !point\n Every <#RED>Enemy</> is predictable, if you learn to read them."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].26
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].26"
msgid "!neutral\n !point\n Study your foes. Watch their moves.\n !happy\n !gruffnod\n Soon you'll see the openings."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].27
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].27"
msgid "!happy\n !gesture\n Didja know you can get a <#RED>Critical</> <#BLUE>Focus Hit</>?\n !gruffnod\n Powerful stuff."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].28
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].28"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !happy\n !gesture\n Need a lesson?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].29
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].29"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !happy\n !gesture\n How're yer studies going?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].3"
msgid "!neutral\n !gesture\n You can check yer <#RED>Weight Class</> over at any <#RED>Weapon Rack</>.\n !cough\n {name.dojo_cough}"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].30
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].30"
msgid "!happy\n !gruffnod\n Need anything explained?\n !cough\n Ask away."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].31
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].31"
msgid "!happy\n !gruffnod\n Hmph.\n !agree\n I'm in a teachin' mood today."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].32
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].32"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !gesture\n Don't forget to review the fundamentals."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].33
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].33"
msgid "!neutral\n !cough\n {name.dojo_cough}\n !happy\n !gesture\n Need me to explain anythin'?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].4"
msgid "!neutral\n !point\n Be thoughtful when yer trying new <#RED>Armour</>.\n !gesture\n Changing your gear might change your <#RED>Weight Class</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].5"
msgid "!happy\n !shrug\n It's easier to fight when you're comfy.\n !neutral\n !gesture\n Try mixin' and matchin' <#RED>Armour</> sets to get your favourite <#RED>Weight Class</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].6"
msgid "!neutral\n !think\n Kids these days can't get enough of them <#RED>'Emote Rings'</> <p bind='Controls.Digital.SHOW_EMOTE_RING' color=BTNICON_DARK>.\n !disagree\n I prefer to never express myself."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].7"
msgid "!neutral\n !point\n Some <#RED>{name_multiple.concept_relic}</> is more powerful than others, y'know.\n !gruffnod\n You can tell <#RED>Fabled {name_multiple.concept_relic}</> apart by the fancier frames around their icons."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].8"
msgid "!neutral\n !point\n Listen up.\n !gruffnod\n You can do <#RED>Dodge Cancels</> to keep up your <#RED>Hit Streak</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo].9"
msgid "!neutral\n !point\n How's yer gear treatin' you?\n !happy\n !shrug\n Gettin' new equipment's just as important as upgrading your old stuff. Maybe even more."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].1"
msgid "!happy\n !gruffnod\n Team trainin's progressin' well. Everyone's showin' up and puttin' in the work. \n !gesture\n Sure, the <#KONJUR>Bubble Shield</> is good 'n' all, but we can't rest on laurels. Should it fail, we need to be ready. \n !think\n <#BLUE>{name.npc_cook}'s</> surprised me. I'd swear she's had combat trainin' before, but she says her cookin' skills are just \"transferable\"... \n !shrug\n And here I am, can't toast a toadstool without burnin' down the woods."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].2"
msgid "!neutral\n !think\n Been a year since <#BLUE>{name.flitt_lastname}</> disappeared. Could be darn near anywhere with that <#KONJUR>{name.konjur} Staff</> of his. \n !point\n But that don't scare me, Hunter, and I'll tell ya why: he's still got love in his heart. \n !think\n Think about it, Hunter. If he'd really wanted to hurt us, the smart move woulda been to play nice, gain our trust, then attack from within. \n !gesture\n But to hear y'all tell it, he teleported away because he feared he might still hurt <#BLUE>{name.npc_scout}</>.\n !gruffnod\n So I choose to believe <#BLUE>{name.flitt_lastname}'s</> out there, workin' on changin', healin'."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].3"
msgid "!neutral\n !greet\n Just got back from a tour of the <#KONJUR>Bubble Shield's</> perimiter. \n !shrug\n I know it aggravates my cough somethin' fierce, but old habits, y'know. Got to make sure it's secure--\n !cough\n {name.dojo_cough}\n !gesture\n Most <#RED>{name.rot}</> act like they just don't like the smell of the <#KONJUR>Shield</> 'n' turn away before gettin' too close.\n !dubious\n But I've seen some <#RED>{name.rot}</>, they seem taken by a darker energy. They <i>test</> the <#KONJUR>Shield</>, Hunter. \n !think\n Poke at it. Press on it. Claw, even. They can't get through, mind you, but it's enough to keep me patrollin'. \n !gruffnod\n Can't give these <#RED>{name.rot}</> an inch, Hunter. Not. One. Inch."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_dojo_master,super_frenzy_unlocked].4"
msgid "agent:\n !happy\n !think\n I don't think I've told you how proud I am of you for defeating <#BLUE>{name.flitt_lastname}</> in the Battle of <#BLUE>{name.tefframech_volcano}</>...\n player:\n Aw, thanks, {name.npc_dojo_master}. And it only took a year!\n agent:\n !neutral\n !angry\n Hmph. Well I still haven't. Let's see if I tell you next year."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_konjurist].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_konjurist].1"
msgid "!neutral\n !dubious\n Ran into <#BLUE>{name.npc_konjurist}</>, huh? I'd know her work anywhere."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_konjurist].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_konjurist].2"
msgid "!neutral\n !think\n I bet <#BLUE>{name.npc_konjurist}</> is snitching on you to <#BLUE>Doc {name.flitt_lastname}</>.\n !point\n But you probably knew that already."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_konjurist].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_konjurist].3"
msgid "!neutral\n !point\n <#BLUE>{name.npc_konjurist}</> doesn't see people. She sees {name.c_konjur} auras.\n !shrug\n At least, that's what she told me. And I believe her."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_specialeventhost]refiner_seen_wanderer.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_seen_npc_specialeventhost]refiner_seen_wanderer.1"
msgid "agent:\n !neutral\n !shocked\n Your {name.c_konjur} signature is...\n !point\n Did you run into that mysterious kind of wandering kind of guy on your last Hunt? How did he seem?\n player:\n Oh... yeah. He seemed, y'know, mysterious and... wander-ous...\n agent:\n !dubious\n Yeah, but did he seem happy?\n player:\n Oh. He's kind of hard to read...\n agent:\n !dejected\n Oh.\n player:\n But yeah, he seemed happy. For sure.\n agent:\n !happy\n ... Appreciated, Hunter."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_town_has_apothecary].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_town_has_apothecary].1"
msgid "!happy\n !gesture\n <#BLUE>{name.npc_apothecary}</> is some kind of plant whisperer.\n !agree\n And not <i>just</> because I've clocked her whispering to plants."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_town_has_apothecary].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_town_has_apothecary].2"
msgid "!happy\n !gesture\n <#BLUE>{name.npc_apothecary}'s</> <i>such</> a dyed-in-the-wool anarchist.\n !clap\n Like, to the point she doesn't even subscribe to <i>that</> ideology. She's an inspiration to us rebels everywhere."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_town_has_apothecary].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,wf_town_has_apothecary].3"
msgid "!neutral\n !nervous\n Do you think <#BLUE>{name.npc_apothecary}</> likes me?\n !gruffnod\n Not that I care, obvs."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].1"
msgid "!happy\n !agree\n Nice work, Hunter. Dad's a bit safer with you thrashing <#RED>{name_multiple.rot}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].2"
msgid "!happy\n !gruffnod\n Nice run, Hunter. I sanction your reckless use of {name.c_konjur}. He he he."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].3"
msgid "!neutral\n !agree\n The way you rock those <#RED>{name_multiple.rot}</> rules."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].4"
msgid "!neutral\n !think\n {name.c_konjur} made the Rot what they are, but <#KONJUR>{name.konjur}</> made you what <i>you</> are so...\n !happy\n !shrug\n Lose, win... draw?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].5"
msgid "!happy\n !point\n You're the one instance of environmental devastation I can get on board with."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].6"
msgid "!happy\n !greet\n Good Hunt? You're glowing!\n !neutral\n !think\n That <i>could</> be the {name.c_konjur}, though..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner,won_last_run].7"
msgid "!neutral\n !think\n Hm. <i>Do</> <#RED>{name.rot}</> have butts?\n !point\n If they do, you've kicked 'em. If they don't, you've kicked 'em off. Case closed."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].1"
msgid "agent:\n !neutral\n !point\n You eat {name.c_konjur} all the time, right?\n player:\n \"Eat\" isn't quite right. \"Absorb\"?\n agent:\n !dubious\n And you're good? No visions of thirsty ghosts or a desire to flip coins?\n player:\n No... Should I?\n agent:\n !notebook\n No, no. Just checking."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].10"
msgid "!neutral\n !point\n Did you know <i>every one of us</> has about a shoe's worth of {name.c_konjur} in their bodies?\n !angry\n Yeah, I said 'shoe's worth'.\n !shrug\n Look, we make do with what measurement tools we've got in the field, alright? Science is DIY, OK? NBD."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].11"
msgid "!neutral\n !eyeroll\n Loving my setup here. <i>Except</> for the smells from <#BLUE>{name.npc_cook}'s</> grill. Yeesh."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].12"
msgid "!neutral\n !think\n <#KONJUR>{name.konjur}'s</> not some miracle goo.\n !angry\n It's useless at spiking up my hair, for example."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].13
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].13"
msgid "!happy\n !shrug\n To me, science is like music--you just bash things together and see what happens!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].14
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].14"
msgid "!neutral\n !gesture\n Is <#BLUE>{name.npc_scout}</> afraid to talk to me?\n !happy\n !shrug\n I mean, <i>I</> would be."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].15
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].15"
msgid "!neutral\n !shrug\n I learned a lot working with <#BLUE>Doc {name.flitt_lastname}</>.\n !think\n Like \"Don't work with mad scientists,\" for example."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].16
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].16"
msgid "!neutral\n !point\n Am I worried about all the {name.c_konjur} you consume? No.\n !neutral\n !scared\n Am I worried about all of <#BLUE>{name.npc_cook}'s</> cooking <i>I</> consume? Yes.\n !think\n <z 0.7> What does she PUT in that stuff? I can't stop eating it...</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].17
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].17"
msgid "!neutral\n !think\n Do I think having worked for <#BLUE>Doc {name.flitt_lastname}</> makes me a sellout?\n !dejected\n All. The. Time."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].18
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].18"
msgid "!neutral\n !think\n I really admire your commitment to direct action, mutual aid, and water conservation.\n !laugh\n I'm assuming the 'water conservation' one, since I've never <i>once</> seen you bathe.\n !shocked\n N-not that I'm trying to watch you bathe! He. He. Eh... <z 0.7>Dang it, {name.npc_refiner}! You're so AWKWARD!</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].19
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].19"
msgid "!neutral\n !think\n Is it weird you're not sick, given all the {name.c_konjur} you're exposed to?\n !happy\n !agree\n Yes, it is very weird. You're a big weirdo. \n !gruffnod\n That <i>is</> my scientific opinion."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].2"
msgid "!happy\n !gesture\n Nothing like some loud music and getting lost in {name.c_konjur}-based mutation data, y'know?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].20
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].20"
msgid "!neutral\n !dubious\n <#BLUE>Doc {name.flitt_lastname}'s</> precious grandchild is bigger than I'd imagined.\n !think\n I guess I <i>did</> imagine they'd be a baby, for whatever reason."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].21
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].21"
msgid "!neutral\n !think\n It's reckless, <#BLUE>{name.npc_scout}'s</> being here.\n !angry\n It'll aggravate their illness <i>and</> their <#BLUE>Grandpa</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].22
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].22"
msgid "!neutral\n !gesture\n I know <#BLUE>{name.npc_scout}'s</> trying to do what's right.\n !angry\n Even though so much wrong has been done in their name..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].3"
msgid "!neutral\n !point\n You weren't about to tell me what I can and can't do, were you?\n !laugh\n I'm just pulling your chain, Hunter. I wouldn't have listened anyway."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].4"
msgid "!neutral\n !think\n I'm concurrently parsing {name.c_konjur}'s mutagenic factors while coming up with names for a new punk band and-- Ooh--\n !happy\n !notebook\n \"Mass In-parse-ration.\"\n \"Factoress.\"\n \"Lottie and The Muta-Genies.\"\n !neutral\n !angry\n Ugh. Those suck. Maybe less multitasking..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].5"
msgid "!neutral\n !gruffnod\n I don't have a problem with authority. Authority has a problem with <i>me</>.\n !laugh\n Mainly because of withering comments like that one."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].6"
msgid "!happy\n !gesture\n So you're all just misfits and losers from <#BLUE>The Brinks</>, huh? \n !gruffnod\n Very cool. Very cool."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].7"
msgid "!neutral\n !gesture\n I've never been to <#BLUE>The Brinks</>. I always imagined it like this, though.\n !think\n Hardscrabble people, pulling together, makin' something better out of what they have...\n !shrug\n But, for some reason, I thought there'd be a lot more hats."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].8"
msgid "!neutral\n !disagree\n Careful with all that {name.c_konjur}. We still don't fully understand it..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner].9"
msgid "!neutral\n !think\n {name.c_konjur}'s here to stay, like it or not.\n !dubious\n Like <#BLUE>{name.npc_cook}'s</> weird foot rash, which she keeps showing me despite my telling her I'm not that kind of doctor."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner]refiner_twin.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_refiner]refiner_twin.1"
msgid "agent:\n !neutral\n !dubious\n Uh, what're you staring at?\n player:\n Do... Do you have a twin?\n agent:\n !neutral\n !think\n Uh, no?\n player:\n You sure? While you were kidnapped, you were somehow simultaneously <i>here,</> in Camp...\n agent:\n !shocked\n Are you feeling okay? You eat a lot of {name.c_konjur}, don't you?\n !think\n It <i>has</> been known to cause hallucinations... You also get hit in the head a lot...\n player:\n Huh. Yeah... that could be it, I guess..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].1"
msgid "!happy\n !gesture\n It's nice to have <#BLUE>{name.npc_armorsmith}</> around.\n !closedeyes\n I think she brightens up the camp."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].2"
msgid "!happy\n !gesture\n Feel free to chat with folks around town.\n !agree\n It's good for morale."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].3"
msgid "!happy\n !gesture\n Take some time to socialize with the other <#RED>{name_multiple.foxtails}</>.\n !neutral\n !point\n It's good for team cohesion."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_armorsmith].4"
msgid "!happy\n !think\n <#BLUE>{name.npc_armorsmith}</> truly doesn't care what others think of her.\n !shrug\n I can't relate. But I admire it."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_blacksmith].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_blacksmith].1"
msgid "!happy\n !gesture\n I'm glad I hired <#BLUE>{name.npc_blacksmith}</>.\n !agree\n I can trust him to be honest with me."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_cook].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_cook].1"
msgid "!happy\n !gesture\n <#BLUE>{name.npc_cook}</> is an interesting character, isn't she?\n !neutral\n !gesture\n There's <i>something</> about her..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_cook].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_cook].2"
msgid "!happy\n !gesture\n If you're taking a <#RED>{name.i_lunchbox}</>, make sure it's packed before we leave.\n !shrug\n I don't wanna have to fly all the way back for a sandwich."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_cook].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,wf_town_has_cook].3"
msgid "!happy\n !gesture\n You'll get some good <#RED>Buffs</> from <#BLUE>{name.npc_cook}'s</> cooking.\n !shrug\n I guess that's just my way of saying \"don't forget to eat\"."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].1"
msgid "!closedeyes\n Ahh. I love a victory flight home, don't you?\n !agree\n The air just <i>feels</i> headier."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].2"
msgid "!clap\n Another hunt well done, Hunter.\n !gesture\n Not that I had any doubts."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].3"
msgid "!gesture\n There are few things more refreshing than the wind rushing through my fur.\n !think\n I have to brush it kinda thoroughly afterwards to prevent matting, though."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout,won_last_run].4"
msgid "!laugh\n I bet you enjoy the flight home more when you're conscious, huh?\n !shrug\n I bet you remember more of the scenery at least."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].1"
msgid "!neutral\n !point\n Remember to prioritize <#RED>Dodging</> over <#RED>{name.concept_damage}</> out there.\n !happy\n !nervous\n I don't mean to tell you how to Hunt. I just don't want anyone getting hurt."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].10"
msgid "!happy\n !gesture\n No pressure, but let me know when you're ready.\n !agree\n I'm itching to get back in the air!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].11"
msgid "!happy\n !gesture\n Ready for another {name.run}?\n !point\n Just hop in the ol'<#RED>{name.i_damselfly}</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].12"
msgid "!happy\n !gesture\n There's training dummies here in town if you'd like a chance to practice.\n !neutral\n !shrug\n If you can bring yourself to hit them, anyway. They're kinda cute.\n !happy"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].13
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].13"
msgid "!happy\n !gesture\n Don't forget, you can practice your moves on the training dummies around town.\n !shrug\n It's a good way to get the hang of a new weapon."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].14
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].14"
msgid "!happy\n !gesture\n Ready to {name.run}?\n !point\n The <#RED>{name_multiple.rot}</> aren't ready for you, I'll tell you that for free."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].2"
msgid "!happy\n !gesture\n Rest here as long as you need, Hunter.\n !shrug\n It's not like the <#RED>{name_multiple.rot}</> are going anywhere."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].3"
msgid "!neutral\n !gesture\n Make sure to double check your gear before we head out.\n !happy\n !dubious\n I don't want to have to fly back, y'know?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].4"
msgid "!happy\n !gesture\n Don't forget, you can't change your <#RED>Armour</> once we leave!\n !neutral\n !shrug\n It'd be unwieldy to pack <i>all</i> the <#RED>Armour</> you own for every flight, y'know?\n !happy"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].5"
msgid "!happy\n !greet\n We can head out whenever you're ready.\n !gesture\n No rush."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].6"
msgid "!happy\n !gesture\n Nice day, isn't it?\n !bliss\n My allergies are only moderately debilitating today!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].7"
msgid "!happy\n !gesture\n Take a load off, Hunter. We're safe here in camp.\n !neutral\n !shrug\n At least I think we're safe.\n !happy"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].8"
msgid "!happy\n !gesture\n Make yourself at home.\n !neutral\n !shrug\n This <i>is</i> your home for the foreseeable future, after all.\n !happy"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout].9"
msgid "!happy\n !gesture\n Ready to head out?\n !neutral\n !think\n I think I'm ready. Wait, did I pack my--"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]NOT[wf_town_has_armorsmith]armoursmith_itch_cream.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]NOT[wf_town_has_armorsmith]armoursmith_itch_cream.1"
msgid "!neutral\n !dubious\n I found <#BLUE>{name.npc_armorsmith}'s</> anti-itch cream in some debris.\n !scared\n She's probably missing that by now."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]bonion_cry.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]bonion_cry.1"
msgid "!neutral\n !dejected\n Every time I see a <#RED>{name.cabbageroll}</> die I end up crying a little bit.\n !think\n But I'm not sure if that's because I feel bad for it, or because of the <#RED>{name.cabbageroll}</> stink."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]dojo_toe_nails.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]dojo_toe_nails.1"
msgid "!neutral\n !angry\n I wish <#BLUE>{name.npc_dojo_master}</> wouldn't clip his toenails in the common area.\n !gesture\n He <i>insists</> they're a natural <#RED>Rot</> repellant, but there's no way that's true... right?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]gathering_data.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]gathering_data.1"
msgid "!happy\n !gesture\n It's a lot easier to scout when you've got a fighter on the ground!\n !bliss\n I'm gathering so much info from your {name_multiple.run}!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]playing_cards.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]playing_cards.1"
msgid "!happy\n !bliss\n Oh hey! My pack of playing cards survived the crash!\n !gesture\n Well at least we have the essentials! Haha."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]smushed_rations.1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,in_town,role_scout]smushed_rations.1"
msgid "!neutral\n !think\n Hm... our food got pretty smushed in the <#RED>{name.i_damselfly}</> crash.\n !happy\n !shrug\n I hope no one's picky."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,konjur_rich,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,konjur_rich,role_konjurist,upgradable_powers].1"
msgid "!happy\n !point\n Whewie, you're <i>ripe</i> with <#KONJUR>{name.i_konjur}</> stink-- need an <#RED>Upgrade</>?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,received_power_upgrade,role_konjurist,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,received_power_upgrade,role_konjurist,upgradable_powers].1"
msgid "!neutral\n !notebook\n Need another <#RED>Upgrade</>?\n !shrug\n <#RED>{name_multiple.mothball}</> are more dangerous than they look, you know."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_konjurist]NOT[upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_konjurist]NOT[upgradable_powers].1"
msgid "!neutral\n !think\n The samples I collect in this swamp are quite interesting.\n !notebook\n If you've got nothing to <#RED>Upgrade</>, I'd like to get back to them."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout,wf_town_has_armorsmith]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout,wf_town_has_armorsmith]NOT[in_town].1"
msgid "!happy\n !point\n <#BLUE>{name.npc_armorsmith}'s</> been teaching me all about skincare lately.\n !think\n I wonder if the goop here would make a good mask."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].1"
msgid "!neutral\n !nervous\n Oooh. I stepped in something goopy.\n !dubious\n Gross."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].2"
msgid "!neutral\n !think\n Hmmmm..... Yeah.\n !dejected\n I'll <i>definitely</i> need to hose down the <#RED>{name.i_damselfly}'s</> floor mats when we get home."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].3"
msgid "!neutral\n !think\n How d'you think the <#RED>{name.bandicoot}</> gets her fur so silky?\n !shocked\n I-I'm not jealous!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].4"
msgid "!neutral\n !nervous\n This whole place is caked top to bottom with fungus.\n !shrug\n And where there's fungus, there's <#RED>Spores</>. They're mostly benign, but they <i>can</i> cause some weird effects.\n !point\n I'd suggest learning to identify them by sight."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_scout]NOT[in_town].5"
msgid "!neutral\n !gesture\n The <#RED>{name.rot_boss}</> in this area is something called an <#RED>{name.bandicoot}</>.\n !nervous\n It's huge, and seems to delight in tormenting people with its tricks.\n !dubious\n This'll be a very different fight from the last <#RED>{name.rot_boss}</>. Steel yourself."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_travelling_salesman].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_travelling_salesman].1"
msgid "!happy\n !gesture\n Don't <i>muck</i> about with inferior products, my friend.\n !point\n For the discerning ssshopper, it's {name.npc_doc_lastname}-brand or bust!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_travelling_salesman].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_bandi_swamp,role_travelling_salesman].2"
msgid "!happy\n !gesture\n Don't get <i>bogged down</i> with inferior products!\n !point\n Buy {name.npc_doc_lastname}-brand <#RED>Health {name.potion}s</>, for all your recovery needs!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1"
msgid "!think\n If the cold's starting to get to you...\n !point\n You could always try warming up with a new <#RED>Upgrade</>."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_konjurist]NOT[upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_konjurist]NOT[upgradable_powers].1"
msgid "!think\n I need to get back to analyzing my samples.\n !shrug\n They'll freeze if I leave them out too long."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout,wf_town_has_cook]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout,wf_town_has_cook]NOT[in_town].1"
msgid "!happy\n !gesture\n It's a shame <#BLUE>{name.npc_cook}</> can't see this place.\n !neutral\n !think\n She likes things that sparkle. Or at least that's what <#BLUE>{name.npc_armorsmith}</> told me."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].1"
msgid "!happy\n !gesture\n Lucky for us, this cavern is wide enough for me to fly the <#RED>{name.i_damselfly}</> through.\n !neutral\n !dejected\n <z 0.7>(sigh)</z> I'll be missing the open sky, though."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].2"
msgid "!neutral\n !gesture\n Look at those giant walls of ice!\n !happy\n !agree\n It's a good thing I'm not claustrophobic.\n !nervous\n Haha... <z 0.7>ha...</z>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].3"
msgid "!happy\n !think\n You know... this place is actually kind of beautiful. In its own way.\n !nervous\n Not that I'd like to stick around too long."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].4"
msgid "!neutral\n !scared\n Brrr...\n !notebook\n Note to self: next expedition, pack extra thick socks."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_eggzy_tundra,role_scout]NOT[in_town].5"
msgid "!neutral\n !think\n <#BLUE>{name.npc_dojo_master}</> told me he lost one of his toes to frostbite.\n !nervous\n Let's... try to avoid that, shall we?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1"
msgid "!shrug\n Sure it's a little eerie out here, but you get used to it after a while.\n !neutral\n ...Mostly."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_konjurist]NOT[upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_konjurist]NOT[upgradable_powers].1"
msgid "!neutral\n !think\n Those old security systems can be a real pain to get around, huh?\n !gesture\n An <#RED>Upgrade</> or two might help with that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].1"
msgid "!neutral\n !dejected\n This is my old home. It's... It's all gone now."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].2"
msgid "!neutral\n !scout_rummage\n Maybe something of mine is still here..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].3"
msgid "!neutral\n !greet\n <#BLUE>Grandpa</> and I lived here. Seems like ancient history now. \n !dejected\n Maybe it is."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].4"
msgid "!neutral\n !closedeyes\n So many memories growing up here. All gone now."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout,room_type_quest]NOT[in_town].5"
msgid "!neutral\n !disagree\n It's surreal, to see your childhood home suddenly in ruins."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,received_power_upgrade,role_scout,upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,received_power_upgrade,role_scout,upgradable_powers].1"
msgid "!neutral\n !gesture\n How are those <#RED>Upgrades</> treating you?\n !notebook\n Let me know if you experience any dizziness or shortness of breath.\n !point\n Ha! Kidding! ...But let me know if you do."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].1"
msgid "!happy\n !closedeyes\n It's so peaceful here.\n !gesture\n Almost makes you forget how crazy the rest of the world is... almost."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].2"
msgid "!neutral\n !think\n I wonder if the old fishing hole still exists. I always meant to go...\n !shrug\n Just assumed it'd always be there, or <i>I'd</> always be here to go. Hm."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].3"
msgid "!happy\n !shocked\n Can you believe this little grove was tucked away in the forest?\n !bliss\n I bet it'll make a great camping spot one day, once we've saved <#BLUE>the {name.rotwood}</>!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].4"
msgid "!neutral\n !think\n The <#RED>Wind</> here is strong and constant enough to actually blow away some of the <#KONJUR>{name.konjur}</> smog.\n !happy\n !agree\n At night, you can actually see the stars!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].5"
msgid "!neutral\n !agree\n I hope you're warm enough in that.\n !dubious\n It gets pretty <#RED>Windy</> out here."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].6"
msgid "!neutral\n !think\n <#RED>{name.owlitzer_forest}'s</> full of <#RED>{name_multiple.rot}</> with <#RED>Wind</> abilities.\n !point\n If you've got <#RED>{name.heavy_weight} Class</> gear it won't bother you much, but anything lighter and you might find it hard to keep your footing."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].7"
msgid "!point\n I've only spotted the <#RED>{name.owlitzer}</> outside its nest a few times, but I saw enough to know it's a <i>massive</i> bird with crazy sharp talons!\n !scared\n A single flap of its wings creates huge blasts of air!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[in_town].8"
msgid "!happy\n !gesture\n The <#RED>Wind</> here presents a fun challenge flying the <#RED>{name.i_damselfly}</> overhead.\n !neutral\n !shocked\n Oh, don't worry though! It won't affect my ability to come to your rescue in an emergency!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[upgradable_powers].1"
msgid "!neutral\n !angry\n Ugh, this stupid wind...\n !dejected\n I lost half a day's worth of notes because I forgot to weigh them down with a paperweight."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1"
msgid "!neutral\n !notebook\n Chilly out.\n !dubious\n Need an <#RED>Upgrade</>?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].2"
msgid "!neutral\n !notebook\n <#KONJUR>{name.konjur}'s</> good for blood circulation, you know.\n !dubious\n So? <#RED>Upgrade</> time?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist]NOT[upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_konjurist]NOT[upgradable_powers].1"
msgid "!neutral\n !dubious\n Nothing to <#RED>Upgrade</>, huh?\n !notebook\n Don't freeze out there."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].1"
msgid "!neutral\n !scared\n Brr...\n !gesture\n My fur's double-coated and I can <i>still</i> feel that chill!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].10
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].10"
msgid "!happy\n !gesture\n If you see a <#RED>Brazier</> that's frozen over, a few good whacks should shake the ice off and get it burning again."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].11
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].11"
msgid "agent:\n !happy\n !point\n Remember Hunter, even if you get frozen solid, you can still wiggle your way out.\n player:\n How do I do that?\n agent:\n !neutral\n !think\n This may be an odd analogy, but I like to imagine I have a keyboard in front of me, and I'm mashing a bunch of buttons.\n player:\n Your mind works in mysterious ways, {name.npc_scout}.\n agent:\n !happy\n !laugh\n Ha! I suppose you're right."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].12
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].12"
msgid "!neutral\n !scared\n Brrr... boy, am I glad I installed a seat warmer in the <#RED>{name.i_damselfly}</>..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].2"
msgid "!neutral\n !scared\n Brrr! Sure wish I was an arctic fox about now."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].3"
msgid "!neutral\n !point\n Hey, don't lick any metal while you're out there.\n !shrug\n If you like having a tongue, anyway."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].4"
msgid "!neutral\n !gesture\n Keep an eye out for <#RED>Heat Sources</> out there so you don't <#RED>Freeze</> solid!\n !scared\n Boy, I'm glad I packed my scarf."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].5"
msgid "!happy\n !think\n This snow's kinda pretty, huh?\n !happy\n !gesture\n I swear it sparkles a little from different angles. Haha. Neat."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].6"
msgid "!neutral\n !scared\n I think my entire nose is turning into an ice cube.\n !nervous\n Hunter? Is my nose still there? Tell me the truth."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].7
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].7"
msgid "!neutral\n !scared\n Brr!!\n !shocked\n My <i>coat</i> needs a coat in this <#BLUE>Cold</>!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].8
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].8"
msgid "!happy\n !think\n This place used to be a granite quarry, back in the day. It supplied the whole <#BLUE>Rotwood</> with stone to build our homes.\n !gesture\n Maybe when this is all over, we'll be able to get it up and running again. We'll have a lot of rebuilding to do, after all."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].9
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_sedament_tundra,role_scout]NOT[in_town].9"
msgid "!happy\n !shrug\n Whew! Sorry for the bumpy flight, Hunter. I had to shake off a particularly territorial flock of crows on the way over."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].1"
msgid "!neutral\n !gesture\n You know, this scarf was my <#BLUE>Grandpa's</>. \n !think\n I wonder if he'll recognize it... Or me..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].2"
msgid "!neutral\n !point\n I'll be ready to pull you out, even in there. \n !nervous\n I've flown <#RED>{name.i_damselfly}</> in tighter spaces, sure!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].3"
msgid "!neutral\n !think\n I've been inside the lab, but it was well over 10 years ago...\n !closedeyes\n I was little. I'm sure it's changed. Like everything."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].4"
msgid "!neutral\n !think\n <#KONJUR>Primeval Teffra</>--what is it, even?\n !disagree\n And could <i>anything</> be worth all this suffering?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].5"
msgid "!neutral\n !cough\n Ah-ah-AH-AH---Oh. I think it's gone--\n !shocked\n -<i>CHOOO!!</>\n !nervous\n Ow. That one kind of <i>hurt</> ..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_entrance]NOT[has_killed_tefframech,in_town].6"
msgid "!neutral\n !gruffnod\n I'm ready to face him. \n !nervous\n I'll <i>be</> ready once we face him."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].1"
msgid "!neutral\n !gruffnod\n I'm ready. Let's go."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].2"
msgid "!neutral\n !point\n It's time to face <#BLUE>Grandpa</>. Together."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].3"
msgid "!neutral\n !closedeyes\n It's okay Flitt. He loves you. He'll listen to you."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].4"
msgid "!neutral\n !gesture\n All this <#KONJUR>{name.konjur}-a-ah--</>\n !shocked\n --ah-AH-<i>CHOO!</>\n !nervous\n Oh dear. <z 0.7>Do you think he heard that?</>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_tefframech_volcano,role_scout,room_type_hype]NOT[has_killed_tefframech,in_town].5"
msgid "!neutral\n !agree\n <#BLUE>Grandpa's</> a fox of science. He'll listen to reason."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_konjurist,upgradable_powers]NOT[can_get_free_upgrade].1"
msgid "!neutral\n !point\n You look like you could use an <#RED>Upgrade</>.\n !dubious\n ...And a bath. How long have you been wading through swamp muck?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_konjurist]NOT[upgradable_powers].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_konjurist]NOT[upgradable_powers].1"
msgid "!neutral\n !gesture\n Lovely day for a walk through the swamp, huh?\n !dubious\n ...For you, anyway. I'm up to my ears in samples that need labeling."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].1"
msgid "!neutral\n !think\n I didn't think to pack bug spray for this Hunt.\n !happy\n !dubious\n I regret that."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].2"
msgid "!happy\n !think\n Y'know, I think <#BLUE>{name.npc_dojo_master}</> grew up around here actually.\n !shrug\n Maybe I'll find him a neat rock to bring back as a souvenir."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].3"
msgid "!happy\n !point\n Oh hey, remember not to stand in the <#RED>{name.concept_toxic}</>.\n !shrug\n You'd be surprised how many Hunters forget."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].4
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].4"
msgid "!neutral\n !nervous\n Ah geez, I hope I don't get any <#RED>{name.concept_toxic}</> on my watch.\n !dejected\n Why didn't I leave it at camp?"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].5
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].5"
msgid "!happy\n !greet\n Watch your step--unless you like <#RED>{name.concept_toxic}</> between your toes."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].6
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_thatcher_swamp,role_scout]NOT[in_town].6"
msgid "!neutral\n !think\n The bog was always home to a lot of toxic creatures, even before the volcano erupted. But the introduction of <#KONJUR>{name.i_konjur}</> certainly didn't help matters.\n !happy\n !gesture\n Remember, with <#RED>{name.concept_toxic}</> there's only one rule--don't touch it. If something spits at you or leaves a <#RED>{name.concept_toxic}</> trail, don't stand around in it.\n !happy\n !shrug\n Unless you're looking to do some industrial-strength exfoliation."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_treemon_forest,role_travelling_salesman].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,location_treemon_forest,role_travelling_salesman].1"
msgid "!happy\n !gesture\n This here tonic is made from the finest, freshest ingredientsss east of the <#RED>{name.treemon}</>.\n !shocked\n Don't misss out!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,needs_potion,role_travelling_salesman]NOT[can_craft_potion].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,needs_potion,role_travelling_salesman]NOT[can_craft_potion].1"
msgid "agent:\n !happy\n !shocked\n Oh my, your pocketsss seem lighter than usual today.\n !neutral\n !dejected\n As the single father of four plucky eruption orphansss, I'm afraid I simply can't give my <#RED>Potions</> away for free.\n !scared\n A little <#KONJUR>{name.i_konjur}</> is all I ask. It's for their college fundsss.\n !happy\n !gesture\n I'm sure you understand."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,needs_potion,role_travelling_salesman]NOT[can_craft_potion].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,needs_potion,role_travelling_salesman]NOT[can_craft_potion].2"
