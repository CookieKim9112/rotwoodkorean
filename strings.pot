msgid "agent:\n !happy\n !greet\n <z 0.8>Quooooo-EEE!</z>\n !neutral\n !dubious\n <z 0.8>...<i>Squet</i>.</z>"
msgstr ""

#: Quest.dgn_thirdmeeting_potion.QUIP.chitchat:[cant_craft_potion,in_quest_dgn_thirdmeeting_potion,never_bought_potion,role_travelling_salesman,seen_third_time].1
msgctxt "Quest.dgn_thirdmeeting_potion.QUIP.chitchat:[cant_craft_potion,in_quest_dgn_thirdmeeting_potion,never_bought_potion,role_travelling_salesman,seen_third_time].1"
msgid "agent:\n !dubious\n (sniff sniff)...\n !dejected\n Kid. We gotta stop meeting like this."
msgstr ""

#: Quest.dgn_understand_nimble_market.QUIP.chitchat:[in_quest_dgn_understand_nimble_market,qc_dgn_firstmeeting_market,qc_dgn_firstmeeting_market_magpie,role_market_merchant].1
