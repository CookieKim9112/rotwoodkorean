#: Quest.dgn_seen_missing_friends_potion.QUIP.chitchat:[can_craft_potion,chitchat,in_quest_dgn_seen_missing_friends_potion,location_treemon_forest,role_travelling_salesman,seen_first_time].1
msgctxt "Quest.dgn_seen_missing_friends_potion.QUIP.chitchat:[can_craft_potion,chitchat,in_quest_dgn_seen_missing_friends_potion,location_treemon_forest,role_travelling_salesman,seen_first_time].1"
msgid "agent:\n !happy\n !shocked\n You're back!\n !dubious\n Can't resist the call of these fine <#RED>Potions</>, can you?"
msgstr ""

#: Quest.dgn_shop_potion.OPT_ASK_CURSE
msgctxt "Quest.dgn_shop_potion.OPT_ASK_CURSE"
msgid "<#RED>[TEMP]</> Your free sample smells weird..."
msgstr ""

#: Quest.dgn_shop_potion.OPT_CONFIRM
msgctxt "Quest.dgn_shop_potion.OPT_CONFIRM"
msgid "<#RED>[<p img='images/hud_images/hud_konjur_drops_currency.tex'> {konjur_cost} {name.konjur}]</> Take my {name.konjur}!\n<i><#RED><z 0.7>(Refill All Potion Charges)</></i></z>"
msgstr ""

#: Quest.dgn_shop_potion.OPT_REMOVE_CURSE
msgctxt "Quest.dgn_shop_potion.OPT_REMOVE_CURSE"
msgid "<#RED>[<p img='images/hud_images/hud_konjur_drops_currency.tex'> {konjur_cost} {name.konjur}]</><#RED>[TEMP]</> Sure, yes please! <i><#RED><z 0.7>(Clean \"Free\" Sample)</></i></z>"
msgstr ""

#: Quest.dgn_shop_potion.OPT_REMOVE_CURSE_CANCEL
msgctxt "Quest.dgn_shop_potion.OPT_REMOVE_CURSE_CANCEL"
msgid "<#RED>[TEMP]</> I'll pass for now..."
msgstr ""

#: Quest.dgn_shop_potion.OPT_TALK_CURSE
msgctxt "Quest.dgn_shop_potion.OPT_TALK_CURSE"
msgid "agent:\n !shrug\n <#RED>[TEMP]</> Ssseems fine. I can fix it for a little {name.konjur} if you want..."
msgstr ""

#: Quest.dgn_shop_potion.TALK_DONE_GAME
msgctxt "Quest.dgn_shop_potion.TALK_DONE_GAME"
msgid "agent:\n !greet\n Pleasssure doing business with you."
msgstr ""

#: Quest.dgn_succeed_first_time_magpie.QUIP.chitchat:[any_frenzy,chitchat,first_market_challenge_success,in_quest_dgn_succeed_first_time_magpie,role_market_magpie,room_type_market]NOT[first_market_challenge_fail,market_challenge_fail,room_type_entrance].1
msgctxt "Quest.dgn_succeed_first_time_magpie.QUIP.chitchat:[any_frenzy,chitchat,first_market_challenge_success,in_quest_dgn_succeed_first_time_magpie,role_market_magpie,room_type_market]NOT[first_market_challenge_fail,market_challenge_fail,room_type_entrance].1"
msgid "agent:\n !happy\n !greet\n <z 0.8>Quooooo-EEE!</z>\n !laugh\n <z 0.8><i>Caa-caa-caa-ca--</i></z>\n !dubious\n <z 0.8>...Chorp?</z>\n !shocked\n <z 0.8>Squet!</z>"
msgstr ""

#: Quest.dgn_succeed_generic_magpie.QUIP.chitchat:[any_frenzy,in_quest_dgn_succeed_generic_magpie,market_challenge_success,role_market_magpie,room_type_market]NOT[first_market_challenge_fail,first_market_challenge_success,market_challenge_fail,room_type_entrance].1
