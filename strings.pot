msgstr ""

#: Convo.dgn_seen_missing_friends_blacksmith_market.HUB0.convo.giver.STATE_0.QUESTION_1A
msgctxt "Convo.dgn_seen_missing_friends_blacksmith_market.HUB0.convo.giver.STATE_0.QUESTION_1A"
