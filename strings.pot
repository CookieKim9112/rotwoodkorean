msgid "!neutral [keep-for-room]\n !dejected\n The <#BLUE>City Center</> used to be so full of life.\n !point\n Now it's so full of <#RED>{name.rot}</>!\n !gruffnod\n Let's do something about that, Hunter."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_grimhollow_volcano_r2,role_scout]NOT[has_killed_grimhollow,in_town].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_grimhollow_volcano_r2,role_scout]NOT[has_killed_grimhollow,in_town].2"
msgid "!neutral [keep-for-room]\n !notebook\n The <#KONJUR>{name.konjur} Pipeline Energy Grid</> still works here.\n !think\n Maybe because it's close to the <#BLUE>Volcano</>? Hmm..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[has_killed_owlitzer,in_town].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_owlitzer_forest,role_scout]NOT[has_killed_owlitzer,in_town].1"
