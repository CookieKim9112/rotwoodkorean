msgstr ""

#: Convo.dgn_seen_missing_friends_blacksmith_market.HUB0.convo.giver.STATE_0.ANSWER_2B
msgctxt "Convo.dgn_seen_missing_friends_blacksmith_market.HUB0.convo.giver.STATE_0.ANSWER_2B"
