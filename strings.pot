msgctxt "Quest.dgn_seen_missing_friends_armorsmith_powerupgrade.QUIP.chitchat:[in_quest_dgn_seen_missing_friends_armorsmith_powerupgrade,role_konjurist,treemon_region]NOT[wf_town_has_armorsmith].1"
