msgid "!happy\n !point\n There's something sparkling deep into this cavern.\n !happy\n !angry\n Let's get cracking, Hunter!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_grimhollow_volcano,role_scout]NOT[has_killed_grimhollow,in_town].1
