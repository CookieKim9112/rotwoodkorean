#: Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_1A
msgctxt "Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_1A"
msgid "agent:\n !neutral\n !shocked\n \"And whatever.\" Feh!\n !gesture\n I'll have you know I maketh my pieces from <i>locally</>-sourced monsters, and this locale is home to some particularly robust <#RED>{name_multiple.rot}</>.\n !happy\n !point\n Why, I had to develop an entirely new forging technique to work their materials--and the result? \n !wink\n Only the most <i>majestically</> powerful gear thou hast ever laid eyes on. Very avant-garde--\"and whatever\"--hm?"
msgstr ""

#: Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_1B
msgctxt "Convo.dgn_new_biome_meeting_market.HUB0.convo.giver.STATE_0.ANSWER_1B"
msgid "agent:\n !neutral\n !shocked\n <i>(*sputter*)</> My <i>\"bangs\"?!</>\n !angry\n First of all, I doth not have <i>\"bangs\"</>, I hath a... a <i>cascade</> of silky locks that crasheth roguishly upon mine chiseled visage.\n !eyeroll\n Second, I was talking about my new works of art. <i>Obviously.</>"
msgstr ""

