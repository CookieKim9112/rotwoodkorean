msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman].2"
msgid "!happy\n !gesture\n Thanks for stopping by the finest little caravan this ssside of the volcano!\n !point\n Be sure to tell your friendsss... <z 0.7>(with money.)</z>"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman].3
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman].3"
msgid "!happy\n !greet\n {name.npc_doc_lastname}-brand <#RED>Health {name.potion}s</>!\n !shocked\n Restore your mojo on the go-go!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman]NOT[run_has_five_finger_brew].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman]NOT[run_has_five_finger_brew].1"
msgid "!neutral\n !dubious\n Those nasssty Rots have been getting into my <#RED>Potion</> supply. I'm sure of it.\n !point\n But don't fret-- now I'm storing my brew somewhere safe from their ssssticky fingers.\n !happy\n !gesture\n Got to make sure there's plenty for honest, hard-working Hunters like yourself to buy!"
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman]NOT[run_has_five_finger_brew].2
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[in_quest_chat_fluff_fallback,role_travelling_salesman]NOT[run_has_five_finger_brew].2"
