#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.POTIONS
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.POTIONS"
msgid "agent:\n !neutral\n !point\n You can drink <#RED>Potions</> with <p bind='Controls.Digital.USE_POTION' color=BTNICON_DARK> to restore a good chunk of yer <#RED>Health</>.\n !agree\n <#BLUE>{name.npc_scout}</> will make sure your <#RED>Potion</> bottle's full when you start a Hunt, but use it sparingly.\n !dubious\n It's better to master <#RED>Dodging</> than it is to count on refills. {name.dojo_cough}"
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.POTIONS_BTN
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.POTIONS_BTN"
