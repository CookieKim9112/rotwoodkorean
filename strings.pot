msgctxt "Quest.dgn_firstmeeting_potion.QUIP.chitchat:[in_quest_dgn_firstmeeting_potion,never_bought_potion,role_travelling_salesman,seen_first_time].1"
msgid "agent:\n !shocked\n Goodness <i>graciousss!</i> Is that a cussstomer I see?\n !greet\n Greetings and sssalutations, my fine <#BLUE>{player.species}</> friend! Welcome to the <#RED>{name.rotwood}</>!\n !point\n <i>Boy howdy</i>, have I ever got a business proposition for YOU!"
msgstr ""

#: Quest.dgn_firstmeeting_powerupgrade.QUIP.chitchat:[in_quest_dgn_firstmeeting_powerupgrade,role_konjurist,seen_first_time].1
msgctxt "Quest.dgn_firstmeeting_powerupgrade.QUIP.chitchat:[in_quest_dgn_firstmeeting_powerupgrade,role_konjurist,seen_first_time].1"
msgid "agent:\n !notebook\n <i>Woah!</i> What the heck is with these readings--?\n !shocked\n You! You're making my equipment go nuts!\n !point\n Who are you?"
msgstr ""

#: Quest.dgn_freezing_temp_powerupgrade.QUIP.chitchat:[in_quest_dgn_freezing_temp_powerupgrade,location_sedament_tundra,qc_dgn_firstmeeting_konjurist,role_konjurist].1
msgctxt "Quest.dgn_freezing_temp_powerupgrade.QUIP.chitchat:[in_quest_dgn_freezing_temp_powerupgrade,location_sedament_tundra,qc_dgn_firstmeeting_konjurist,role_konjurist].1"
msgid "agent:\n !neutral\n !notebook\n Isn't it interesting that <#KONJUR>{name.konjur}</> doesn't freeze in these sub-zero temperatures?\n !think\n I should do some lab-controlled experiments to see what conditions it becomes a solid under."
msgstr ""

#: Quest.dgn_frenzy_price_increase_potion.QUIP.chitchat:[any_super_frenzy,in_quest_dgn_frenzy_price_increase_potion,increased_potion_refill_price,needs_potion,role_travelling_salesman].1
msgctxt "Quest.dgn_frenzy_price_increase_potion.QUIP.chitchat:[any_super_frenzy,in_quest_dgn_frenzy_price_increase_potion,increased_potion_refill_price,needs_potion,role_travelling_salesman].1"
msgid "agent:\n !neutral\n !dubious\n That pallor, the dilation of the pupils...\n !agree\n I know a case of sssticker-shock when I see it."
msgstr ""

#: Quest.dgn_grove_potion.QUIP.chitchat:[in_quest_dgn_grove_potion,location_owlitzer_forest,role_travelling_salesman].1
msgctxt "Quest.dgn_grove_potion.QUIP.chitchat:[in_quest_dgn_grove_potion,location_owlitzer_forest,role_travelling_salesman].1"
msgid "!happy\n !shocked\n Restore your mojo on the go-go!\n !greet\n {name.npc_doc_lastname}-brand <#RED>Health {name.potion}s</>!"
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.OPT_1
msgctxt "Quest.dgn_intro_meeting_apothecary.OPT_1"
msgid "I'm a Hunter. Doing Hunter things. You?"
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.OPT_2
msgctxt "Quest.dgn_intro_meeting_apothecary.OPT_2"
msgid "Okaaaay. Y'know, we have a camp. It's safe there--if you wanted to join us."
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.OPT_3
msgctxt "Quest.dgn_intro_meeting_apothecary.OPT_3"
msgid "Oh. Are you sure?"
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.TALK
msgctxt "Quest.dgn_intro_meeting_apothecary.TALK"
msgid "agent:\n !neutral\n !dubious\n {name.apothecary_sniff}\n !point\n I don't know you. What are <i>you</> doing here?"
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.TALK2
msgctxt "Quest.dgn_intro_meeting_apothecary.TALK2"
msgid "agent:\n !neutral\n !shrug\n I'm a me. Doing me things."
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.TALK3
msgctxt "Quest.dgn_intro_meeting_apothecary.TALK3"
msgid "agent:\n !neutral\n !shocked\n 'Camp'. With... <i>people?</>\n !disagree\n Um... NO."
msgstr ""

#: Quest.dgn_intro_meeting_apothecary.TALK4
msgctxt "Quest.dgn_intro_meeting_apothecary.TALK4"
msgid "agent:\n !neutral [keep-for-room]\n !closedeyes\n ...\n !eyeroll\n ... \n !notebook\n ...\n [title:SPEAKER]\n [sound:Event.joinedTheParty] 0.5\n !shrug\n ... okay.\n !gesture\n ... bye.\n [title:CLEAR]"
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.OPT_1
msgctxt "Quest.dgn_intro_meeting_armorsmith.OPT_1"
msgid "Yep! Well, apart from how worried they were about you."
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.OPT_2A
msgctxt "Quest.dgn_intro_meeting_armorsmith.OPT_2A"
msgid "Woah! Really?"
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.OPT_2B
msgctxt "Quest.dgn_intro_meeting_armorsmith.OPT_2B"
msgid "That's... a little hard to believe."
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.OPT_3
msgctxt "Quest.dgn_intro_meeting_armorsmith.OPT_3"
msgid "I'm just relieved to have our resilient {name.job_armorsmith} back!"
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.TALK
msgctxt "Quest.dgn_intro_meeting_armorsmith.TALK"
msgid "agent:\n !happy\n !greet\n Hunter!! You're okay-- wait. Where's your cloak?\n player:\n {name.npc_armorsmith}! My cloak? Um, I think it's in the {name.damselfly}.\n agent:\n !happy\n !bliss\n Phew! I was really worried! Such a nice piece. Brown. Plain. <i>Really</> shadowy hood. *Chef's kiss.*\n !neutral\n !dubious\n Oh! Speaking of the <#RED>{name.i_damselfly}</>-- how's <#BLUE>{name.npc_scout}</>? Are they okay??"
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.TALK2
msgctxt "Quest.dgn_intro_meeting_armorsmith.TALK2"
msgid "agent:\n !happy\n !gesture\n Aw, they're so sweet-- but they didn't have to worry.\n !point\n I arm-wrestled a <#RED>{name.zucco}</> once, so..."
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.TALK3
msgctxt "Quest.dgn_intro_meeting_armorsmith.TALK3"
msgid "agent:\n !neutral\n !think\n Y'know... come to think of it, I might've read that in a diary I found.\n !happy\n !shrug\n The point is, I'm resilient. (And good at finding diaries.)"
msgstr ""

#: Quest.dgn_intro_meeting_armorsmith.TALK4
msgctxt "Quest.dgn_intro_meeting_armorsmith.TALK4"
msgid "agent:\n [title:SPEAKER]\n [sound:Event.joinedTheParty] 0.5\n !happy\n !clap\n And <i>I'll</> be relieved to get to camp and work on that armour of yours!\n !dubious\n I mean, no offense, but <i>WOOF</>...\n [title:CLEAR]"
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.OPT_1A
msgctxt "Quest.dgn_intro_meeting_blacksmith.OPT_1A"
msgid "Maybe you don't recognize me without my cool brown cloak?"
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.OPT_1B
msgctxt "Quest.dgn_intro_meeting_blacksmith.OPT_1B"
msgid "Just call me 'They Who Saved My Life'."
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.OPT_2A
msgctxt "Quest.dgn_intro_meeting_blacksmith.OPT_2A"
msgid "I <i>knew</> you'd remember me!"
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.OPT_2B
msgctxt "Quest.dgn_intro_meeting_blacksmith.OPT_2B"
msgid "That...doesn't <i>sound</> like me... You must be thinking of... you..."
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.OPT_3
msgctxt "Quest.dgn_intro_meeting_blacksmith.OPT_3"
msgid "Err, <i>anyway--</> {name.npc_scout}'s waiting above to take you back to camp."
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.TALK
msgctxt "Quest.dgn_intro_meeting_blacksmith.TALK"
msgid "agent:\n !neutral\n !point\n Och, yer an ugly lil' <#RED>{name.rot}</>, aren't ye? Well c'mon, then! I'll peel ye like a grape!\n player:\n Nonono, {name.npc_blacksmith}! It's me! The Hunter! From the {name.i_damselfly}!\n agent:\n !dubious\n ... Who?"
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.TALK2
msgctxt "Quest.dgn_intro_meeting_blacksmith.TALK2"
msgid "agent:\n !happy\n !think\n Ah. I remember ye now.\n !neutral\n !point\n Screamin' an' cryin' as our whirlybird took a nose dive."
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.TALK3
msgctxt "Quest.dgn_intro_meeting_blacksmith.TALK3"
msgid "agent:\n !agree\n Like a wee bairn, wailin' for yer ba-ba, ye were."
msgstr ""

#: Quest.dgn_intro_meeting_blacksmith.TALK4
msgctxt "Quest.dgn_intro_meeting_blacksmith.TALK4"
msgid "agent:\n [title:SPEAKER]\n [sound:Event.joinedTheParty] 0.5\n !neutral\n !gruffnod\n Hrm. Best pack me things.|...Done.\n [title:CLEAR]"
msgstr ""

#: Quest.dgn_intro_meeting_cook.OPT_1
msgctxt "Quest.dgn_intro_meeting_cook.OPT_1"
msgid "That's terrible! Nice spatula, there. Any chance you're a {name.job_cook}?"
msgstr ""

#: Quest.dgn_intro_meeting_cook.OPT_2
msgctxt "Quest.dgn_intro_meeting_cook.OPT_2"
msgid "Wait--we don't have a {name.job_cook}. Would you want to join our camp?"
msgstr ""

#: Quest.dgn_intro_meeting_cook.TALK
msgctxt "Quest.dgn_intro_meeting_cook.TALK"
msgid "agent:\n !neutral\n !nervous\n Woe is me! Woe Woe W-Oh! Is that a st-st-stranger I see?? \n !scared\n Shoot straight with me: y'ain't h-h-here ta steal my meagre belongin's and leave me fer dead, are ya?\n player:\n What? No, of course not. I'm a Hunter. I'm here searching for an Old Fox.   \n agent:\n !happy\n !laugh\n Well c-c-count my lucky stars! The name's <#BLUE>{name.npc_cook}</>. \n !gesture\n Just a poor old gal, lost and freezin' her dern buns off out here, alone 'n' defenseless-like..."
msgstr ""

#: Quest.dgn_intro_meeting_cook.TALK2
msgctxt "Quest.dgn_intro_meeting_cook.TALK2"
msgid "agent:\n !neutral\n !dubious\n Nice spat-u-what-now? \n !shocked\n M-my back scratcher? Er, I'm just kiddin'! O'course cookin' is what I use it for! All the time I do that. With this! 'Course!\n !point\n Oh, but I don't suppose an outfit like yours has any m-m-mouths what need feedin'. \n !dejected\n What a shame. I'm good too. At cookin'. Welp! Guess I'll just curl up and die, now..."
msgstr ""

#: Quest.dgn_intro_meeting_cook.TALK3
msgctxt "Quest.dgn_intro_meeting_cook.TALK3"
msgid "agent:\n !happy\n !clap\n Really? Truly? Oh, I'd cry happy tears if'n they wouldn't instantly freeze and turn into deadly projectiles! \n [title:SPEAKER]\n [sound:Event.joinedTheParty] 0.5\n !bliss\n <i>Hoo-whee!</> See you at camp, ya kind soul! Kindest in the land!\n !shrug\n Oh, and I ain't seen no <#BLUE>Old Fox</> 'round here. Sorry!\n [title:CLEAR]"
msgstr ""

#: Quest.dgn_intro_meeting_refiner.ANSWER_CHICKENS
msgctxt "Quest.dgn_intro_meeting_refiner.ANSWER_CHICKENS"
msgid "agent:\n !angry\n ...\n !dejected\n ... <i>(sigh)</> You're right. <z 0.7>Dang it. Can't a gal just quiet quit anymore?</>\n !think\n Well, the Shutdown Panel is <i>in</> the lab, which is locked. You'll need a <#RED>Key</>.\n !shrug\n Of course <#RED>Grimhollow</> smashed mine and fed each of the <#RED>Three Key Fragments</> to random <#RED>Frenzy Bosses</>, so...\n flitt:\n !neutral\n !point\n If you're right--IF--then we'll just go fight <#RED>Frenzy Bosses</> until we find those <#RED>Key Fragments</>.\n agent:\n !laugh\n HAH! Okay, kid! \"Just\" like taking candy from <i>super-violent</> babies that already ate the candy! He he he.\n ...\n [title:SPEAKER]\n [sound:Event.joinedTheParty] 0.5\n !laugh\n You're serious! HAH! You guys are wild. Alright, I'm in. \n !gesture\n Also, is this <#BLUE>{name.town}</> an anarcho-collectivist type situation or--y'know what? I'll figure it out.\n [title:CLEAR]"
msgstr ""

#: Quest.dgn_intro_meeting_refiner.QUESTION_CHICKENS
msgctxt "Quest.dgn_intro_meeting_refiner.QUESTION_CHICKENS"
msgid "Run?? Run where? A blast that size will destroy everything--even The Brinks!"
msgstr ""

#: Quest.dgn_intro_meeting_refiner.TALK
msgctxt "Quest.dgn_intro_meeting_refiner.TALK"
msgid "agent:\n !happy\n !point\n Thanks for the rescue--aaand the weird looks?\n player:\n Um, we thought we were rescuing {name.npc_grandpa} {name.flitt_lastname}. Who are you?\n agent:\n !greet\n <#BLUE>{name.npc_refiner}</>, <#KONJUR>{name.job_konjurist}</>. I work--<i>used</> to work for <#BLUE>Doc {name.flitt_lastname}</>. \n flitt:\n !happy\n !clap\n Oh! Please! You must let us into his lab! We need my <#BLUE>Grandpa</> to save us--\n agent:\n !neutral\n !point\n \"Save us\"?? Uh, have you felt those quakes lately? \n !gruffnod\n Well <#BLUE>Doc's</> got all his mining gear maxed out--\n !shocked\n He's trying trigger a <#KONJUR>SECOND ERUPTION</> of this stuff called <#KONJUR>Primeval {name.konjur}</>!\n flitt:\n !neutral\n !shocked\n Wh-what?? No... He wouldn't... Y-you must be mistaken! \n agent:\n !point\n I thought so too, so I stole his <#RED>Diary</>. <#RED>Take it.</> It's missing a few <#RED>Pages</> but it paints the picture.  \n !scared\n This'll be TRIPLE the size of the first eruption. I have to go find my dad and RUN. You better do the same."
msgstr ""

#: Quest.dgn_mask_powerupgrade.QUIP.chitchat:[chitchat,in_quest_dgn_mask_powerupgrade,qc_dgn_firstmeeting_konjurist,role_konjurist].1
msgctxt "Quest.dgn_mask_powerupgrade.QUIP.chitchat:[chitchat,in_quest_dgn_mask_powerupgrade,qc_dgn_firstmeeting_konjurist,role_konjurist].1"
msgid "agent:\n !neutral\n !notebook\n Hm?\n !dubious\n Oh. Hey Hunter."
msgstr ""

#: Quest.dgn_new_biome_meeting_market.QUIP.chitchat:[chitchat,in_quest_dgn_new_biome_meeting_market,qc_dgn_firstmeeting_market,role_market_merchant]NOT[seen_first_time,treemon_region].1
msgctxt "Quest.dgn_new_biome_meeting_market.QUIP.chitchat:[chitchat,in_quest_dgn_new_biome_meeting_market,qc_dgn_firstmeeting_market,role_market_merchant]NOT[seen_first_time,treemon_region].1"
msgid "agent:\n !happy\n !smirk\n Welcome back, culver.\n !gesture\n Dost thou notice anything different?"
msgstr ""

#: Quest.dgn_no_custom_orders_market.QUIP.chitchat:[chitchat,in_quest_dgn_no_custom_orders_market,qc_dgn_firstmeeting_market,role_market_merchant].1
msgctxt "Quest.dgn_no_custom_orders_market.QUIP.chitchat:[chitchat,in_quest_dgn_no_custom_orders_market,qc_dgn_firstmeeting_market,role_market_merchant].1"
msgid "agent:\n !neutral\n !dubious\n Something on your mind, culver?"
msgstr ""

#: Quest.dgn_sdmnt_blizzard_scout.QUIP.chitchat:[in_quest_dgn_sdmnt_blizzard_scout,location_sedament_tundra_r2,role_scout]NOT[has_killed_sedament,in_town].1
msgctxt "Quest.dgn_sdmnt_blizzard_scout.QUIP.chitchat:[in_quest_dgn_sdmnt_blizzard_scout,location_sedament_tundra_r2,role_scout]NOT[has_killed_sedament,in_town].1"
msgid "agent:\n !happy\n !gesture\n W-welcome to <#BLUE>{name.sedament_tundra_r2}</>! I sure h-hope you're wearing your l-l-long underwear under that ar-ar-armour.\n player:\n Brr-r-r... This place wins the award for ch-ch-chilliest reception! \n agent:\n !neutral\n !think\n Wh-what's that? I th-think my ears are fr-fr-frozen. The sn-sn-snowy w-winds here will <#RED>Freeze</> y-you solid if you stray too f-far from a heat source.\n !happy\n !gesture\n L-lucky for you, there's a n-network of old <#RED>Braziers</> t-t-to keep workers w-w-warm back when this place was st-still an functional stone qu-quarry.\n !point\n Stick cl-cl-close to those, and you sh-should be cozy enough--th-though you might need to h-h-hack the ice off some to get them b-b-burning again.\n !neutral\n !scared\n I'd b-better hurry back to the <#RED>Damselfly</> before my f-f-fingers get too numb to f-fly it! Stay warm, and find my Grandpa, Hunter!"
msgstr ""

#: Quest.dgn_secondmeeting_potion.QUIP.chitchat:[in_quest_dgn_secondmeeting_potion,never_bought_potion,role_travelling_salesman,seen_second_time].1
msgctxt "Quest.dgn_secondmeeting_potion.QUIP.chitchat:[in_quest_dgn_secondmeeting_potion,never_bought_potion,role_travelling_salesman,seen_second_time].1"
msgid "agent:\n !shocked\n Ah, my friend! You've returned!"
msgstr ""

#: Quest.dgn_seen_missing_friends_armorsmith_market.QUIP.chitchat:[in_quest_dgn_seen_missing_friends_armorsmith_market,role_market_merchant,treemon_region]NOT[wf_town_has_armorsmith].1
