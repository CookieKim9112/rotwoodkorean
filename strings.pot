msgstr ""

#: Convo.dgn_seen_missing_friends_armorsmith_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2
msgctxt "Convo.dgn_seen_missing_friends_armorsmith_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2"
msgid "agent:\n !disagree\n I'd be quick about finding them if I were you...\n !gesture\n They're gonna run right into the <#RED>{name.megatreemon}</> if they keep heading that way."
msgstr ""

#: Convo.dgn_seen_missing_friends_armorsmith_powerupgrade.HUB0.convo.giver.STATE_0.QUESTION_1A
msgctxt "Convo.dgn_seen_missing_friends_armorsmith_powerupgrade.HUB0.convo.giver.STATE_0.QUESTION_1A"
msgid "I'm looking for my missing crew-- have you seen anyone else out here?"
