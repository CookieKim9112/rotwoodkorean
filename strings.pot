#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.LUCK_STAT
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.LUCK_STAT"
msgid "agent:\n !happy\n !gesture\n Ah yeah, <#RED>Luck's</> an unusual stat. 'Affects a little bit of everything.\n !point\n It can boost yer chances of getting rarer <#RED>{name_multiple.concept_relic}</>, getting extra loot from <#RED>{name_multiple.rot}</>, double <#RED>Healing</>, or even <#RED>Reviving</> when you should get knocked out.\n !think\n Might even have other effects I don't know 'bout. {name.dojo_cough}"
msgstr ""

#: Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.LUCK_STAT_BTN
msgctxt "Quest.twn_repeatable_tutorials_dojo.TUTORIALS.EQUIPMENT.LUCK_STAT_BTN"
