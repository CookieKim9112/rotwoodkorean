msgid "!neutral\n !dubious\n That <#RED>{name.weapon_crystal}</> needs to be <#RED>Charged</> before I can finish it.\n !gesture\n Killin' a <#RED>{name.elite_prefix} {name.rot_boss}</> with it'll do the trick."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[drunken,in_quest_chat_fluff_fallback,role_travelling_salesman].1
msgctxt "Quest.chat_fluff_fallback.QUIP.chitchat:[drunken,in_quest_chat_fluff_fallback,role_travelling_salesman].1"
msgid "!neutral\n !think\n [TEMP] I might have a cure for your affliction..."
msgstr ""

