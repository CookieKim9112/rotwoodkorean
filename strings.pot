msgid ""
msgstr ""
"Application: Rotwood\n"
"POT Version: 2.0\n"

#: Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.ANSWER_BOOKCLUB
msgctxt "Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.ANSWER_BOOKCLUB"
msgid "agent:	\n !neutral [keep-for-room]\n !gruffnod\n You're right--let's get to <#BLUE>{name.tefframech_volcano}</>, and face <#BLUE>Grandpa</>!"
msgstr ""

#: Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.ANSWER_OHAND
msgctxt "Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.ANSWER_OHAND"
msgid "agent:\n !gesture\n After the <#KONJUR>Eruption</>, the writing is replaced by strange drawings of triangles and winged snakes... Until this, his final entry:\n !diary_start\n {name.grandpa_quote} \"They tried to stop me, but I HAD to trigger the <#KONJUR>Eruption</>! It was the only way to tap into the <#KONJUR>Primeval Source of {name.konjur}</>...\"\n player:\n Your Grandpa... <i>triggered</> the Eruption??\n agent:\n Y-yes... He goes on: {name.grandpa_quote} \"The power hidden in <#KONJUR>Primeval {name.konjur}'s</> dark, glittering crystals drove <#BLUE>{name.npc_refiner}'s</> father mad--but not I.\"\n {name.grandpa_quote} \"For I understand that <#KONJUR>Primeval {name.konjur}</> is pure potential! Chaotic creation! As such, there's no problem it can't solve!\"\n {name.grandpa_quote} \"With it, we can purge ALL our impurities, all our vulnerabilities, all our mistakes! You will be CURED, <#BLUE>{name.npc_scout}</>!\"\n {name.grandpa_quote} \"But everything ages, decays, and passes, you argue? It's part of the fabric of our world, you plead? It's what gives life meaning, you acquiesce?\"\n {name.grandpa_quote} \"Acquiesce no longer, we say. We will fix everything, <#BLUE>{name.npc_scout}</>. We will be perfect. We promise.\"\n player:\n Oh {name.npc_scout}, that's... Wait--what did he mean, \"we\"??\n agent:\n !neutral [keep-for-room]\n !think\n I... I don't know...\n !gesture\n But maybe I can get through to him, if we reach him in time...\n !point\n Let's get to <#BLUE>{name.tefframech_volcano}</> and use those <#RED>Key Fragments</>."
msgstr ""

#: Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.QUESTION_BOOKCLUB
msgctxt "Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.QUESTION_BOOKCLUB"
msgid "Let's book club later, stop Second Eruption now."
msgstr ""

#: Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.QUESTION_OHAND
msgctxt "Convo.after_find_all_keys_scout.HUB0.convo.giver.STATE_0.QUESTION_OHAND"
msgid "Oh? And?"
msgstr ""

#: Convo.after_find_first_key_dojo.HUB0.convo.giver.STATE_0.ANSWER_HAMISH_GOSSIP
msgctxt "Convo.after_find_first_key_dojo.HUB0.convo.giver.STATE_0.ANSWER_HAMISH_GOSSIP"
msgid "agent:\n !think\n Hm. I suspected as much. \n player:\n What?? <i>All</> of that?\n agent:\n !gesture\n In my old Huntin' days, I noticed <#RED>{name.rot}</> hot spots were always near damaged <#KONJUR>{name.i_town_grid_cryst}</> pipes. \n !shrug\n <#BLUE>{name.flitt_lastname}</> denied leaks, said some <#RED>{name.rot}</> must've damaged them. But I know <#RED>{name.rot}</> marks when I see 'em. \n player:\n And {name.npc_blacksmith}? How did you know he was involved?\n agent:\n !gesture\n The moment he laid eyes on that busted old <#KONJUR>{name.i_town_grid_cryst}</> that <#BLUE>{name.npc_scout}</> has scavenged in <#BLUE>The Brinks</>, it was like he saw a ghost.\n !gruffnod\n Also... I could tell <#BLUE>{name.npc_blacksmith}</> swung his hammer with a heavy heart. Each strike tryin' to put right the last. \n !closedeyes\n Figured he'd joined the <#RED>{name_multiple.foxtails}</> for related reasons. Now I know the reasons.\n player:\n Y'know, for an old guy with one eye, you sure see a lot.\n agent:\n !laugh\n HAH. And I'll see <i>you</> doin' 50 wind sprints tomorrow at dawn, kid. \n player:\n Dang it."
msgstr ""

#: Convo.after_find_first_key_dojo.HUB0.convo.giver.STATE_0.QUESTION_HAMISH_GOSSIP
msgctxt "Convo.after_find_first_key_dojo.HUB0.convo.giver.STATE_0.QUESTION_HAMISH_GOSSIP"
msgid "{name.npc_blacksmith} smithied the {name.town_grid_cryst}, and leaks <i>caused</> the {name.rot}!"
msgstr ""

#: Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.ANSWER_GOTTAGO
msgctxt "Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.ANSWER_GOTTAGO"
msgid "agent:\n !neutral [keep-for-room]\n !greet\n Understood, Hunter. The <#RED>{name.i_damselfly}</> is ready and waiting."
msgstr ""

#: Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.ANSWER_OFCOURSE
msgctxt "Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.ANSWER_OFCOURSE"
msgid "agent:\n !neutral\n !diary_start\n Well, seems that a smithy who worked on the pipelines reported <#RED>leaks</>.\n Leaks that caused local flora and fauna to mutate and become aggressive...\n player:\n Whoa. The system caused the {name.rot}!\n agent:\n Well, the smithy wanted to shut the whole grid down. But <#BLUE>Grandpa</> covered it up so he could study the <#RED>{name.rot}</> for clues to my illness.\n player:\n Whoa! I wonder if {name.npc_blacksmith} knew the smithy...\n agent:\n !nervous\n I'm sure he did. <#BLUE>{name.npc_blacksmith}</> WAS the smithy! \n player:\n WHOA!\n agent:\n !neutral [keep-for-room]\n !dejected\n I-I had no idea. I feel like I ought to apologize to <#BLUE>{name.npc_blacksmith}</>...\n !think\n Y'know what? Don't worry about it, Hunter. You have enough on your plate. \n !point\n Get after that second <#RED>Key Fragment</>. The <#RED>{name.i_damselfly}</> is ready and waiting."
msgstr ""

#: Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.QUESTION_GOTTAGO
msgctxt "Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.QUESTION_GOTTAGO"
msgid "Fascinating. Listen, I'd better run after Key Fragment number two."
msgstr ""

#: Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.QUESTION_OFCOURSE
msgctxt "Convo.after_find_first_key_scout.HUB0.convo.giver.STATE_0.QUESTION_OFCOURSE"
msgid "Of course. His system really ushered in the {name.konjur} Age."
msgstr ""

#: Convo.after_find_second_key_dojo.HUB0.convo.giver.STATE_0.ANSWER_DIARY
msgctxt "Convo.after_find_second_key_dojo.HUB0.convo.giver.STATE_0.ANSWER_DIARY"
msgid "agent:\n !shrug\n Oh. Yeah. That he tested <#KONJUR>{name.konjur}</> on Hunters knowin' it could make us sick. \n !gesture\n Pfft. Throw it on the pile. \n player:\n Are you joking?? <i>He was testing on you without you knowing!</> He MADE you sick!\n agent:\n !angry\n And how's that any different than him exposin' us ALL to <#KONJUR>{name.konjur}</> after learnin' it makes us sick? \n !point\n We're all in the same leaky boat, kid. All we can do is keep rowin'.\n player:\n ... Not until we've thrown the Captain overboard. \n agent:\n !dubious\n ...\n !happy\n !laugh\n HA HA HA!\n !cough\n <#KONJUR><i><z 0.8>(cough <i>HACK</> cough)</></></> Hm. Seems my trainin's sinkin' in. I'll take one push up off your training regimen.\n player:\n Really?? YES!\n agent:\n !neutral\n !dubious\n Hm. Too eager to slack off. Addin' 20. \n player:\n Dang it."
msgstr ""

#: Convo.after_find_second_key_dojo.HUB0.convo.giver.STATE_0.QUESTION_DIARY
msgctxt "Convo.after_find_second_key_dojo.HUB0.convo.giver.STATE_0.QUESTION_DIARY"
msgid "Didn't you hear? Grandpa's Diary... It said--"
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_BYEBYE
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_BYEBYE"
msgid "agent:\n !neutral [keep-for-room]\n !shrug\n I... I was just kidding. I'm ready to go when you are, Hunter."
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_DIARY
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_DIARY"
msgid "agent:\n !dejected\n I'm about halfway through, now, and the more I read, the less I know my <#BLUE>Grandpa</>. \n !gesture\n Studying the <#RED>{name.rot}</> in secret, he discovered it was impurities in <#KONJUR>{name.konjur}</> causing their mutations.\n !think\n It's those same impurities that cause both powers AND illnesses in <i>people.</> \n !dubious\n Powers like yours. Illnesses like mine."
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_SICK
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_SICK"
msgid "agent:\n !dejected\n Not only that, <#BLUE>Grandpa</> decided to test this on <#RED>Hunters</>...\n player:\n Like {name.npc_dojo_master}!\n agent:\n !diary_start\n {name.grandpa_quote} \"Any powers will benefit their duties, any illnesses will benefit my research to help my dear <#BLUE>{name.npc_scout}</>.\"\n player:\n Whoa. Wait--if the same impurities change us, does that mean... <i>we're</> <#RED>{name.rot}</> too?!\n agent:\n !neutral [keep-for-room]\n !dubious\n Well, n--uh, y--.... This isn't the time for semantics... \n !gruffnod\n Go get the final <#RED>Key Fragment</>, Hunter."
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_STOPHIM
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.ANSWER_STOPHIM"
msgid "agent:\n !neutral [keep-for-room]\n !shocked\n He was obsessed with finding a cure--but I agree. \n !gruffnod\n Go find that last <#RED>Key Fragment</>, Hunter."
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_BYEBYE
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_BYEBYE"
msgid "I wish I could chat, but I'm on a Key Fragment-finding roll!"
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_DIARY
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_DIARY"
msgid "Not exactly light reading, is it?"
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_SICK
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_SICK"
msgid "Wait--so your random 'allergy' was <i>caused</> by his 'brighter new {name.konjur} future'?"
msgstr ""

#: Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_STOPHIM
msgctxt "Convo.after_find_second_key_scout.HUB0.convo.giver.STATE_0.QUESTION_STOPHIM"
msgid "And he let it happen. Let's get the last Key Fragment and stop him."
msgstr ""

#: Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.ANSWER_LETSRIDE_ENDLOOP
msgctxt "Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.ANSWER_LETSRIDE_ENDLOOP"
msgid "agent:\n !happy\n !gruffnod\n I suppose that's true! We're coming, <#BLUE>Grandpa</>!"
msgstr ""

#: Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.ANSWER_PAPER
msgctxt "Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.ANSWER_PAPER"
msgid "agent:\n !neutral\n !dubious\n How odd... wait.\n !shocked\n This... this is a page torn from <#RED>my Grandpa's Diary</>! I'm certain of it. After a decade with his notes, I'd recognize his handwriting anywhere.\n player:\n Can you read it? Is it... \"private\"?\n agent:\n !shocked\n \"Private\"?! Hunter! Heavens, no. Look, this is dated back when I was just a baby! It reads:\n !happy\n !diary_page_start\n {name.grandpa_quote} \"Smithying of <#KONJUR>{name.konjur} Pipeline Energy Grid</> is ahead of schedule. No wonder--smithies are marvelously talented.\"\n {name.grandpa_quote} \"To think! Bringing <#KONJUR>{name.konjur}</> power to every household on the continent! A brighter world for all!\"\n {name.grandpa_quote} \"But especially for my young <#BLUE>{name.npc_scout}</>. They've had such a hard start, so I'll do all in my power to build them a future free from pain--that I vow!\"\n {name.grandpa_quote} \"P.S., How the little one delights in my <#KONJUR>{name.konjur}</> experiments! A brilliant <#KONJUR>{name.job_konjurist}</> in the making!\"\n player:\n That's very sweet, {name.npc_scout}.\n agent:\n !agree\n <i>(sniffle)</> We have to save him, Hunter. Hurry! Let's go!"
msgstr ""

#: Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.ANSWER_SMARTROT
msgctxt "Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.ANSWER_SMARTROT"
msgid "agent:\n !neutral [keep-for-room]\n !think\n I... I hadn't stopped to think about that...\n !nervous\n And to be honest, we'll have to figure that out later!\n !point\n We must focus on the fact that <#RED>Grandpa's</> alive and we need to save him before the <#RED>{name.rot}</> get smart and realize they're dumb and hurt him!\n !nervous\n I-I realize that didn't make any sense b-but it also <i>does?</> \n !point\n Forget all that. We must hurry!"
msgstr ""

#: Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.QUESTION_LETSRIDE_ENDLOOP
msgctxt "Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.QUESTION_LETSRIDE_ENDLOOP"
msgid "Hey, it's dawn o'clock somewhere! We ride now!"
msgstr ""

#: Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.QUESTION_PAPER
msgctxt "Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.QUESTION_PAPER"
msgid "<#RED>[Give {name.npc_scout} the Page]</> Before we go, that {name.rot_boss} dropped this sheet of paper. Can <i>you</> make out the chicken-scratch?"
msgstr ""

#: Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.QUESTION_SMARTROT
msgctxt "Convo.after_insert_heart_5_scout.HUB0.convo.giver.STATE_0.QUESTION_SMARTROT"
msgid "Since when do brainless {name.rot} hatch kidnapping plans that involve multiple locations?"
msgstr ""

#: Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.ANSWER_JOURNAL
msgctxt "Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.ANSWER_JOURNAL"
msgid "agent:\n !happy\n !gesture\n Ooh, let's see here... Dated not long after the last page, when I was still young. It reads:\n !neutral\n !diary_page_start\n {name.grandpa_quote} \"<#BLUE>{name.npc_scout}</> is sick. Their illness is unique--aggravated by proximity to <#KONJUR>{name.konjur}</>...\"\n {name.grandpa_quote} \"I've had to quarantine them in a home away from my lab, out on the edge of the <#BLUE>Capital</>.\"\n !think\n I... I remember that... \n !diary_page_start\n {name.grandpa_quote} \"I tremble to think: Could I have caused <#BLUE>{name.npc_scout}'s</> illness?? Don't dwell. Forward, ever forward. I can fix this. A cure! I MUST find a cure...\"\n {name.grandpa_quote} \"<#BLUE>{name.npc_konjurist}</> has a theory on <#KONJUR>Primeval {name.konjur}</>. It is the source of all <#KONJUR>{name.konjur}</> with 'boundless potential'. It is our only hope.\"\n {name.grandpa_quote} \"<#BLUE>{name.npc_refiner}</> and her father warn against deeper excavations, but if it may cure my grandchild--fix what I have done--then the choice is clear. We dig.\"\n player:\n Y-your Grandpa... he <i>caused</> your illness!\n agent:\n !dubious\n N-not on purpose! He... All we know for certain is my <#BLUE>Grandpa</> was doing all he could to cure me.\n player:\n With some kind of '<#KONJUR>Primeval {name.konjur}</>' with 'unlimited potential'...?	\n agent:\n !neutral [keep-for-room]\n !gruffnod\n Which he might have right now! So, to the <#BLUE>{name.grimhollow_volcano}</>, then!"
msgstr ""

#: Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.ANSWER_SAVEGRANDPA
msgctxt "Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.ANSWER_SAVEGRANDPA"
msgid "agent:\n !neutral [keep-for-room]\n !point\n To <#BLUE>{name.grimhollow_volcano}</>, then! Hold on, <#BLUE>Grandpa</>!"
msgstr ""

#: Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.QUESTION_JOURNAL
msgctxt "Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.QUESTION_JOURNAL"
msgid "<#RED>[Give {name.npc_scout} the Diary Page]</> That {name.rot_boss} dropped another of your Grandpa's Diary Pages."
msgstr ""

#: Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.QUESTION_SAVEGRANDPA
msgctxt "Convo.after_insert_heart_6_scout.HUB0.convo.giver.STATE_0.QUESTION_SAVEGRANDPA"
msgid "Enough jaw-flappin'. Let's go get us a Grandpa."
msgstr ""

#: Convo.after_insert_heart_scout_bnd.HUB0.convo.giver.STATE_0.ANSWER_HUNTER
msgctxt "Convo.after_insert_heart_scout_bnd.HUB0.convo.giver.STATE_0.ANSWER_HUNTER"
msgid "agent:\n !point\n Someone as skilled as <i>you?</> You'll be in high demand, I'm sure of it.\n !neutral\n !think\n Besides, I could always use a test subject.\n player:\n Hey!\n agent:\n !happy\n !laugh\n Oh! The look on your face! Complete lack of expression! Classic.\n !point\n Alright test subject--I mean <i>Hunter</>. How about we go get that last <#KONJUR>{name.i_konjur_heart}</>?"
msgstr ""

#: Convo.after_insert_heart_scout_bnd.HUB0.convo.giver.STATE_0.BYE_GOGOGO
msgctxt "Convo.after_insert_heart_scout_bnd.HUB0.convo.giver.STATE_0.BYE_GOGOGO"
msgid "Let's do it!"
msgstr ""

#: Convo.after_insert_heart_scout_bnd.HUB0.convo.giver.STATE_0.QUESTION_HUNTER
msgctxt "Convo.after_insert_heart_scout_bnd.HUB0.convo.giver.STATE_0.QUESTION_HUNTER"
msgid "I'm in, but what use will a Rot-free world have for a Hunter like me?"
msgstr ""

#: Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_ADDITIONAL_COMMENT
msgctxt "Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_ADDITIONAL_COMMENT"
msgid "agent:\n !neutral\n !nervous\n Oh, but please don't forget, <#BLUE>{name.npc_blacksmith}</> is still lost out there somewhere. Finding him is our top priority, even above the <#KONJUR>{name_multiple.i_konjur_heart}</>.\n !dejected\n I can hardly call myself the leader of the <#RED>{name_multiple.foxtails}</> until my whole team is safe.\n !point\n And not to sound callous but <i>your</> job will be a lot less dangerous with our <#RED>{name.job_blacksmith}</> here improving your weaponry.\n player:\n On it. I'll get him back safe.\n agent:\n !happy\n !gruffnod\n Thanks, Hunter."
msgstr ""

#: Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_BYE
msgctxt "Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_BYE"
msgid "agent:\n !happy\n !agree\n Sounds good, Hunter. Great work!"
msgstr ""

#: Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_THINKIN
msgctxt "Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_THINKIN"
msgid "agent:\n !gesture\n I was just thinking... I wish my Grandpa was here to see this.\n player:\n Wait--your last name's {name.flitt_lastname}! Your Grandpa... he wasn't--?\n agent:\n !happy\n !shrug\n \"<#BLUE>{name.npc_grandpa} {name.flitt_lastname}</>, pioneer of {name.konjur} science and inventor of the <#KONJUR>{name.town_grid_cryst}</> and the <#KONJUR>{name.konjur} Pipeline Energy Grid</>.\" Yep. That's my Grandpa.\n !neutral\n !think\n Sorry. I didn't bring him up to name-drop. Truly. I actually try and avoid talking about him, if I'm honest.\n player:\n Really? Why?\n agent:\n !nervous\n Following in his pawprints... it's a lot to live up to. Grandpa did a lot in his lifetime, more than most ever dream of.\n !neutral\n !dejected\n We lost a great mind when he passed in the <#KONJUR>Eruption</>.\n player:\n Right... sorry. You must miss him a lot.\n agent:\n !neutral\n !gesture\n ... I just hope he's proud of all this. I wasn't much help to him while he was alive, but I can at least try to protect his legacy.\n !happy\n !shocked\n A-anyways, he'd tell us to stop rambling about the past, and start pushing towards our <#KONJUR>{name.konjur}</>-perfected future!\n !happy\n !point\n So what do you say, Hunter? Ready to get back out there?\n player:\n Ready. And {name.npc_scout}? Your Grandpa would be very proud of you. I know it.\n agent:\n !happy\n !nervous\n Oh, hah, thanks, Hunter. Oh dear. Am I turning red?"
msgstr ""

#: Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_BYE
msgctxt "Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_BYE"
msgid "Yeah, same here. I'd better get after more {name_multiple.konjur_heart}!"
msgstr ""

#: Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_THINKIN
msgctxt "Convo.after_insert_heart_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_THINKIN"
msgid "Penny for your thoughts? <z 0.7>Unrelated: Can I borrow a penny?</>"
msgstr ""

#: Convo.after_insert_heart_scout_owl.HUB0.convo.giver.STATE_0.ANSWER_1
msgctxt "Convo.after_insert_heart_scout_owl.HUB0.convo.giver.STATE_0.ANSWER_1"
msgid "agent:\n !happy\n !nervous\n Oh, I don't know <i>that</> much. It was my Grandpa who was a {name.c_konjur} genius. As a kit, I watched him work on all kinds of amazing things.\n !notebook\n Fortunately, a chest of his research notes was saved during the <#KONJUR>Eruption</>. I've pored over them every day for the past 10 years. \n !gesture\n It's how I was inspired to modify one of his <#KONJUR>{name_multiple.town_grid_cryst}</> so it could generate a <#KONJUR>Bubble Shield</>.\n player:\n Wow. You must really take after your Grandpa. \n agent:\n !happy\n !shrug\n I should be so lucky. With so little <#KONJUR>{name.konjur}</> in <#BLUE>The Brinks</>, not to mention my <#KONJUR>{name.konjur}</> allergy, I couldn't properly test anything I dreamt up. Including the <#KONJUR>Bubble Shield</>.\n !laugh\n I'm amazed the darn thing actually works!\n !nervous\n Oh! Uh--don't tell anyone I said that, please. Me being the fearless leader of the <#RED>{name.foxtails}s</> and everything. \n player:\n You really need to give yourself more credit.\n agent:\n !happy\n !laugh\n You sound like <#BLUE>{name.npc_dojo_master}</>! Next you'll be complaining about your \"gall-darn knees!\"\n !gruffnod\n But in all sincerity, thank you. \n !happy\n !point\n So what do you say, Hunter? Ready to get back out there?"
msgstr ""

#: Convo.after_insert_heart_scout_owl.HUB0.convo.giver.STATE_0.END
msgctxt "Convo.after_insert_heart_scout_owl.HUB0.convo.giver.STATE_0.END"
msgid "Let's do this!"
msgstr ""

#: Convo.after_insert_heart_scout_owl.HUB0.convo.giver.STATE_0.QUESTION_1
msgctxt "Convo.after_insert_heart_scout_owl.HUB0.convo.giver.STATE_0.QUESTION_1"
msgid "How did you learn so much about this stuff?"
msgstr ""

#: Convo.defeated_boss_scout_bnd.ATTRACT0.convo.giver.STATE_0.ANSWER_1A
msgctxt "Convo.defeated_boss_scout_bnd.ATTRACT0.convo.giver.STATE_0.ANSWER_1A"
msgid "agent:\n !happy\n !agree\n I'll say. Lucky for us, our Hunter's too crafty to fall for its tricks!\n !gesture\n Now, don't forget to put its <#KONJUR>{name.i_konjur_heart}</> in our modded <#KONJUR>{name.i_town_grid_cryst}</> there at the center of camp."
msgstr ""

#: Convo.defeated_boss_scout_bnd.ATTRACT0.convo.giver.STATE_0.QUESTION_1A
msgctxt "Convo.defeated_boss_scout_bnd.ATTRACT0.convo.giver.STATE_0.QUESTION_1A"
msgid "That {name.bandicoot} was one sly customer."
msgstr ""

#: Convo.defeated_boss_scout_bnd.ATTRACT0.convo.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_bnd.ATTRACT0.convo.giver.STATE_0.TALK"
msgid "agent:\n !happy\n !agree\n I'm still haunted by your fight with <#RED>{name.bandicoot}</>, Hunter. \n !neutral\n !dejected\n Honestly, I'm just glad it's over. That was a tough fight to watch... I mean, literally.\n !shocked\n I swear I was seeing double through half of it. Not exactly ideal when I'm trying to keep the <#RED>{name.i_damselfly}</> flying straight."
msgstr ""

#: Convo.defeated_boss_scout_eggzy.ATTRACT0.convo.giver.STATE_0.END
msgctxt "Convo.defeated_boss_scout_eggzy.ATTRACT0.convo.giver.STATE_0.END"
msgid "It'll be okay, {name.npc_scout}. I'll be right back."
msgstr ""

#: Convo.defeated_boss_scout_eggzy.ATTRACT0.convo.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_eggzy.ATTRACT0.convo.giver.STATE_0.TALK"
msgid "agent:\n !neutral\n !dejected\n Hey, Hunter. It's good you defeated <#RED>{name.eggzy}</> and all, but I can't shake this feeling... \n !gesture\n They're an orphan, like a lot of folks in <#BLUE>the Brinks.</>\n !dejected\n Like me. \n !closedeyes\n <z 0.7><i>... Re-burying emotions... Deeper...</></>\n !closedeyes\n <z 0.7><i>...............</></>\n !happy\n !clap\n Woo! Great job, Hunter! Now, don't forget to put that <#KONJUR>{name.i_konjur_heart}</> in the <#KONJUR>{name.i_town_grid_cryst}</>!"
msgstr ""

#: Convo.defeated_boss_scout_grimhollow.ATTRACT0.convo.giver.STATE_0.END
msgctxt "Convo.defeated_boss_scout_grimhollow.ATTRACT0.convo.giver.STATE_0.END"
msgid "Will do!"
msgstr ""

#: Convo.defeated_boss_scout_grimhollow.ATTRACT0.convo.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_grimhollow.ATTRACT0.convo.giver.STATE_0.TALK"
msgid "agent:\n !neutral\n !agree\n Not the rescue we expected, obviously, but we still made progress. \n !gesture\n We found the door to <#BLUE>Grandpa's</> lab, confirmation that he <i>is</> alive, and a plan for how to get in. \n player:\n And <#BLUE>{name.npc_refiner}</> gave you the rest of your <#BLUE>Grandpa's</> <#RED>Diary</>. Are you going to read it?\n agent:\n !think\n ... Yes. I will. It will have more answers... I'm not sure I'm ready to hear them, however. \n player:\n Whatever it says, remember: you are not your <#BLUE>Grandpa</>. \n agent:\n !neutral [keep-for-room]\n !agree\n Sure. Of course not. Of course not.\n !think\n Suppose it's time to get after those <#RED>Key Fragments</> to open the lab door, eh, Hunter?  \n !point\n But first, put that <#KONJUR>{name.i_konjur_heart}</> in my modified <#KONJUR>{name.i_town_grid_cryst}</> for some more power."
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.ANSWER_HONEST
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.ANSWER_HONEST"
msgid "agent:\n !neutral\n !dubious\n Really? Oh dear...\n !happy\n !shrug\n Well, um, I would never have guessed!"
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.ANSWER_MODEST
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.ANSWER_MODEST"
msgid "agent:\n !happy\n !laugh\n Oh, no need to be modest--you just did something very few have ever even dared to attempt! Own it!"
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.QUESTION_HONEST
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.QUESTION_HONEST"
msgid "Did I? All I remember is screaming in my head the entire time."
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.QUESTION_MODEST
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.QUESTION_MODEST"
msgid "Heh. No biggie."
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.TALK"
msgid "agent:\n !neutral\n !shocked\n That was... <i>incredible!</> I can't believe you downed a <#RED>{name.megatreemon}</> on your first try!"
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.TALK2
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT0.congrats.giver.STATE_0.TALK2"
msgid "agent:\n !happy\n !think\n I think you might become a Hunter to rival <#BLUE>{name.npc_dojo_master}</> in his heyday.\n !happy\n !point\n Speaking of which, you should check in with <#BLUE>{name.npc_dojo_master}</> if you haven't already.\n player:\n <#RED>[Show them the Heart-Shaped {name.konjur} Crystal]</> Would he know anything about this weird rock the {name.megatreemon} dropped?\n agent:\n !neutral\n !shocked\n Egads! In all the commotion I almost forgot!\n !happy\n !point\n That right there is a <#KONJUR>{name.i_konjur_heart}</>. It's <i>very</> important to our expedition.\n !happy\n !gesture\n Can you do me a favour? Place <#RED>{name.megatreemon}'s</> <#KONJUR>{name.i_konjur_heart}</> in the modified <#KONJUR>{name.i_town_grid_cryst}</> here.\n !neutral\n !nervous\n Oh gosh oh gosh oh gosh. I really hope this works, Hunter..."
msgstr ""

#: Convo.defeated_boss_scout_mt.ATTRACT1.congrats.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_mt.ATTRACT1.congrats.giver.STATE_0.TALK"
msgid "agent:\n !happy\n !shocked\n You really did it! You took down the <#RED>{name.megatreemon}</> that swatted the <#RED>{name.i_damselfly}</> out of the sky!\n !happy\n !dejected\n What a relief. Maybe now I'll be able to unclench my jaw when I'm flying over the forest.\n player:\n <#RED>[Show them the Heart-Shaped {name.konjur} Crystal]</> Oh, by the way, {name.megatreemon} dropped this.\n agent:\n !happy\n !shocked\n Ah! You found it! A <#KONJUR>{name.i_konjur_heart}</>!\n !point\n Hunter... would you please place it in the modified <#KONJUR>{name.i_town_grid_cryst}</>?\n !happy\n !nervous\n Oh gosh oh gosh oh gosh. Let's hope this works..."
msgstr ""

#: Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.ANSWER_1
msgctxt "Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.ANSWER_1"
msgid "agent:\n !happy\n !laugh\n Yikes! Good to know! Alright, go pop that <#KONJUR>{name.konjur_heart}</> into the modified <#KONJUR>{name.i_town_grid_cryst}</>."
msgstr ""

#: Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.END_OPT
msgctxt "Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.END_OPT"
msgid "Alright!"
msgstr ""

#: Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.QUESTION_1
msgctxt "Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.QUESTION_1"
msgid "You should see my high fives! 'Up top!' <i>(Explosion Sound)</>"
msgstr ""

#: Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_owl.ATTRACT0.convo.giver.STATE_0.TALK"
msgid "agent:\n !happy\n !clap\n Amazing that you got <#RED>{name.owlitzer}'s</> <#KONJUR>{name.konjur_heart}</>!\n !think\n She's so tough, it's almost hard to believe she's gone...\n !laugh\n I might need you to pinch me, to make sure I'm not dreaming.\n !neutral\n !think\n ... On second thought, don't. I've seen you fight. Your idea of a 'pinch' might lead to some serious injury."
msgstr ""

#: Convo.defeated_boss_scout_sdmnt.ATTRACT0.convo.giver.STATE_0.END
msgctxt "Convo.defeated_boss_scout_sdmnt.ATTRACT0.convo.giver.STATE_0.END"
msgid "You bet. And don't worry, {name.npc_scout}. We'll find your Grandpa."
msgstr ""

#: Convo.defeated_boss_scout_sdmnt.ATTRACT0.convo.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_sdmnt.ATTRACT0.convo.giver.STATE_0.TALK"
msgid "agent:\n !neutral\n !dejected\n You know, I've been thinking of <#RED>{name.sedament}</>, and I feel... kinda bad. Behind that granite facade was just a little crow, defending its nest. \n !neutral\n !think\n That said, the crow <i>was</> a <#RED>{name.rot}</>, <i>and</> we needed its <#KONJUR>{name.i_konjur_heart}</>, <i>and</> it's still alive, so... \n !happy\n !clap\n Guilt: absolved!  \n !neutral\n !dejected\n But no Grandpa. While you fought, his <#KONJUR>{name.teffrometer}</> signature leapt to another location. They're moving him around!\n player:\n That's weird, right? {name.rot}'s known for mindless violence, not playing keep-away...\n agent:  \n !think\n That <i>is</> very weird... as in, very never-happens-at-all-ever-weird, indeed. \n !point\n Hm. Best we prepare for the worst. Put that <#KONJUR>{name.i_konjur_heart}</> in our modded-out <#KONJUR>{name.i_town_grid_cryst}</> for more power, Hunter."
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_BACKLATER
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_BACKLATER"
msgid "agent:\n !happy\n !greet\n Of course. Talk soon, Hunter!"
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_BUBBLE
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_BUBBLE"
msgid "agent:\n !happy\n !clap\n Sometimes, I catch myself staring up at it and it feels like I'm dreaming. \n !neutral\n !dejected\n And then I'm flooded with embarrassment. \n player:\n \"Embarrassment\"? \n agent:\n !neutral\n !gesture\n At how much I believed <#BLUE>{name.npc_grandpa}</> would save us. As though he were some superpowered, infallible, genius godhead. \n !disagree\n But seeing him after all those years... he was just an old fox who took it all on by himself and failed. Utterly. \n !gruffnod\n Seeing that, I knew we could save ourselves--we just had to band together and do the work, dang it! \n player:\n Oh heck yeah!\n agent:\n !happy\n !laugh\n I swear, you and <#BLUE>{name.npc_refiner}</> have dragged my vocabulary through the... <z 0.7>flippin'</> mud! Hahaha!"
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_FOXTAILS
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_FOXTAILS"
msgid "agent:\n !happy\n !bliss\n This team... \n !dejected\n Despite facing utter disaster from Day One, culminating in a threat to everything they know and love brought on by my own flesh and blood... \n !gruffnod\n They've stuck together and shown true resilience, courage, and determination. You especially, Hunter. \n player:\n You, too, {name.npc_scout}. You're not sneaking off without some shine on you!\n agent:\n !happy\n !laugh\n I wouldn't dream of it! \n !think\n I finally accept that <i>I'm</> a part of this team--not my Grandpa's notes or legacy or whatever. Me. \n !gruffnod\n <#BLUE>{name.npc_scout} {name.flitt_lastname}</>. {name.job_scout} extraordinaire of the <#RED>{name_multiple.foxtails}</>!\n player:\n Speaking of: \"{name_multiple.foxtails}\" on three? \n agent:\n !happy\n !clap\n Oh! Yes! 1... 2... 3!\n player:\n {name_multiple.foxtails}!\n agent:\n !happy\n !dubious\n \"Uh, did you mean ON three, dude? Or, like, right AFTER three? Oh my flippin' head....\"\n player:\n Is that supposed to be an impression of <i>me,</> {name.npc_scout}?? I never!\n agent:\n !happy\n !laugh\n Ah, your face, Hunter! Charmingly expressionless as ever. \n !bliss\n Oh, and <#RED>{name_multiple.foxtails}</>!"
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_GRANDPA
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.ANSWER_GRANDPA"
msgid "agent:\n !neutral\n !disagree\n No, I haven't. \n !dubious\n If I'm honest, Hunter? I can't say I <i>want</> to. \n !dejected\n Back when we defeated him, I'd hoped he'd come back with us. But he... he chose not to... \n !think\n I'd like to think <#BLUE>{name.npc_grandpa}'s</> doing better, wherever he is. That he's left the <#KONJUR>Primeval {name.konjur}</> behind. \n !closedeyes\n And that <i>it's</> left <i>him</> behind...\n !shrug\n But that's out of my control. I'm moving on and doing what <i>I</> can to make this world a better place. \n !gesture\n Anything else you want to talk about? I'm sure you've got a lot on your mind, one year on..."
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_BACKLATER
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_BACKLATER"
msgid "I think it's time to go bash some {name_multiple.rot}, y'know?"
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_BUBBLE
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_BUBBLE"
msgid "You can be proud your Bubble Shield is up and running, right?"
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_FOXTAILS
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_FOXTAILS"
msgid "How do you feel the {name_multiple.foxtails} are doing these days?"
msgstr ""

#: Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_GRANDPA
msgctxt "Convo.defeated_boss_scout_tefframech.HUB0.convo.giver.STATE_0.QUESTION_GRANDPA"
msgid "Have you heard from your Grandpa in the year since we defeated him?"
msgstr ""

#: Convo.defeated_boss_scout_thchr.ATTRACT0.convo.giver.STATE_0.ANSWER_1A
msgctxt "Convo.defeated_boss_scout_thchr.ATTRACT0.convo.giver.STATE_0.ANSWER_1A"
msgid "agent:\n !happy\n !gruffnod\n As do you! I'd call for an encore, but it's curtains for them, and we have their <#KONJUR>{name.i_konjur_heart}</> to put in our modded <#KONJUR>{name.i_town_grid_cryst}</>!\n !gesture\n Wanna do the honours?"
msgstr ""

#: Convo.defeated_boss_scout_thchr.ATTRACT0.convo.giver.STATE_0.QUESTION_1A
msgctxt "Convo.defeated_boss_scout_thchr.ATTRACT0.convo.giver.STATE_0.QUESTION_1A"
msgid "It really knew how to shred."
msgstr ""

#: Convo.defeated_boss_scout_thchr.ATTRACT0.convo.giver.STATE_0.TALK
msgctxt "Convo.defeated_boss_scout_thchr.ATTRACT0.convo.giver.STATE_0.TALK"
msgid "agent:\n !neutral\n !think\n Hunter, that was a performance I'll never forget. You deserve a standing ovation for taking down these <#RED>{name_multiple.rot_boss}</>.\n !happy\n !shrug\n It strikes me, <#RED>{name.thatcher}</> just wanted an audience. I almost feel bad for it... <i>almost.</>"
msgstr ""

#: Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_1
msgctxt "Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_1"
msgid "agent:\n !happy\n !agree\n Mm-hm! You've truly found your footing since we got here."
msgstr ""

#: Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_2A
msgctxt "Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_2A"
msgid "agent:\n !happy\n !shocked\n Ah-! Me? Oh no, no, no, you deserve the credit for your hard work! I'm just glad to help where I can.\n !gesture\n Congrats on your win, Hunter."
msgstr ""

#: Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_2B
msgctxt "Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.ANSWER_2B"
msgid "agent:\n !happy\n !point\n You really are! You're doing the <#RED>{name_multiple.foxtails}</> proud.\n !clap\n Congrats on your win, Hunter."
msgstr ""

#: Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_1
msgctxt "Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_1"
msgid "I really downed that {name.yammo_miniboss}, didn't I?"
msgstr ""

#: Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_2A
msgctxt "Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_2A"
msgid "A lot of that is thanks to you."
msgstr ""

#: Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_2B
msgctxt "Convo.defeated_miniboss_scout_mt.HUB0.convo.giver.STATE_0.QUESTION_2B"
msgid "I <i>do</> feel like I'm finding my groove!"
msgstr ""

#: Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_1
msgctxt "Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_1"
msgid "agent:\n !happy\n !shocked\n Um, only the most versatile chemical compound in the whole entire world!\n !think\n I love talking about <#KONJUR>{name.konjur}</>. Ask me whatever you want to know."
msgstr ""

#: Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2A
msgctxt "Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2A"
msgid "agent:\n !neutral\n !dejected\n Ugh, that's right. I forgot you were from the <#RED>Brinks</>.\n !gesture\n Less, uh, <i>educated</i> folks might think of <#KONJUR>{name.konjur}</> as \"magic\".\n !notebook\n But that's just because they're unable to explain its unusual properties."
msgstr ""

#: Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2B
msgctxt "Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2B"
msgid "agent:\n !shrug\n There are veins of it all over the earth-- some {name_multiple.job_konjurist} theorize the planet has a molten core of <#KONJUR>{name.konjur}</>.\n !gesture\n But before the disaster, the best industrial source of <#KONJUR>{name.konjur}</> was the mountain."
msgstr ""

#: Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2C
msgctxt "Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2C"
msgid "agent:\n !shrug\n Beats me.\n !happy\n !gesture\n Preliminary studies showed thickening in some areas of the brain after the ingestion of <#KONJUR>{name.konjur}</>.\n !neutral\n !dejected\n But sadly that research was in the early stages when the eruption hit, and is now lost entirely.\n !think\n I guess in a way you're a continuation of that research. That's sort of comforting."
msgstr ""

#: Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_3
msgctxt "Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_3"
msgid "agent:\n !neutral\n !gesture\n No.\n !notebook\n ...\n !dubious\n ...What?\n !shocked\n Oh! You think I've contradicted myself. Haha.\n !disagree\n No. Just because I'm not personally able to explain <#KONJUR>{name.konjur}</> yet, doesn't mean an explanation doesn't exist.\n !gesture\n It just means we have more to learn."
msgstr ""

#: Convo.dgn_1_what_is_konjur_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_4
