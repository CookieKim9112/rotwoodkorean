msgid "!neutral [keep-for-room]\n !shocked\n The Anti-<#RED>{name.rot}</> Security Systems my <#BLUE>Grandpa</> built are still active.\n !point\n They can't discern between <#RED>{name.rot}</> and not, so stay on guard.\n !think\n Hm. Not his <i>best</> design..."
msgstr ""

#: Quest.chat_fluff_fallback.QUIP.chitchat:[chitchat,in_quest_chat_fluff_fallback,location_grimhollow_volcano_r2,role_scout]NOT[has_killed_grimhollow,in_town].1
