#: STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_heavy.desc
msgctxt "STRINGS.ITEMS.WEAPON_MASTERY.BOW.bow_focus_heavy.desc"
msgid "Shoot a <#BLUE>piercing</> <#RED>Heavy</> arrow with <#BLUE>Focus</> timing that hits <#RED>three or more Targets</>. Damage is NOT reduced per pierce.\n"
"{name.tutorial_complete_in_town}"
msgstr "<#BLUE>집중</> 타이밍으로 <#BLUE>관통</> <#RED>강</> 화살을 쏴 <#RED>대상 3명 이상</>을 맞혀라. 관통해도 피해가 줄지 않는다.\n"
"{name.tutorial_complete_in_town}"

