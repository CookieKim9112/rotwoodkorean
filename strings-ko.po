msgctxt "STRINGS.ITEMS.POWERS.SKILL.polearm_extend.name"
msgid "As-You-Will"
msgstr "뜻대로"

#: STRINGS.ITEMS.POWERS.SKILL.polearm_javelin.desc
msgctxt "STRINGS.ITEMS.POWERS.SKILL.polearm_javelin.desc"
msgid "Throw your <#RED>{name.weapon_polearm}</> and if it hits a <#RED>Target</>, appear behind them with a backstab."
msgstr "<#RED>{name.weapon_polearm}</>을(를) 던져 <#RED>대상</>에게 적중하면, 등 뒤로 이동해 기습 공격을 가합니다."

