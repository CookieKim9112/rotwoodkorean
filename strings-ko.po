#: Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_1
msgctxt "Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_1"
msgid "agent:\n"
" !neutral\n"
" !gesture\n"
" To prevent <#KONJUR>{name.konjur}</> inhalation."
msgstr "agent:\n"
" !neutral\n"
" !gesture\n"
" <#KONJUR>{name.konjur}</>를 흡입하지 않으려고."

#: Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2
msgctxt "Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.ANSWER_2"
msgid "agent:\n"
" !notebook\n"
" Haha. <i>Oh</i> yeah.\n"
" !dubious\n"
" Anyway, want anything <#RED>Upgraded</>?"
msgstr "agent:\n"
" !notebook\n"
" 하하. <i>아</i> 맞다.\n"
" !dubious\n"
" 아무튼, 뭐 <#RED>강화</>할 거 있어?"

#: Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.QUESTION_1
msgctxt "Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.QUESTION_1"
msgid "Why do you wear that mask, {name.npc_konjurist}?"
msgstr "왜 그 마스크 쓰고 있어, {name.npc_konjurist}?"

#: Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.QUESTION_2
msgctxt "Convo.dgn_mask_powerupgrade.HUB0.convo.giver.STATE_0.QUESTION_2"
msgid "Err, I consume {name.konjur} regularly. Should I be worried?"
msgstr "어... 난 {name.konjur}를 자주 먹는데. 걱정해야 돼?"

#: Convo.dgn_mp_meet_refiner.AMBIENT0.dungeon_wrong_meet_quips.giver.QUIP.rescue_lottie_again:[in_convo_dgn_mp_meet_refiner.ambient0.dungeon_wrong_meet_quips.giver,role_refiner].1
msgctxt "Convo.dgn_mp_meet_refiner.AMBIENT0.dungeon_wrong_meet_quips.giver.QUIP.rescue_lottie_again:[in_convo_dgn_mp_meet_refiner.ambient0.dungeon_wrong_meet_quips.giver,role_refiner].1"
msgid "!happy\n"
" !greet\n"
" Dibs on whatever the <#RED>{name.damselfly}'s</> music situation is."
msgstr "!happy\n"
" !greet\n"
" 음악 관련은 <#RED>{name.damselfly}의</> 쪽이 뭐든 내가 먼저 찜."

#: Convo.dgn_mp_meet_refiner.AMBIENT1.dungeon_wrong_meet_quips.flitt.QUIP.rescue_lottie_again:[in_convo_dgn_mp_meet_refiner.ambient1.dungeon_wrong_meet_quips.flitt,role_scout].1
msgctxt "Convo.dgn_mp_meet_refiner.AMBIENT1.dungeon_wrong_meet_quips.flitt.QUIP.rescue_lottie_again:[in_convo_dgn_mp_meet_refiner.ambient1.dungeon_wrong_meet_quips.flitt,role_scout].1"
